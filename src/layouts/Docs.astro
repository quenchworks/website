---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;

const groups = [
  {
    title: 'Guides',
    items: [
      { label: 'Get started', href: '/docs/get-started' },
      { label: 'Migrate from Bitnami', href: '/docs/migrate' },
      { label: 'Verify a signature', href: '/docs/verify' },
      { label: 'SBOM & provenance', href: '/docs/sbom' },
      { label: 'Pin by digest', href: '/docs/pin-by-digest' },
      { label: 'Air-gapped install', href: '/docs/air-gapped' },
    ],
  },
  {
    title: 'Reference',
    items: [
      { label: 'Tags & versions', href: '/docs/tags' },
      { label: 'Configuration', href: '/docs/configuration' },
      { label: 'Licensing', href: '/docs/licensing' },
      { label: 'Troubleshooting', href: '/docs/troubleshooting' },
    ],
  },
];
const path = Astro.url.pathname.replace(/\/$/, '');

// Derive the GitHub source path for this page from the URL.
// /docs -> src/pages/docs/index.astro, /docs/verify -> src/pages/docs/verify.astro
const slug = path === '/docs' ? 'index' : path.replace(/^\/docs\//, '');
const sourcePath = `src/pages/docs/${slug}.astro`;
const editUrl = `https://github.com/quenchworks/website/edit/main/${sourcePath}`;

// Flattened, ordered list of all docs pages: the top-level index first,
// then Guides and Reference items in their declared order.
const flat = [{ label: 'Docs', href: '/docs' }, ...groups.flatMap((g) => g.items)];
const current = flat.findIndex((n) => n.href === path);
const prev = current > 0 ? flat[current - 1] : null;
const next = current >= 0 && current < flat.length - 1 ? flat[current + 1] : null;
---

<Base title={title} description={description}>
  <Header />
  <div class="mx-auto max-w-5xl px-5 py-16 lg:grid lg:grid-cols-[210px_1fr] lg:gap-12">
    <aside class="mb-10 lg:mb-0">
      <div class="lg:sticky lg:top-24">
        <a
          href="/docs"
          aria-current={path === '/docs' ? 'page' : undefined}
          class:list={[
            'font-mono text-xs uppercase tracking-widest transition-colors duration-200',
            path === '/docs' ? 'text-paper' : 'text-ash hover:text-paper',
          ]}
        >
          Docs
        </a>
        <nav class="mt-4 flex flex-col gap-5" aria-label="Docs">
          {
            groups.map((g) => (
              <div class="flex flex-col gap-1">
                <p class="px-3 font-mono text-[10px] uppercase tracking-widest text-ash/70">{g.title}</p>
                {g.items.map((n) => (
                  <a
                    href={n.href}
                    aria-current={path === n.href ? 'page' : undefined}
                    class:list={[
                      'rounded-lg px-3 py-2 text-sm transition-colors duration-200',
                      path === n.href ? 'bg-graphite font-medium text-paper' : 'text-ash hover:text-paper',
                    ]}
                  >
                    {n.label}
                  </a>
                ))}
              </div>
            ))
          }
        </nav>
      </div>
    </aside>

    <main class="max-w-2xl" data-pagefind-body data-pagefind-meta="type:Docs">
      <div class="doc">
        <slot />
      </div>

      <div class="mt-16 border-t border-line pt-5" data-pagefind-ignore>
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper"
        >
          Edit this page on GitHub
        </a>
      </div>

      {
        (prev || next) && (
          <nav class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-stretch sm:justify-between" aria-label="Pagination">
            {prev ? (
              <a
                href={prev.href}
                class="group flex flex-1 flex-col gap-1 rounded-xl border border-line px-4 py-3 transition-colors duration-200 hover:border-ash/40"
              >
                <span class="font-mono text-[10px] uppercase tracking-widest text-ash/70">Previous</span>
                <span class="text-sm text-ash transition-colors duration-200 group-hover:text-paper">&larr; {prev.label}</span>
              </a>
            ) : (
              <span class="hidden flex-1 sm:block" />
            )}
            {next ? (
              <a
                href={next.href}
                class="group flex flex-1 flex-col gap-1 rounded-xl border border-line px-4 py-3 text-right transition-colors duration-200 hover:border-ash/40"
              >
                <span class="font-mono text-[10px] uppercase tracking-widest text-ash/70">Next</span>
                <span class="text-sm text-ash transition-colors duration-200 group-hover:text-paper">{next.label} &rarr;</span>
              </a>
            ) : (
              <span class="hidden flex-1 sm:block" />
            )}
          </nav>
        )
      }
    </main>
  </div>
  <Footer />

  <style is:global>
    .doc h1 { font-size: 2.25rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
    .doc h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.01em; margin-top: 2.5rem; }
    .doc p { color: var(--color-ash); line-height: 1.7; margin-top: 1rem; }
    .doc h1 + p { margin-top: 1rem; }
    .doc ul { color: var(--color-ash); margin-top: 1rem; padding-left: 1.1rem; list-style: disc; }
    .doc li { margin-top: 0.4rem; }
    .doc a { color: var(--color-paper); text-underline-offset: 4px; }
    .doc a:hover { text-decoration: underline; }
    .doc code { font-family: var(--font-mono); font-size: 0.9em; }
    .doc p code, .doc li code { color: var(--color-paper); background: var(--color-graphite); padding: 0.1rem 0.35rem; border-radius: 4px; }
    .doc pre {
      margin-top: 1rem; overflow-x: auto; border-radius: var(--radius-xl);
      border: 1px solid var(--color-line); background: var(--color-graphite);
      padding: 1rem; font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-paper);
      line-height: 1.6;
    }
    .doc .lead { color: var(--color-ash); font-size: 1.05rem; }
    .doc hr { border: 0; border-top: 1px solid var(--color-line); margin: 2.5rem 0; }
    .doc table { width: 100%; margin-top: 1.25rem; border-collapse: collapse; font-size: 0.9rem; }
    .doc th, .doc td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--color-line); vertical-align: top; }
    .doc th { color: var(--color-paper); font-weight: 600; }
    .doc td { color: var(--color-ash); line-height: 1.55; }
  </style>
</Base>
