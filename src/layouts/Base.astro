---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl, rtlLangs, useTranslations } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  // The locales this particular page is actually published in. Defaults to all
  // three (most pages are fully translated). English-only pages (e.g. the
  // /alternative SEO landings) pass ['en'] so we never emit hreflang/og
  // alternates that point at a 404.
  locales?: ('en' | 'ar' | 'es')[];
}

const {
  title = 'QuenchWorks: hardened, 0-CVE Helm charts and container images',
  description = 'QuenchWorks is a free, open-source catalog of hardened, 0-CVE container images and signed Helm charts, built from source on Wolfi, cosign-signed, and pinned by digest. A vendor-neutral, drop-in alternative to the Bitnami catalog.',
  image = '/og.png',
  locales = ['en', 'ar', 'es'],
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dir = rtlLangs.includes(lang) ? 'rtl' : 'ltr';

// Open Graph locale code per language.
const ogLocale: Record<string, string> = { en: 'en_US', ar: 'ar_AR', es: 'es_ES' };

// Path with the locale prefix stripped, so we can build the same page under
// each locale for the hreflang alternates. Only emit alternates for the
// locales this page is actually published in.
const basePath = Astro.url.pathname.replace(/^\/(ar|es)(?=\/|$)/, '') || '/';
const alternates = locales.map((l) => ({
  lang: l,
  href: new URL(getRelativeLocaleUrl(l, basePath), Astro.site).href,
}));
// x-default points at the English (default-locale) version when present,
// otherwise the first available alternate.
const xDefault = (alternates.find((a) => a.lang === 'en') ?? alternates[0]).href;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// Structured data, tuned for entity disambiguation: an unrelated UK IT-consulting
// firm owns the exact-match domain quenchworks.com, so we give Google explicit,
// software-flavoured signals (SoftwareApplication, free Offer, sameAs to our
// authoritative profiles) so this project gets its own knowledge-graph entity
// rather than being merged with the consultancy or the Etsy shop.
const orgId = new URL('/#org', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: 'QuenchWorks',
      alternateName: ['Quench Works', 'quench-works'],
      url: new URL('/', Astro.site).href,
      logo: { '@type': 'ImageObject', url: new URL('/brand/logo.svg', Astro.site).href },
      image: ogImage.href,
      description:
        'QuenchWorks is a free, independent open-source project: a catalog of hardened, 0-CVE container images and signed Helm charts, built from source on Wolfi, cosign-signed, and pinned by digest. A vendor-neutral, drop-in alternative to the Bitnami catalog.',
      foundingDate: '2026',
      slogan: 'Hardened, 0-CVE container images and Helm charts.',
      knowsAbout: [
        'container images', 'Helm charts', 'Kubernetes', 'cloud-native', 'supply-chain security',
        '0-CVE images', 'Wolfi', 'apko', 'melange', 'cosign', 'SBOM', 'Bitnami alternative',
      ],
      sameAs: [
        'https://github.com/quenchworks',
        'https://artifacthub.io/packages/search?org=quenchworks',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': new URL('/#site', Astro.site).href,
      name: 'QuenchWorks',
      alternateName: 'QuenchWorks catalog',
      url: new URL('/', Astro.site).href,
      inLanguage: ['en', 'ar', 'es'],
      description,
      publisher: { '@id': orgId },
      about: { '@id': orgId },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': new URL('/#catalog', Astro.site).href,
      name: 'QuenchWorks catalog',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Linux, Kubernetes',
      url: new URL('/', Astro.site).href,
      description:
        'Hardened, 0-CVE container images and signed Helm charts for Redis, Harbor, Mattermost, PostgreSQL, cert-manager, Grafana, and 130+ more — a drop-in, vendor-neutral alternative to the Bitnami catalog.',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      publisher: { '@id': orgId },
    },
  ],
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Mark JS live before first paint so the reveal pre-state applies only when the observer can run. No-JS = visible. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0b0b0c" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="QuenchWorks" />
    <meta property="og:locale" content={ogLocale[lang]} />
    {alternates.filter((a) => a.lang !== lang).map((a) => <meta property="og:locale:alternate" content={ogLocale[a.lang]} />)}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="QuenchWorks: free, hardened, zero-CVE container images and signed Helm charts." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    <!-- Fonts (Inter + JetBrains Mono) are self-hosted via @fontsource, imported in global.css. -->

    <!-- Microsoft Clarity analytics (site-wide; is:inline so Astro emits it verbatim). -->
    <script is:inline type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', 'xjegkf3icr');
    </script>
  </head>
  <body class="min-h-dvh antialiased">
    <!-- First focusable element: a skip link, hidden until keyboard focus, that
         jumps past the header to the page's main content (see id="main"). Uses the
         global :focus-visible paper ring. -->
    <a
      href="#main"
      class="sr-only rounded-lg border border-line bg-graphite px-4 py-2 font-mono text-xs uppercase tracking-widest text-paper focus:not-sr-only focus:absolute focus:start-4 focus:top-4 focus:z-50"
    >
      {t('a11y.skipToContent')}
    </a>
    <slot />

    <script>
      // Reveal grids/lists on first view (sibling stagger). Reveal-once, then
      // unobserve. Skips entirely under reduced-motion (elements are visible by
      // default there, since the hidden pre-state is scoped to no-preference).
      const revealables = document.querySelectorAll('[data-reveal]');
      if (revealables.length && matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          },
          { rootMargin: '0px 0px -10% 0px' },
        );
        revealables.forEach((el) => io.observe(el));
      } else {
        revealables.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Copy buttons on every code block. Progressive enhancement: adds a button to
      //    each code block and copies its text content on click.
      const COPY =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      const CHECK =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';

      for (const pre of document.querySelectorAll('pre')) {
        // Expressive Code blocks render their own copy button; skip them so we
        // don't end up with two buttons on fenced MDX/MD code blocks.
        if (pre.closest('.expressive-code')) continue;
        if (pre.dataset.copyReady) continue;
        pre.dataset.copyReady = '1';
        pre.classList.add('group', 'relative');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Copy to clipboard');
        btn.className =
          'absolute end-2 top-2 inline-flex items-center justify-center rounded-md border border-line bg-graphite p-1.5 text-ash opacity-0 transition-opacity duration-150 hover:text-paper focus-visible:opacity-100 group-hover:opacity-100';
        btn.innerHTML = COPY;
        btn.addEventListener('click', async () => {
          const text = (pre.querySelector('code') ?? pre).textContent ?? '';
          try {
            await navigator.clipboard.writeText(text.trim());
            btn.innerHTML = CHECK;
            btn.classList.add('text-paper');
            setTimeout(() => {
              btn.innerHTML = COPY;
              btn.classList.remove('text-paper');
            }, 1500);
          } catch {
            /* clipboard unavailable; no-op */
          }
        });
        pre.appendChild(btn);
      }
    </script>
  </body>
</html>
