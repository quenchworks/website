---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Vendor order; QuenchWorks stays first so it keeps the highlighted column.
// Each `cells` array below has one entry per vendor, in this same order.
const vendors: string[] = ['QuenchWorks', 'Bitnami', 'Chainguard', 'Docker', 'RapidFort', 'Minimus'];

// Each cell is { v: short verdict, n?: short note }. Be factual, conservative, and fair.
// Where a fact could not be confirmed from a primary source, the verdict is hedged
// ("Varies", "Partial", "—") with a neutral note rather than a hard claim.
type Cell = { v: string; n?: string };
type Row = { label: string; cells: Cell[] };

const rows: Row[] = [
  {
    label: 'Price / free tier',
    cells: [
      { v: 'Free' },
      { v: 'Paid', n: 'Bitnami Secure Images is commercial; a latest-only hardened community set and a frozen legacy registry remain' },
      { v: 'Freemium', n: 'A small set of Starter images is free; the full catalog is a paid subscription' },
      { v: 'Free', n: 'Docker Hardened Images opened as free, Apache-2.0 open source in Dec 2025' },
      { v: 'Varies', n: 'Commercial platform; public pricing for image access is not published' },
      { v: 'Paid', n: 'Commercial; a free open-source program exists for eligible projects' },
    ],
  },
  {
    label: 'Built from source on Wolfi',
    cells: [
      { v: 'Yes' },
      { v: 'No', n: 'Debian-based hardening, not Wolfi' },
      { v: 'Yes', n: 'Wolfi-based' },
      { v: 'No', n: 'Built on Debian and Alpine' },
      { v: 'No', n: 'Curated / optimized upstream images, not a Wolfi rebuild' },
      { v: 'No', n: 'Proprietary from-source build, not Wolfi' },
    ],
  },
  {
    label: '0-CVE goal with daily rebuilds',
    cells: [
      { v: 'Yes', n: 'Hard Trivy gate; a fixable CVE fails the build' },
      { v: 'Yes', n: 'Near-zero-CVE goal; cadence not publicly specified here' },
      { v: 'Yes', n: 'Near-zero-CVE goal with frequent rebuilds' },
      { v: 'Yes', n: 'Near-zero-CVE goal; paid tiers add a remediation SLA' },
      { v: 'Yes', n: 'Near-zero-CVE goal via continuous hardening' },
      { v: 'Yes', n: 'Near-zero-CVE goal; paid tiers add a remediation SLA' },
    ],
  },
  {
    label: 'Signed (cosign keyless)',
    cells: [
      { v: 'Yes' },
      { v: 'Yes', n: 'Signed images' },
      { v: 'Yes' },
      { v: 'Yes' },
      { v: 'Yes', n: 'Cryptographic signing' },
      { v: 'Yes', n: 'Cosign signatures' },
    ],
  },
  {
    label: 'SBOM (SPDX or CycloneDX)',
    cells: [
      { v: 'Yes', n: 'SPDX' },
      { v: 'Yes' },
      { v: 'Yes' },
      { v: 'Yes', n: 'SPDX and CycloneDX' },
      { v: 'Yes' },
      { v: 'Yes' },
    ],
  },
  {
    label: 'SLSA build provenance',
    cells: [
      { v: 'Yes' },
      { v: 'Partial', n: 'Attestations vary by offering' },
      { v: 'Yes', n: 'SLSA Build Level 2' },
      { v: 'Yes', n: 'SLSA Build Level 3' },
      { v: 'Yes', n: 'SLSA Level 3 (per vendor)' },
      { v: 'Yes', n: 'SLSA Level 3-aligned (per vendor)' },
    ],
  },
  {
    label: 'Multi-arch (amd64 + arm64)',
    cells: [
      { v: 'Yes' },
      { v: 'Yes' },
      { v: 'Yes' },
      { v: 'Yes' },
      { v: 'Varies', n: 'Not confirmed across the catalog' },
      { v: 'Varies', n: 'Not confirmed from a primary source' },
    ],
  },
  {
    label: 'Helm charts included',
    cells: [
      { v: 'Yes' },
      { v: 'Yes', n: 'Behind the paid catalog' },
      { v: 'No', n: 'Images focused' },
      { v: 'Yes' },
      { v: 'Partial', n: 'Charts-compatible images; integrates with existing charts' },
      { v: 'Yes', n: 'Helm charts offered' },
    ],
  },
  {
    label: 'Charts pin images by digest',
    cells: [
      { v: 'Yes' },
      { v: 'Varies', n: 'Not confirmed here' },
      { v: 'n/a' },
      { v: 'Varies', n: 'Not confirmed here' },
      { v: 'n/a', n: 'No first-party charts' },
      { v: 'Varies', n: 'Not confirmed here' },
    ],
  },
  {
    label: 'License transparency, clean alternatives flagged',
    cells: [
      { v: 'Yes', n: 'Source-available apps are labeled, with an OSI-clean alternative named' },
      { v: 'Partial' },
      { v: 'Partial' },
      { v: 'Partial' },
      { v: 'Partial' },
      { v: 'Partial' },
    ],
  },
  {
    label: 'Open and free to verify',
    cells: [
      { v: 'Yes', n: 'Public images, charts, and build workflows' },
      { v: 'Partial', n: 'Full catalog gated behind a subscription' },
      { v: 'Partial', n: 'Full catalog gated behind a subscription' },
      { v: 'Yes', n: 'Free, open-source catalog with public attestations' },
      { v: 'Partial', n: 'Commercial platform; not a fully open catalog' },
      { v: 'Partial', n: 'Commercial; open-source program for eligible projects' },
    ],
  },
];

// Group the flat capability list into thematic sections so the table reads as
// a structured comparison, not one long list. Mapping is by row label, so the
// row data above stays the single source of truth.
const groupOrder = ['Access & cost', 'Build & hardening', 'Supply chain', 'Charts & licensing'] as const;
const rowGroup: Record<string, (typeof groupOrder)[number]> = {
  'Price / free tier': 'Access & cost',
  'Open and free to verify': 'Access & cost',
  'Built from source on Wolfi': 'Build & hardening',
  '0-CVE goal with daily rebuilds': 'Build & hardening',
  'Multi-arch (amd64 + arm64)': 'Build & hardening',
  'Signed (cosign keyless)': 'Supply chain',
  'SBOM (SPDX or CycloneDX)': 'Supply chain',
  'SLSA build provenance': 'Supply chain',
  'Helm charts included': 'Charts & licensing',
  'Charts pin images by digest': 'Charts & licensing',
  'License transparency, clean alternatives flagged': 'Charts & licensing',
};
const groupedRows = groupOrder.map((title) => ({ title, rows: rows.filter((r) => rowGroup[r.label] === title) }));

// Pick a visual treatment per verdict word without adding any color accent.
function tone(v: string): string {
  const yes = v.toLowerCase();
  if (yes === 'yes' || yes === 'free') return 'text-paper';
  // Everything else (No, Paid, Partial, Varies, Freemium, n/a, —) is muted.
  return 'text-ash';
}

// The handful of things that set QuenchWorks apart, called out above the grid.
const differentiators: { label: string; body: string }[] = [
  { label: 'Free, no account', body: 'Pull images and deploy charts with no subscription, no login, and no registry to add.' },
  { label: 'Fully public, verifiable', body: 'Images, charts, and the proof (SBOM and SLSA provenance) are public for anyone to check.' },
  { label: 'Charts pinned by digest', body: 'Signed Helm charts reference their image by sha256, never a moving tag.' },
  { label: 'License honesty', body: 'Source-available apps are labeled as such, each with an OSI-clean alternative named.' },
];

// One-line, neutral snapshot per vendor (same order as `vendors`); tier drives the pill.
const vendorMeta: { name: string; tier: string; blurb: string }[] = [
  { name: 'QuenchWorks', tier: 'Free', blurb: 'Independent, fully public hardened catalog. Wolfi-built images and signed Helm charts pinned by digest, no account needed.' },
  { name: 'Bitnami', tier: 'Paid', blurb: "Broadcom's commercial Bitnami Secure Images. The free community catalog was retired, leaving a frozen legacy registry behind." },
  { name: 'Chainguard', tier: 'Freemium', blurb: 'Premium Wolfi-based minimal images. A small Starter set is free; the full catalog is a paid subscription.' },
  { name: 'Docker', tier: 'Free', blurb: 'Docker Hardened Images, opened as a free, Apache-2.0 open-source catalog in late 2025. Built on Debian and Alpine.' },
  { name: 'RapidFort', tier: 'Varies', blurb: 'Curated, optimized images that strip attack surface from upstream containers. Commercial platform.' },
  { name: 'Minimus', tier: 'Paid', blurb: 'Proprietary from-source minimal images. Commercial, with a free program for eligible open-source projects.' },
];

// Pill treatment for a price tier; monochrome, with Free carrying the emphasis.
function pillTone(tier: string): string {
  return tier === 'Free' ? 'border-paper/40 text-paper' : 'border-line text-ash';
}
---

<Base
  title="QuenchWorks vs the hardened-image providers · Comparison"
  description="A factual, conservative comparison of QuenchWorks against Bitnami, Chainguard, Docker Hardened Images, RapidFort, and Minimus across price, hardening, signing, SBOMs, provenance, and Helm charts."
>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16" data-pagefind-body data-pagefind-meta="title:QuenchWorks vs Bitnami, Chainguard, Docker, RapidFort, Minimus,type:Compare">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">Compare</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">QuenchWorks vs the hardened-image providers</h1>
      <p class="mt-4 leading-relaxed text-ash">
        Hardened, low-CVE container images are now a crowded field: Bitnami (Broadcom), Chainguard,
        Docker Hardened Images, RapidFort, and Minimus all ship signed, minimal images with SBOMs and
        provenance. The differences are in access and approach. Bitnami moved its catalog to a
        commercial offering and froze a legacy registry; Chainguard gives a small free set and gates
        the rest behind a subscription; Docker opened its Hardened Images as free, Apache-2.0 source
        in late 2025; RapidFort and Minimus are commercial platforms. QuenchWorks is free, Wolfi-built,
        and fully public: images, signed charts pinned by digest, and build workflows anyone can read.
        The table below is conservative on purpose. Where we could not confirm a competitor fact from a
        primary source, we mark it "Varies" or "Partial" rather than guess. Verify every claim yourself.
      </p>
    </header>

    <!-- Where QuenchWorks is different -->
    <section class="mt-12">
      <h2 class="font-mono text-xs uppercase tracking-widest text-ash">Where QuenchWorks is different</h2>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          differentiators.map((d) => (
            <div class="rounded-xl border border-line bg-graphite p-5">
              <p class="text-sm font-semibold text-paper">{d.label}</p>
              <p class="mt-2 text-sm leading-relaxed text-ash">{d.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- The providers at a glance -->
    <section class="mt-12">
      <h2 class="font-mono text-xs uppercase tracking-widest text-ash">The providers at a glance</h2>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          vendorMeta.map((v) => (
            <div class:list={['rounded-xl border bg-graphite p-5', v.name === 'QuenchWorks' ? 'border-paper/40' : 'border-line']}>
              <div class="flex items-center justify-between gap-3">
                <p class="text-base font-semibold text-paper">{v.name}</p>
                <span class:list={['shrink-0 rounded border px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest', pillTone(v.tier)]}>{v.tier}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-ash">{v.blurb}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Feature-by-feature deep dive -->
    <h2 class="mt-14 font-mono text-xs uppercase tracking-widest text-ash">Feature by feature</h2>

    <!-- Desktop / tablet table -->
    <div class="mt-4 hidden overflow-x-auto rounded-2xl border border-line sm:block">
      <table class="w-full min-w-[56rem] border-collapse text-sm">
        <thead>
          <tr class="border-b border-line bg-graphite">
            <th class="w-1/4 min-w-[12rem] px-4 py-4 text-left font-mono text-[11px] uppercase tracking-widest text-ash">
              Capability
            </th>
            {
              vendors.map((v) => (
                <th
                  class:list={[
                    'px-4 py-4 text-left font-mono text-[11px] uppercase tracking-widest',
                    v === 'QuenchWorks' ? 'text-paper' : 'text-ash',
                  ]}
                >
                  {v}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            groupedRows.map((group) => (
              <Fragment>
                <tr class="border-b border-line bg-graphite/60">
                  <td colspan={vendors.length + 1} class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-[0.2em] text-ash">
                    {group.title}
                  </td>
                </tr>
                {group.rows.map((row) => (
                  <tr class="border-b border-line/70">
                    <td class="px-4 py-4 align-top font-medium text-paper">{row.label}</td>
                    {row.cells.map((cell, i) => (
                      <td class:list={['px-4 py-4 align-top', i === 0 ? 'bg-graphite/40' : '']}>
                        <span class:list={['font-medium', tone(cell.v)]}>{cell.v}</span>
                        {cell.n && <span class="mt-1 block text-xs leading-relaxed text-ash">{cell.n}</span>}
                      </td>
                    ))}
                  </tr>
                ))}
              </Fragment>
            ))
          }
        </tbody>
      </table>
    </div>

    <!-- Mobile: stacked cards per capability, grouped by category -->
    <div class="mt-4 space-y-8 sm:hidden">
      {
        groupedRows.map((group) => (
          <div>
            <h3 class="font-mono text-[10px] uppercase tracking-[0.2em] text-ash">{group.title}</h3>
            <div class="mt-3 space-y-3">
              {group.rows.map((row) => (
                <div class="rounded-xl border border-line bg-graphite p-4">
                  <p class="font-medium text-paper">{row.label}</p>
                  <dl class="mt-3 space-y-2">
                    {row.cells.map((cell, i) => (
                      <div class="flex items-baseline justify-between gap-3 border-t border-line/60 pt-2 first:border-0 first:pt-0">
                        <dt class:list={['font-mono text-[10px] uppercase tracking-widest', vendors[i] === 'QuenchWorks' ? 'text-paper' : 'text-ash']}>
                          {vendors[i]}
                        </dt>
                        <dd class="text-right">
                          <span class:list={['text-sm font-medium', tone(cell.v)]}>{cell.v}</span>
                          {cell.n && <span class="mt-0.5 block text-xs leading-relaxed text-ash">{cell.n}</span>}
                        </dd>
                      </div>
                    ))}
                  </dl>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 max-w-2xl text-sm leading-relaxed text-ash">
      Bitnami, Chainguard, Docker, RapidFort, and Minimus are all serious engineering, and this page
      is not a knock on any of them. Several of them ship excellent free options too. QuenchWorks
      exists to keep a fully free, fully public, no-account path open, with everything from images to
      charts to build workflows out in the open. Verify any claim here against each provider's own
      public sources before you rely on it.
    </p>

    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ash">
      Two related projects sit slightly outside this table: Google Distroless ships minimal,
      language-runtime base images (no app catalog or Helm charts), and Red Hat UBI provides
      redistributable enterprise base images (a base layer rather than ready-to-run app images). Both
      are worth knowing about, but they solve a different problem than a hardened application catalog.
    </p>

    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ash">
      QuenchWorks is independent and is not affiliated with, endorsed by, or sponsored by Bitnami,
      Broadcom, Chainguard, Docker, RapidFort, Minimus, Google, or Red Hat. All product names and
      trademarks are the property of their respective owners.
    </p>

    <section class="mt-12 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-base text-paper">Free, hardened, and yours to verify.</p>
      <p class="mt-2 text-sm text-ash">Browse the catalog or read the source. No account, no registry to add.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-2 font-mono text-xs uppercase tracking-widest">
        <a href="/charts" class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">Browse charts</a>
        <a href="/images" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">Browse images</a>
        <a href="/runtimes" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">Browse runtimes</a>
        <a href="https://github.com/quenchworks" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">GitHub</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
