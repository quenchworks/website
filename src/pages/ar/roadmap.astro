---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { images as catalog } from '../../data/images';
import { roadmap, roadmapTotal, roadmapCategories, byPriority, blockedCount, blockedList } from '../../data/roadmap';
import { localizedSummary } from '../../i18n/content';
import { categoryName } from '../../i18n/categories';
import { localizeUrl } from '../../i18n/ui';

const shipped = catalog.filter((e) => e.status === 'available');
const total = shipped.length + roadmapTotal;
const available = [...shipped].sort((a, b) => a.name.localeCompare(b.name));

const openItems = roadmap.filter((r) => !r.blocked);
const openTotal = openItems.length;
const shippedPct = Math.round((shipped.length / total) * 100);
const blockedPct = Math.round((blockedCount / total) * 100);
const roadmapPct = 100 - shippedPct - blockedPct;

const priorityLabel: Record<string, string> = { next: 'التالي', planned: 'مُخطّط', exploring: 'قيد الاستكشاف' };
const priorityBadge: Record<string, string> = {
  next: 'border border-paper/50 bg-paper/10 text-paper',
  planned: 'border border-ash/50 text-ash',
  exploring: 'border border-dashed border-ash/45 text-ash/70',
};
const grouped = roadmapCategories
  .map((cat) => ({ cat, items: openItems.filter((r) => r.category === cat).sort(byPriority) }))
  .filter((g) => g.items.length > 0);

const catsOf = <T extends { category: string }>(items: T[]) =>
  [...new Set(items.map((i) => i.category))]
    .sort()
    .map((cat) => ({ cat, items: items.filter((i) => i.category === cat) }));
const availableGrouped = catsOf(available);
const blockedGrouped = catsOf(blockedList);
---

<Base title="خارطة الطريق · QuenchWorks" description="ما هو مطروح الآن و180+ تطبيقًا في الطريق إلى كتالوج QuenchWorks، تغطّي قواعد البيانات والبنية التحتية وأدوات المطوّرين الأكثر طلبًا.">
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">خارطة الطريق</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">ما هو مطروح، وما هو التالي</h1>
      <p class="mt-4 leading-relaxed text-ash">
        {shipped.length} قاعدة بيانات وأداة مُحصّنة ومطروحة اليوم. في الأسفل ما هو في الطريق،
        خيارات OSI النظيفة أولًا. كل مُدخَل مبني من المصدر على Wolfi، ومفحوص حتى صفر ثغرات
        قابلة للإصلاح، وموقّع، ومثبّت بالبصمة الرقمية قبل أن ينتقل إلى المتاح.
      </p>
    </header>

    <!-- progress -->
    <section class="mt-12 rounded-2xl border border-line bg-graphite p-6 sm:p-8" aria-label="تقدّم الكتالوج">
      <div class="flex items-end justify-between gap-4">
        <div class="font-mono text-5xl font-bold tabular-nums leading-none tracking-tight">
          {shipped.length}<span class="text-ash">/{total}</span>
        </div>
        <div class="font-mono text-2xl font-bold tabular-nums">{shippedPct}%<span class="text-ash"> مطروح</span></div>
      </div>
      {/* شريط من ثلاثة أجزاء: مطروح + على خارطة الطريق + محجوبة = 100% من الإجمالي. */}
      <div class="mt-4 flex h-1.5 overflow-hidden rounded-full bg-ink" role="img" aria-label={`${shippedPct}% مطروح، ${roadmapPct}% على خارطة الطريق، ${blockedPct}% محجوبة — ${total} إجمالًا`}>
        <div class="h-full bg-paper" style={`width:${shippedPct}%`}></div>
        <div class="h-full bg-ash/40" style={`width:${roadmapPct}%`}></div>
        <div class="h-full bg-red-500/70" style={`width:${blockedPct}%`}></div>
      </div>
      <dl class="mt-6 grid grid-cols-3 gap-4 border-t border-line pt-5 text-center">
        {
          (
            [
              ['مطروح', shipped.length, shippedPct, 'text-paper'],
              ['على خارطة الطريق', openTotal, roadmapPct, 'text-ash'],
              ['محجوبة', blockedCount, blockedPct, blockedCount > 0 ? 'text-red-300' : 'text-ash'],
            ] as [string, number, number, string][]
          ).map(([label, n, pct, tone]) => (
            <div>
              <dd class="font-mono text-2xl font-bold tabular-nums">
                {n}<span class:list={['ml-1 text-sm font-medium', tone]}>{pct}%</span>
              </dd>
              <dt class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ash">{label}</dt>
            </div>
          ))
        }
      </dl>
    </section>

    {/* Roadmap item names are intentionally kept in English (proper nouns). */}
    <!-- available -->
    <details open class="group mt-16">
      <summary class="mb-6 flex cursor-pointer list-none items-center gap-4 [&::-webkit-details-marker]:hidden">
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">المتاح الآن</h2>
        <span class="h-px flex-1 bg-line"></span>
        <span class="font-mono text-xs tabular-nums text-ash">{shipped.length}</span>
        <span class="font-mono text-xs text-ash transition-transform duration-200 group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
      </summary>
      <div class="space-y-10">
        {
          availableGrouped.map((g) => (
            <details open class="group/cat">
              <summary class="mb-3 flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                <h3 class="text-sm font-semibold text-paper">{categoryName('ar', g.cat)}</h3>
                <span class="h-px flex-1 bg-line/60"></span>
                <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
                <span class="font-mono text-[10px] text-ash transition-transform duration-200 group-open/cat:rotate-90" aria-hidden="true">&rsaquo;</span>
              </summary>
              <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {g.items.map((e) => (
                  <li>
                    <a
                      href={localizeUrl('ar', `/images/${e.slug}`)}
                      class="group flex h-full flex-col justify-between gap-5 rounded-xl border border-line bg-graphite p-5 transition-colors duration-200 hover:border-paper/40"
                    >
                      <div class="flex items-start justify-between">
                        <span class="inline-flex size-10 items-center justify-center rounded-lg border border-line bg-ink">
                          <img src="/brand/icon-dark.svg" alt="" class="size-6" width="24" height="24" />
                        </span>
                        <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
                      </div>
                      <div>
                        <span class="block text-base font-semibold leading-tight">{e.name}</span>
                        <span class="mt-2 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                          <span class="rounded bg-ink px-2 py-0.5">{categoryName('ar', e.category)}</span>
                          <span class="rounded bg-ink px-2 py-0.5">{e.tier}</span>
                        </span>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </div>
    </details>

    <!-- held: built + tested, not shipped -->
    {
      blockedCount > 0 && (
        <details open class="group mt-16">
          <summary class="mb-6 flex cursor-pointer list-none items-center gap-4 [&::-webkit-details-marker]:hidden">
            <h2 class="font-mono text-xs uppercase tracking-widest text-paper">محجوبة &mdash; مبنية، غير مطروحة</h2>
            <span class="h-px flex-1 bg-line" />
            <span class="font-mono text-xs tabular-nums text-ash">{blockedCount}</span>
            <span class="font-mono text-xs text-ash transition-transform duration-200 group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
          </summary>
          <p class="-mt-3 mb-8 max-w-2xl text-sm text-ash">
            تُبنى وتُختبر بنجاح لكنها لا تصل بعد إلى <span class="text-paper">صفر ثغرات قابلة للإصلاح</span> &mdash; إذ يثبّت
            التطبيق أو أساسه اعتمادية دون الإصدار الذي يُصلح ثغرة معروفة، فنحجبها بدل طرح صورة مُعرّضة. تعود كل واحدة
            تلقائيًا فور إصدار المنبع للإصلاح. اضغط <span class="text-red-300">لماذا محجوبة؟</span> لمعرفة التثبيت الدقيق.
          </p>
          <div class="space-y-10">
            {blockedGrouped.map((g) => (
              <details open class="group/cat">
                <summary class="mb-3 flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                  <h3 class="text-sm font-semibold text-paper">{categoryName('ar', g.cat)}</h3>
                  <span class="h-px flex-1 bg-line/60"></span>
                  <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
                  <span class="font-mono text-[10px] text-ash transition-transform duration-200 group-open/cat:rotate-90" aria-hidden="true">&rsaquo;</span>
                </summary>
                <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                  {g.items.map((r) => (
                    <li class="flex h-full flex-col gap-3 rounded-xl border border-line/70 bg-graphite/50 p-5">
                      <div class="flex items-start justify-between gap-2">
                        <span class="text-base font-medium leading-tight text-paper/90">{r.name}</span>
                        <span
                          class="shrink-0 rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300"
                          role="img"
                          aria-label="مُختبَرة ومحجوبة: تعذّر الوصول إلى صفر ثغرات قابلة للإصلاح بسبب تثبيت اعتمادية من المنبع"
                        >
                          محجوبة
                        </span>
                      </div>
                      <p class="flex-1 text-sm leading-relaxed text-ash">{localizedSummary('ar', 'roadmap', r.name, r.note)}</p>
                      {r.blockedReason && (
                        <button
                          type="button"
                          data-blocked-open
                          data-name={r.name}
                          data-reason={r.blockedReason}
                          aria-haspopup="dialog"
                          class="self-start rounded-lg border border-red-500/40 bg-red-500/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-red-300 transition-colors duration-200 hover:bg-red-500/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-300"
                        >
                          لماذا محجوبة؟
                        </button>
                      )}
                      <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                        <span class="rounded bg-ink px-2 py-0.5">{categoryName('ar', r.category)}</span>
                        <span class="rounded bg-ink px-2 py-0.5">{r.license}</span>
                      </div>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        </details>
      )
    }

    <!-- on the roadmap, grouped by theme -->
    <details open class="group mt-16">
      <summary class="mb-6 flex cursor-pointer list-none items-center gap-4 [&::-webkit-details-marker]:hidden">
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">على خارطة الطريق</h2>
        <span class="h-px flex-1 bg-line"></span>
        <span class="font-mono text-xs tabular-nums text-ash">{openTotal}</span>
        <span class="font-mono text-xs text-ash transition-transform duration-200 group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
      </summary>
      <p class="-mt-3 mb-8 max-w-2xl text-sm text-ash">
        مرشّحات، لا التزامات. <span class="text-paper">التالي</span> = أقوى الخيارات القريبة؛
        ثم <span class="text-paper">مُخطّط</span> و<span class="text-paper">قيد الاستكشاف</span>. العناصر
        المُعلّمة بـ <span class="text-paper">تنبيه</span> متاحة المصدر (ليست OSI) ولن تُطرح إلا مع
        ملاحظة ترخيص واضحة وذِكر البديل النظيف. (التطبيقات التي تُبنى لكنها لا تبلغ صفر ثغرات قابلة للإصلاح بعد
        موجودة في قسم <span class="text-red-300">المحجوبة</span> بالأعلى.) تُظهر كل بطاقة أيضًا كيف ستُطرح:
        <span class="text-paper">صورة + مخطط</span> لخدمة قابلة للنشر، أو
        <span class="text-paper">صورة فقط</span> لأداة أساس/سطر أوامر/جانبية (مثل busybox).
      </p>

      <div class="space-y-10">
        {
          grouped.map((g) => (
            <details open class="group/cat">
              <summary class="mb-3 flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                <h3 class="text-sm font-semibold text-paper">{categoryName('ar', g.cat)}</h3>
                <span class="h-px flex-1 bg-line/60"></span>
                <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
                <span class="font-mono text-[10px] text-ash transition-transform duration-200 group-open/cat:rotate-90" aria-hidden="true">&rsaquo;</span>
              </summary>
              <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {g.items.map((r) => (
                  <li class="flex h-full flex-col gap-3 rounded-xl border border-line/70 bg-graphite/50 p-5">
                    <div class="flex items-start justify-between gap-2">
                      <span class="text-base font-medium leading-tight text-paper/90">{r.name}</span>
                      <span
                        class:list={[
                          'shrink-0 rounded px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest',
                          priorityBadge[r.priority],
                        ]}
                      >
                        {priorityLabel[r.priority]}
                      </span>
                    </div>
                    <p class="flex-1 text-sm leading-relaxed text-ash">{localizedSummary('ar', 'roadmap', r.name, r.note)}</p>
                    {r.cleanAlternative && (
                      <p class="text-xs leading-relaxed text-ash">
                        <span class="font-mono uppercase tracking-widest text-paper/70">بديل نظيف:</span> {r.cleanAlternative}
                      </p>
                    )}
                    <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                      <span class="rounded border border-line px-2 py-0.5 text-paper/70">
                        {r.deliverable === 'image' ? 'صورة فقط' : 'صورة + مخطط'}
                      </span>
                      <span class="rounded bg-ink px-2 py-0.5">{r.license}</span>
                      {r.licenseClean === 'caution' && (
                        <span class="rounded border border-ash/50 px-2 py-0.5 text-paper/80">تنبيه</span>
                      )}
                      {r.licenseClean === 'agpl' && <span class="rounded bg-ink px-2 py-0.5">agpl</span>}
                    </div>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </div>
    </details>

    {
      blockedCount > 0 && (
        <section class="mt-16 rounded-2xl border border-line bg-graphite p-6 sm:p-8" aria-label="عن التطبيقات المحجوبة">
          <div class="flex items-center gap-3">
            <span class="rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300">محجوبة</span>
            <h2 class="font-mono text-xs uppercase tracking-widest text-paper">لماذا تُحجب بعض التطبيقات</h2>
          </div>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ash">
            لا تطرح QuenchWorks أي صورة تحمل ثغرة قابلة للإصلاح. بعض التطبيقات تُبنى بنظافة لكنها لا تبلغ هذا الحد بعد:
            إذ يثبّت التطبيق نفسه اعتمادية <em class="not-italic text-paper/90">دون</em> الإصدار الذي يصلح ثغرة معروفة،
            فإصلاحها يكسر قيوده المُعلَنة. تُعلَّم هذه بـ <span class="text-red-300">محجوبة</span>: مبنية ومُختبرة،
            ومحجوزة (غير مطروحة) حتى يُرخّي المنبع التثبيت أو يُرجِع الإصلاح. تنتقل إلى المتاح فور حدوث ذلك. لا شيء في
            الكتالوج حاليًا يحمل ثغرة معروفة قابلة للإصلاح.
          </p>
        </section>
      )
    }

    <section class="mt-16 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-ash">
        تريد إعطاء شيء أولوية؟{' '}
        <a href="mailto:info@quench-works.com?subject=App%20request" class="font-medium text-paper underline-offset-4 hover:underline">اطلب تطبيقًا</a>{' '}
        وسنُدرجه في خارطة الطريق.
      </p>
    </section>
  </main>

  <dialog
    id="blocked-dialog"
    aria-labelledby="bd-title"
    class="m-auto w-[calc(100%-2rem)] max-w-md rounded-xl border border-line bg-graphite p-0 text-paper backdrop:bg-ink/70 backdrop:backdrop-blur-sm"
  >
    <div class="p-6">
      <div class="flex items-center justify-between gap-3">
        <h2 id="bd-title" class="text-lg font-semibold tracking-tight"></h2>
        <span class="shrink-0 rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300">محجوبة</span>
      </div>
      <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-ash">مُختبَرة ومحجوزة: تعذّر الوصول إلى صفر ثغرات قابلة للإصلاح</p>
      <p id="bd-reason" class="mt-4 text-sm leading-relaxed text-ash"></p>
      <div class="mt-6 flex justify-end">
        <button
          id="bd-close"
          type="button"
          class="rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper"
        >
          إغلاق
        </button>
      </div>
    </div>
  </dialog>

  <script>
    const dlg = document.getElementById('blocked-dialog') as HTMLDialogElement | null;
    const title = document.getElementById('bd-title');
    const reason = document.getElementById('bd-reason');
    if (dlg && title && reason) {
      const render = (text: string) => {
        reason.replaceChildren();
        text.split('`').forEach((part, i) => {
          if (i % 2 === 1) {
            const code = document.createElement('code');
            code.className = 'rounded bg-ink px-1.5 py-0.5 font-mono text-[0.85em] text-paper';
            code.textContent = part;
            reason.appendChild(code);
          } else if (part) {
            reason.appendChild(document.createTextNode(part));
          }
        });
      };
      for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-blocked-open]')) {
        btn.addEventListener('click', () => {
          title.textContent = btn.dataset.name ?? '';
          render(btn.dataset.reason ?? '');
          dlg.showModal();
        });
      }
      document.getElementById('bd-close')?.addEventListener('click', () => dlg.close());
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) dlg.close();
      });
    }
  </script>
  <Footer />
</Base>
