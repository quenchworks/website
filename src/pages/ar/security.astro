---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const sections = [
  {
    h: 'صفر ثغرات قابلة للإصلاح، مفروضة',
    p: 'تمرّ كل صورة عبر بوابة Trivy تُفشل البناء عند أي ثغرة قابلة للإصلاح. نُعيد البناء وفق جدول، لأن الفحص النظيف لا يصف إلا اليوم الذي جرى فيه. النتيجة هدف متحرّك يُبقى نظيفًا، لا تدقيق لمرة واحدة.',
  },
  {
    h: 'مبنية من المصدر على Wolfi',
    p: 'نُجمّع كل تطبيق من المصدر باستخدام melange، ثم يجمّع apko صورة صغيرة تعمل بدون صلاحيات الجذر. لا توجد ملفات Dockerfile ولا شيء موروث من توزيعة أخرى، فلا يكون سطح الهجوم إلا ما يحتاجه التطبيق.',
  },
  {
    h: 'موقّعة، دون مفتاح',
    p: 'تُوقّع كل صورة وكل مخطط بـ cosign باستخدام GitHub OIDC (Sigstore). لا يوجد مفتاح طويل الأمد قد يتسرّب. يربط التوقيع القطعة الأثرية بمسار العمل الذي بناها، ويمكن لأي شخص التحقّق منه.',
  },
  {
    h: 'مثبّتة بالبصمة الرقمية',
    p: 'تشير المخططات إلى الصور عبر بصمة sha256، لا عبر وسم متغيّر. ما تُثبّته هو بالضبط القطعة الأثرية التي اجتازت البوابة ووُقّعت، دون أي مجال لانحراف وسم من تحتك.',
  },
];
---

<Base title="الأمان · Quenchworks" description="كيف يُبقي QuenchWorks الصور عند صفر ثغرات قابلة للإصلاح: مبنية من المصدر، موقّعة بـ cosign، مثبّتة بالبصمة الرقمية، ومُعاد بناؤها وفق جدول.">
  <Header />
  <main class="mx-auto max-w-3xl px-5 py-16">
    <p class="font-mono text-xs uppercase tracking-widest text-ash">الأمان</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">ثقة يمكنك التحقّق منها</h1>
    <p class="mt-4 text-ash">
      بُني QuenchWorks بحيث لا تضطر أبدًا لأن تأخذ كلامنا على عِلّاته. كل ما يلي قابل
      لإعادة الإنتاج وقابل للفحص من طرفيتك الخاصة.
    </p>

    <div class="mt-10 space-y-8">
      {
        sections.map((s) => (
          <section>
            <h2 class="text-xl font-semibold tracking-tight">{s.h}</h2>
            <p class="mt-2 leading-relaxed text-ash">{s.p}</p>
          </section>
        ))
      }
    </div>

    <section class="mt-10">
      <h2 class="text-xl font-semibold tracking-tight">تحقّق بنفسك</h2>
      <pre class="mt-3 overflow-x-auto rounded-xl border border-line bg-graphite p-4 font-mono text-sm text-paper"><code><span class="text-ash"># تأكّد من أن صورة بُنيت ووُقّعت بواسطة CI الخاص بنا (الصور بلا وسم latest)</span>
cosign verify ghcr.io/quenchworks/images/redis:8.8.0 \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com

<span class="text-ash"># الأمر نفسه ينطبق على أي مخطط، عبر وسم إصداره</span>
cosign verify ghcr.io/quenchworks/charts/redis:0.0.5 \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com</code></pre>
    </section>

    <section class="mt-10 rounded-xl border border-line bg-graphite p-6">
      <h2 class="text-lg font-semibold tracking-tight">الإبلاغ عن ثغرة</h2>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        وجدت شيئًا؟ يُرجى اتّباع عملية الإفصاح الواردة في سياسة الأمان لدينا.
      </p>
      <a
        href="https://github.com/quenchworks/.github/blob/main/SECURITY.md"
        class="mt-4 inline-flex rounded-lg border border-line px-4 py-2 font-mono text-xs uppercase tracking-widest text-paper transition-colors hover:bg-ink"
      >
        سياسة الأمان
      </a>
    </section>
  </main>
  <Footer />
</Base>
