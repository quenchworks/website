---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const links = [
  { label: 'الرئيسية', href: '/' },
  { label: 'المخططات', href: '/charts' },
  { label: 'الصور', href: '/images' },
  { label: 'التوثيق', href: '/docs' },
];
---

<Base
  title="غير موجود · Quenchworks"
  description="تعذّر العثور على تلك الصفحة. عُد إلى كتالوج QuenchWorks من الصور والمخططات المُحصّنة والخالية من الثغرات."
>
  <Header />
  <main class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-5 py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.25em] text-ash">خطأ</p>
    <p class="mt-4 font-mono text-7xl font-bold tracking-tight tabular-nums text-paper sm:text-8xl">404</p>
    <p class="mx-auto mt-6 max-w-md text-pretty text-base leading-relaxed text-ash sm:text-lg">
      سحبت هذه الصفحة وسمًا غير موجود. الرابط معطوب أو نُقلت الصفحة.
    </p>

    <nav class="mt-9 flex flex-wrap items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest" aria-label="روابط الاستعادة">
      {
        links.map((l, i) => (
          <a
            href={l.href}
            class={
              i === 0
                ? 'rounded-lg bg-paper px-3.5 py-2 font-semibold text-ink transition-transform duration-200 hover:scale-[1.02]'
                : 'rounded-lg border border-line px-3.5 py-2 text-paper transition-colors duration-200 hover:bg-graphite'
            }
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </main>
  <Footer />
</Base>
