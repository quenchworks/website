---
// One SEO landing per competitor, generated from the shared comparison data in
// src/data/compare.ts. Each page is "QuenchWorks vs <Vendor>": a per-vendor lead,
// then the feature-by-feature matrix narrowed to QuenchWorks vs that one vendor.
// Add/refine a competitor by editing the data module — the page follows.
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { vendors, rows, vendorMeta, vendorSlug, vendorIntro, tone } from '../../data/compare';

export function getStaticPaths() {
  // Every vendor except QuenchWorks (index 0) gets a "vs" page.
  return vendors
    .map((name, i) => ({ name, i }))
    .filter((v) => v.name !== 'QuenchWorks')
    .map((v) => ({ params: { vendor: vendorSlug(v.name) }, props: { name: v.name, index: v.i } }));
}

const { name, index } = Astro.props;
const meta = vendorMeta[index];
const intro = vendorIntro[vendorSlug(name)] ?? { headline: `QuenchWorks vs ${name}`, body: meta.blurb };

// Narrow each capability row to the two columns this page compares.
const compared = rows.map((r) => ({ label: r.label, quench: r.cells[0], rival: r.cells[index] }));

// Breadcrumb structured data (Alternatives > <vendor>) for richer search results.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Alternatives', item: new URL('/alternative', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: `QuenchWorks vs ${name}`, item: new URL(Astro.url.pathname, Astro.site).href },
  ],
};
---

<Base
  title={`QuenchWorks vs ${name} · A free, signed alternative`}
  description={`How QuenchWorks compares to ${name} across price, hardening, signing, SBOMs, SLSA provenance, and Helm charts — feature by feature, conservative and verifiable.`}
>
  <Header />
  <main
    class="mx-auto max-w-3xl px-5 py-16"
    data-pagefind-body
    data-pagefind-meta={`title:QuenchWorks vs ${name},type:Alternative`}
  >
    <p class="font-mono text-xs uppercase tracking-widest text-ash">
      <a href="/alternative" class="transition-colors hover:text-paper">Alternatives</a>
      <span class="text-ash/50">/</span> {name}
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{intro.headline}</h1>
    <p class="mt-4 leading-relaxed text-ash">{intro.body}</p>

    <div class="mt-6 flex flex-wrap gap-2 font-mono text-xs uppercase tracking-widest">
      <a href="/charts" class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">Browse charts</a>
      <a href="/docs/migrate" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">Migrate</a>
    </div>

    <!-- Feature-by-feature: QuenchWorks vs this vendor -->
    <h2 class="mt-14 font-mono text-xs uppercase tracking-widest text-ash">QuenchWorks vs {name}, feature by feature</h2>
    <div class="mt-4 space-y-3">
      {
        compared.map((r) => (
          <div class="rounded-xl border border-line bg-graphite p-5">
            <p class="font-mono text-[11px] uppercase tracking-widest text-ash">{r.label}</p>
            <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div>
                <p class="text-sm font-semibold text-paper">QuenchWorks</p>
                <p class:list={['mt-1 text-sm font-medium', tone(r.quench.v)]}>{r.quench.v}</p>
                {r.quench.n && <p class="mt-1 text-xs leading-relaxed text-ash">{r.quench.n}</p>}
              </div>
              <div class="border-t border-line/60 pt-4 sm:border-s sm:border-t-0 sm:ps-4 sm:pt-0">
                <p class="text-sm font-semibold text-ash">{name}</p>
                <p class:list={['mt-1 text-sm font-medium', tone(r.rival.v)]}>{r.rival.v}</p>
                {r.rival.n && <p class="mt-1 text-xs leading-relaxed text-ash">{r.rival.n}</p>}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-4 text-sm leading-relaxed text-ash">
      Conservative on purpose: where a {name} fact could not be confirmed from a primary source it is
      marked "Varies" or "Partial" rather than guessed. See the
      <a href="/compare" class="text-paper underline underline-offset-4 hover:no-underline">full comparison</a>
      across every provider, and verify every claim yourself on the
      <a href="/security" class="text-paper underline underline-offset-4 hover:no-underline">security</a> page.
    </p>

    <section class="mt-12 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-base text-paper">Free, signed, and yours to verify.</p>
      <p class="mt-2 text-sm text-ash">Browse the catalog or read the migration guide to switch.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-2 font-mono text-xs uppercase tracking-widest">
        <a href="/charts" class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">Browse all charts</a>
        <a href="/docs/migrate" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">Migration guide</a>
      </div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Base>
