---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { images } from '../../data/images';
import { charts } from '../../data/charts';
import { roadmap } from '../../data/roadmap';
import { PER_PAGE } from './v1/_data';

const resources = [
  { name: 'images', total: images.length, desc: 'Hardened container images in the catalog.' },
  { name: 'charts', total: charts.length, desc: 'Signed Helm charts in the catalog.' },
  { name: 'roadmap', total: roadmap.length, desc: 'Apps on deck, not yet built.' },
];
const pre = 'mt-3 overflow-x-auto rounded-lg border border-line bg-graphite/40 p-4 font-mono text-xs text-ash';
---

<Base title="API · Quenchworks" description="The free QuenchWorks JSON API: hardened images, signed charts, and the roadmap as paginated JSON.">
  <Header />
  <main class="mx-auto max-w-3xl px-5 py-16">
    <p class="font-mono text-xs uppercase tracking-widest text-ash">API · v1</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">JSON API</h1>
    <div class="mt-6 space-y-5 leading-relaxed text-ash">
      <p>
        A free, read-only JSON API over the catalog. It is prerendered as static JSON
        (the dataset is small and the site is static), so it is fast, cacheable, and
        needs no key. Base path <code class="font-mono text-paper">/api/v1</code>.
      </p>
    </div>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">Collections</h2>
    <p class="mt-2 text-ash">Each resource returns its full list under a small envelope.</p>
    <ul class="mt-4 space-y-2">
      {resources.map((r) => (
        <li class="font-mono text-sm">
          <a class="text-paper underline" href={`/api/v1/${r.name}.json`}>GET /api/v1/{r.name}.json</a>
          <span class="text-ash"> — {r.desc} ({r.total} items)</span>
        </li>
      ))}
    </ul>
    <pre class={pre}>{`{
  "apiVersion": "v1",
  "resource": "images",
  "total": ${images.length},
  "data": [ /* every item */ ]
}`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">Pagination</h2>
    <p class="mt-2 text-ash">
      Pages are prerendered at {PER_PAGE} items each, so the page number lives in the
      path (not a <code class="font-mono text-paper">?page</code> query). Each page carries
      <code class="font-mono text-paper">meta</code> + <code class="font-mono text-paper">links</code>.
    </p>
    <p class="mt-3 font-mono text-sm">
      <a class="text-paper underline" href="/api/v1/images/1.json">GET /api/v1/&lbrace;resource&rbrace;/&lbrace;page&rbrace;.json</a>
    </p>
    <pre class={pre}>{`{
  "apiVersion": "v1",
  "resource": "images",
  "page": 2, "perPage": ${PER_PAGE}, "total": ${images.length},
  "totalPages": ${Math.ceil(images.length / PER_PAGE)},
  "links": {
    "self": "/api/v1/images/2.json",
    "first": "/api/v1/images/1.json",
    "last":  "/api/v1/images/${Math.ceil(images.length / PER_PAGE)}.json",
    "prev":  "/api/v1/images/1.json",
    "next":  "/api/v1/images/3.json",
    "collection": "/api/v1/images.json"
  },
  "data": [ /* this page */ ]
}`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">Examples</h2>
    <pre class={pre}>{`# whole catalog
curl https://quench-works.com/api/v1/images.json

# one page
curl https://quench-works.com/api/v1/charts/2.json

# filter client-side (the dataset is small — fetch once, filter in JS)
const all = await fetch('/api/v1/images.json').then(r => r.json());
const dbs = all.data.filter(i => i.category === 'Relational' && i.tier === 'critical');`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">Notes</h2>
    <ul class="mt-3 list-disc space-y-1 ps-5 text-ash">
      <li>Read-only, no auth, CORS-open, cached for an hour.</li>
      <li>Item fields match what the catalog pages show (slug, name, category, tier, license, versions, …).</li>
      <li>Server-side filtering via <code class="font-mono text-paper">?query</code> is not offered: static hosting can't read query strings. Filter the collection client-side, or open an issue if you need live query endpoints (they'd need SSR).</li>
    </ul>
  </main>
  <Footer />
</Base>
