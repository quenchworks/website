---
import Docs from '../../layouts/Docs.astro';

const pages = [
  { href: '/docs/get-started', h: 'Get started', p: 'Install a chart and pull an image. No repo to add, no account needed.' },
  { href: '/docs/verify', h: 'Verify a signature', p: 'Check an image or chart with cosign. Keyless, tied to the build workflow.' },
  { href: '/docs/pin-by-digest', h: 'Pin by digest', p: 'Run exactly what was scanned and signed, with no moving tag.' },
];
---

<Docs title="Docs · Quenchworks" description="How to install, verify, and pin QuenchWorks images and charts.">
  <h1>Docs</h1>
  <p class="lead">Short, practical guides for using the catalog. Install something, check that you can trust it, then pin it.</p>

  <div class="mt-8 grid gap-3 sm:grid-cols-1">
    {
      pages.map((pg) => (
        <a href={pg.href} class="group rounded-xl border border-line bg-graphite p-5 no-underline transition-colors duration-200 hover:border-paper/40">
          <div class="flex items-center justify-between gap-3">
            <span class="text-base font-semibold text-paper">{pg.h}</span>
            <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
          </div>
          <p class="mt-1">{pg.p}</p>
        </a>
      ))
    }
  </div>
</Docs>
