---
import Docs from '../../layouts/Docs.astro';
import { getCollection } from 'astro:content';

const guarantees = [
  ['0 fixable CVEs', 'A hard Trivy gate; a fixable CVE fails the build, so nothing ships dirty.'],
  ['Built from source', 'Compiled on Wolfi with melange + apko. No Dockerfile, nothing inherited.'],
  ['Nonroot, read-only', 'uid 1001, read-only root filesystem, all capabilities dropped.'],
  ['Multi-arch', 'linux/amd64 + linux/arm64, one signed index.'],
  ['Signed', 'cosign keyless, tied to the build workflow and logged in Rekor.'],
  ['Pinned by digest', 'Charts reference images by sha256, never a moving tag.'],
];

// The guide and reference cards are driven by the docs collection, so adding an
// MDX file under src/content/docs/ surfaces it here automatically.
const docs = await getCollection('docs');
const cardsFor = (group: 'Guides' | 'Build images' | 'Reference') =>
  docs
    .filter((d) => d.data.group === group)
    .sort((a, b) => a.data.order - b.data.order)
    .map((d) => ({ href: `/docs/${d.id}`, h: d.data.title, p: d.data.description }));

const guides = cardsFor('Guides');
const buildImages = cardsFor('Build images');
const reference = cardsFor('Reference');
---

<Docs title="Docs · Quenchworks" description="How to install, verify, pin, configure, and migrate to QuenchWorks images and charts.">
  <h1>Docs</h1>
  <p class="lead">Short, practical guides for using the catalog. Install something, check that you can trust it, pin it, and tune it.</p>

  <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
    {
      guarantees.map(([h, p]) => (
        <div class="rounded-xl border border-line bg-graphite p-4">
          <p class="font-mono text-[11px] uppercase tracking-widest text-paper">{h}</p>
          <p class="mt-1.5 text-sm leading-relaxed">{p}</p>
        </div>
      ))
    }
  </div>

  <h2>Guides</h2>
  <div class="mt-4 grid gap-3">
    {
      guides.map((pg) => (
        <a href={pg.href} class="group rounded-xl border border-line bg-graphite p-5 no-underline transition-colors duration-200 hover:border-paper/40">
          <div class="flex items-center justify-between gap-3">
            <span class="text-base font-semibold text-paper">{pg.h}</span>
            <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
          </div>
          <p class="mt-1">{pg.p}</p>
        </a>
      ))
    }
  </div>

  <h2>Build images</h2>
  <div class="mt-4 grid gap-3">
    {
      buildImages.map((pg) => (
        <a href={pg.href} class="group rounded-xl border border-line bg-graphite p-5 no-underline transition-colors duration-200 hover:border-paper/40">
          <div class="flex items-center justify-between gap-3">
            <span class="text-base font-semibold text-paper">{pg.h}</span>
            <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
          </div>
          <p class="mt-1">{pg.p}</p>
        </a>
      ))
    }
  </div>

  <h2>Reference</h2>
  <div class="mt-4 grid gap-3">
    {
      reference.map((pg) => (
        <a href={pg.href} class="group rounded-xl border border-line bg-graphite p-5 no-underline transition-colors duration-200 hover:border-paper/40">
          <div class="flex items-center justify-between gap-3">
            <span class="text-base font-semibold text-paper">{pg.h}</span>
            <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
          </div>
          <p class="mt-1">{pg.p}</p>
        </a>
      ))
    }
  </div>

  <p class="mt-10 text-sm">
    Looking for a specific datastore? Browse <a href="/charts">all charts</a> or <a href="/images">all images</a>.
  </p>
</Docs>
