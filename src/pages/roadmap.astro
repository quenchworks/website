---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { images as catalog } from '../data/images';
import { roadmap, roadmapTotal, roadmapCategories, byPriority, blockedCount, blockedList } from '../data/roadmap';

const shipped = catalog.filter((e) => e.status === 'available');
const total = shipped.length + roadmapTotal;
const available = [...shipped].sort((a, b) => a.name.localeCompare(b.name));

// Blocked apps are held (built, not shipped) and get their own "Held" section, so
// they are excluded from the "On the roadmap" count + listing. The progress bar
// shows shipped and blocked as slices of the same total (blocked in red).
const openItems = roadmap.filter((r) => !r.blocked);
const openTotal = openItems.length;
// The three states partition the total: shipped + on-roadmap + blocked = total.
// Show all three as % so they visibly sum to 100 (roadmap takes the remainder so
// rounding always lands on 100).
const shippedPct = Math.round((shipped.length / total) * 100);
const blockedPct = Math.round((blockedCount / total) * 100);
const roadmapPct = 100 - shippedPct - blockedPct;

const priorityLabel: Record<string, string> = { next: 'next', planned: 'planned', exploring: 'exploring' };
// Priority is NOT security state, so it's distinguished within the monochrome ramp
// (border style + tone), never by hue — hue stays reserved for CVE severity. next
// is loudest (solid bright border), planned is a solid line, exploring is dashed
// (reads as tentative). Scannable at a glance without a legend.
const priorityBadge: Record<string, string> = {
  next: 'border border-paper/50 bg-paper/10 text-paper',
  planned: 'border border-ash/50 text-ash',
  exploring: 'border border-dashed border-ash/45 text-ash/70',
};
const grouped = roadmapCategories
  .map((cat) => ({ cat, items: openItems.filter((r) => r.category === cat).sort(byPriority) }))
  .filter((g) => g.items.length > 0);

// Available + Held are grouped by category too (each a nested collapsible), matching On-the-roadmap.
const catsOf = <T extends { category: string }>(items: T[]) =>
  [...new Set(items.map((i) => i.category))]
    .sort()
    .map((cat) => ({ cat, items: items.filter((i) => i.category === cat) }));
const availableGrouped = catsOf(available);
const blockedGrouped = catsOf(blockedList);
---

<Base title="Roadmap · QuenchWorks" description="What is shipped now and the 180+ apps on deck for the QuenchWorks catalog, covering the most-requested datastores, infrastructure, and developer tools.">
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">Roadmap</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">What is shipped, what is next</h1>
      <p class="mt-4 leading-relaxed text-ash">
        {shipped.length} datastores and tools are hardened and shipping today. Below is what is on
        deck, OSI-clean options first. Every entry is built from source on Wolfi, scanned to zero
        fixable CVEs, signed, and pinned by digest before it moves to available.
      </p>
    </header>

    <!-- progress -->
    <section class="mt-12 rounded-2xl border border-line bg-graphite p-6 sm:p-8" aria-label="Catalog progress">
      <div class="flex items-end justify-between gap-4">
        <div class="font-mono text-5xl font-bold tabular-nums leading-none tracking-tight">
          {shipped.length}<span class="text-ash">/{total}</span>
        </div>
        <div class="font-mono text-2xl font-bold tabular-nums">{shippedPct}%<span class="text-ash"> shipped</span></div>
      </div>
      {/* Three-segment meter: shipped + on-roadmap + blocked partition the total (=100%). */}
      <div class="mt-4 flex h-1.5 overflow-hidden rounded-full bg-ink" role="img" aria-label={`${shippedPct}% shipped, ${roadmapPct}% on the roadmap, ${blockedPct}% held/blocked — ${total} total`}>
        <div class="h-full bg-paper" style={`width:${shippedPct}%`}></div>
        <div class="h-full bg-ash/40" style={`width:${roadmapPct}%`}></div>
        <div class="h-full bg-red-500/70" style={`width:${blockedPct}%`}></div>
      </div>
      <dl class="mt-6 grid grid-cols-3 gap-4 border-t border-line pt-5 text-center">
        {
          (
            [
              ['Shipped', shipped.length, shippedPct, 'text-paper'],
              ['On the roadmap', openTotal, roadmapPct, 'text-ash'],
              ['Blocked', blockedCount, blockedPct, blockedCount > 0 ? 'text-red-300' : 'text-ash'],
            ] as [string, number, number, string][]
          ).map(([label, n, pct, tone]) => (
            <div>
              <dd class="font-mono text-2xl font-bold tabular-nums">
                {n}<span class:list={['ml-1 text-sm font-medium', tone]}>{pct}%</span>
              </dd>
              <dt class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ash">{label}</dt>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- available -->
    <details open class="group mt-16">
      <summary class="mb-6 flex cursor-pointer list-none items-center gap-4 [&::-webkit-details-marker]:hidden">
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">Available now</h2>
        <span class="h-px flex-1 bg-line"></span>
        <span class="font-mono text-xs tabular-nums text-ash">{shipped.length}</span>
        <span class="font-mono text-xs text-ash transition-transform duration-200 group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
      </summary>
      <div class="space-y-10">
        {
          availableGrouped.map((g) => (
            <details open class="group/cat">
              <summary class="mb-3 flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                <h3 class="text-sm font-semibold text-paper">{g.cat}</h3>
                <span class="h-px flex-1 bg-line/60"></span>
                <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
                <span class="font-mono text-[10px] text-ash transition-transform duration-200 group-open/cat:rotate-90" aria-hidden="true">&rsaquo;</span>
              </summary>
              <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {g.items.map((e) => (
                  <li>
                    <a
                      href={`/images/${e.slug}`}
                      class="group flex h-full flex-col justify-between gap-5 rounded-xl border border-line bg-graphite p-5 transition-colors duration-200 hover:border-paper/40"
                    >
                      <div class="flex items-start justify-between">
                        <span class="inline-flex size-10 items-center justify-center rounded-lg border border-line bg-ink">
                          <img src="/brand/icon-dark.svg" alt="" class="size-6" width="24" height="24" />
                        </span>
                        <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
                      </div>
                      <div>
                        <span class="block text-base font-semibold leading-tight">{e.name}</span>
                        <span class="mt-2 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                          <span class="rounded bg-ink px-2 py-0.5">{e.category}</span>
                          <span class="rounded bg-ink px-2 py-0.5">{e.tier}</span>
                        </span>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </div>
    </details>

    <!-- held: built + tested, not shipped (all blocked apps in one place) -->
    {
      blockedCount > 0 && (
        <details open class="group mt-16">
          <summary class="mb-6 flex cursor-pointer list-none items-center gap-4 [&::-webkit-details-marker]:hidden">
            <h2 class="font-mono text-xs uppercase tracking-widest text-paper">Held &mdash; built, not shipped</h2>
            <span class="h-px flex-1 bg-line" />
            <span class="font-mono text-xs tabular-nums text-ash">{blockedCount}</span>
            <span class="font-mono text-xs text-ash transition-transform duration-200 group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
          </summary>
          <p class="-mt-3 mb-8 max-w-2xl text-sm text-ash">
            These build and test clean but can't reach <span class="text-paper">0 fixable CVEs</span> yet &mdash; the
            app or its base pins a dependency below the version that fixes a known CVE, so we hold it rather than ship a
            vulnerable image. Each re-lists automatically the moment upstream ships the fix. Tap
            <span class="text-red-300">why blocked?</span> for the exact pin.
          </p>
          <div class="space-y-10">
            {blockedGrouped.map((g) => (
              <details open class="group/cat">
                <summary class="mb-3 flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                  <h3 class="text-sm font-semibold text-paper">{g.cat}</h3>
                  <span class="h-px flex-1 bg-line/60"></span>
                  <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
                  <span class="font-mono text-[10px] text-ash transition-transform duration-200 group-open/cat:rotate-90" aria-hidden="true">&rsaquo;</span>
                </summary>
                <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                  {g.items.map((r) => (
                    <li class="flex h-full flex-col gap-3 rounded-xl border border-line/70 bg-graphite/50 p-5">
                      <div class="flex items-start justify-between gap-2">
                        <span class="text-base font-medium leading-tight text-paper/90">{r.name}</span>
                        <span
                          class="shrink-0 rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300"
                          role="img"
                          aria-label="Tested and held: cannot reach zero fixable CVEs due to an upstream dependency pin"
                        >
                          blocked
                        </span>
                      </div>
                      <p class="flex-1 text-sm leading-relaxed text-ash">{r.note}</p>
                      {r.blockedReason && (
                        <button
                          type="button"
                          data-blocked-open
                          data-name={r.name}
                          data-reason={r.blockedReason}
                          aria-haspopup="dialog"
                          class="self-start rounded-lg border border-red-500/40 bg-red-500/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-red-300 transition-colors duration-200 hover:bg-red-500/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-300"
                        >
                          why blocked?
                        </button>
                      )}
                      <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                        <span class="rounded bg-ink px-2 py-0.5">{r.category}</span>
                        <span class="rounded bg-ink px-2 py-0.5">{r.license}</span>
                      </div>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        </details>
      )
    }

    <!-- on the roadmap, grouped by theme -->
    <details open class="group mt-16">
      <summary class="mb-6 flex cursor-pointer list-none items-center gap-4 [&::-webkit-details-marker]:hidden">
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">On the roadmap</h2>
        <span class="h-px flex-1 bg-line"></span>
        <span class="font-mono text-xs tabular-nums text-ash">{openTotal}</span>
        <span class="font-mono text-xs text-ash transition-transform duration-200 group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
      </summary>
      <p class="-mt-3 mb-8 max-w-2xl text-sm text-ash">
        Candidates, not commitments. <span class="text-paper">next</span> = strongest near-term picks;
        <span class="text-paper">planned</span> and <span class="text-paper">exploring</span> follow. Items
        marked <span class="text-paper">caution</span> are source-available (not OSI) and would ship only with a
        loud license note and the clean alternative called out. (Apps that build but can't hit 0 fixable CVEs yet are
        in <span class="text-red-300">Held</span>, above.) Each card also shows how it will
        ship: <span class="text-paper">image + chart</span> for a deployable service, or
        <span class="text-paper">image only</span> for a base/CLI/sidecar utility (like busybox).
      </p>

      <div class="space-y-10">
        {
          grouped.map((g) => (
            <details open class="group/cat">
              <summary class="mb-3 flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                <h3 class="text-sm font-semibold text-paper">{g.cat}</h3>
                <span class="h-px flex-1 bg-line/60"></span>
                <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
                <span class="font-mono text-[10px] text-ash transition-transform duration-200 group-open/cat:rotate-90" aria-hidden="true">&rsaquo;</span>
              </summary>
              <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {g.items.map((r) => (
                  <li class="flex h-full flex-col gap-3 rounded-xl border border-line/70 bg-graphite/50 p-5">
                    <div class="flex items-start justify-between gap-2">
                      <span class="text-base font-medium leading-tight text-paper/90">{r.name}</span>
                      {r.blocked ? (
                        <span
                          class="shrink-0 rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300"
                          role="img"
                          aria-label="Tested and held: cannot reach zero fixable CVEs due to upstream dependency pins"
                        >
                          blocked
                        </span>
                      ) : (
                        <span
                          class:list={[
                            'shrink-0 rounded px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest',
                            priorityBadge[r.priority],
                          ]}
                        >
                          {priorityLabel[r.priority]}
                        </span>
                      )}
                    </div>
                    <p class="flex-1 text-sm leading-relaxed text-ash">{r.note}</p>
                    {r.blocked && r.blockedReason && (
                      <button
                        type="button"
                        data-blocked-open
                        data-name={r.name}
                        data-reason={r.blockedReason}
                        aria-haspopup="dialog"
                        class="self-start rounded-lg border border-red-500/40 bg-red-500/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-red-300 transition-colors duration-200 hover:bg-red-500/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-300"
                      >
                        why blocked?
                      </button>
                    )}
                    {r.cleanAlternative && (
                      <p class="text-xs leading-relaxed text-ash">
                        <span class="font-mono uppercase tracking-widest text-paper/70">clean alt:</span> {r.cleanAlternative}
                      </p>
                    )}
                    <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                      <span class="rounded border border-line px-2 py-0.5 text-paper/70">
                        {r.deliverable === 'image' ? 'image only' : 'image + chart'}
                      </span>
                      <span class="rounded bg-ink px-2 py-0.5">{r.license}</span>
                      {r.licenseClean === 'caution' && (
                        <span class="rounded border border-ash/50 px-2 py-0.5 text-paper/80">caution</span>
                      )}
                      {r.licenseClean === 'agpl' && <span class="rounded bg-ink px-2 py-0.5">agpl</span>}
                    </div>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </div>
    </details>

    {
      blockedCount > 0 && (
        <section class="mt-16 rounded-2xl border border-line bg-graphite p-6 sm:p-8" aria-label="About blocked apps">
          <div class="flex items-center gap-3">
            <span class="rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300">blocked</span>
            <h2 class="font-mono text-xs uppercase tracking-widest text-paper">Why some apps are held</h2>
          </div>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ash">
            QuenchWorks ships nothing that carries a fixable CVE. A few apps build cleanly but can't
            reach that bar yet: the app itself pins a dependency <em class="not-italic text-paper/90">below</em> the
            version that fixes a known CVE, so patching it would break the app's own declared
            constraints. Those are marked <span class="text-red-300">blocked</span>: built and tested,
            held (not shipped) until upstream relaxes the pin or backports the fix. They go live the
            moment that lands. Nothing already in the catalog carries a known fixable CVE to get there faster.
          </p>
        </section>
      )
    }

    <section class="mt-16 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="mx-auto max-w-md text-ash">Want something prioritized? Request an app and we will slot it into the roadmap.</p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://github.com/quenchworks/.github/issues/new?template=app-request.yml"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-paper/50 bg-paper/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-paper transition-colors duration-200 hover:border-paper/70"
        >
          Open a GitHub issue
        </a>
        <a
          href="mailto:info@quench-works.com?subject=App request"
          class="rounded-lg border border-line px-4 py-2 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper"
        >
          Request by email
        </a>
      </div>
    </section>
  </main>

  {/* One shared modal for every "why blocked?" button. Native <dialog> gives the
      centered layout, focus trap, and Escape-to-close for free; the ::backdrop is
      blurred. Populated from the clicked button's data-* by the script below. */}
  <dialog
    id="blocked-dialog"
    aria-labelledby="bd-title"
    class="m-auto w-[calc(100%-2rem)] max-w-md rounded-xl border border-line bg-graphite p-0 text-paper backdrop:bg-ink/70 backdrop:backdrop-blur-sm"
  >
    <div class="p-6">
      <div class="flex items-center justify-between gap-3">
        <h2 id="bd-title" class="text-lg font-semibold tracking-tight"></h2>
        <span class="shrink-0 rounded border border-red-500/40 bg-red-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-red-300">blocked</span>
      </div>
      <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-ash">Tested and held: cannot reach 0 fixable CVEs</p>
      <p id="bd-reason" class="mt-4 text-sm leading-relaxed text-ash"></p>
      <div class="mt-6 flex justify-end">
        <button
          id="bd-close"
          type="button"
          class="rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper"
        >
          close
        </button>
      </div>
    </div>
  </dialog>

  <script>
    const dlg = document.getElementById('blocked-dialog') as HTMLDialogElement | null;
    const title = document.getElementById('bd-title');
    const reason = document.getElementById('bd-reason');
    if (dlg && title && reason) {
      // Render the reason with `backtick` spans as inline <code> — built as DOM
      // nodes (textContent), so no markdown lib and no innerHTML injection.
      const render = (text: string) => {
        reason.replaceChildren();
        text.split('`').forEach((part, i) => {
          if (i % 2 === 1) {
            const code = document.createElement('code');
            code.className = 'rounded bg-ink px-1.5 py-0.5 font-mono text-[0.85em] text-paper';
            code.textContent = part;
            reason.appendChild(code);
          } else if (part) {
            reason.appendChild(document.createTextNode(part));
          }
        });
      };
      for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-blocked-open]')) {
        btn.addEventListener('click', () => {
          title.textContent = btn.dataset.name ?? '';
          render(btn.dataset.reason ?? '');
          dlg.showModal();
        });
      }
      document.getElementById('bd-close')?.addEventListener('click', () => dlg.close());
      // Click on the backdrop (the dialog element itself, outside the panel) closes.
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) dlg.close();
      });
    }
  </script>
  <Footer />
</Base>
