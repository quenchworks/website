---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { catalog } from '../data/catalog';

const total = catalog.length;
const shipped = catalog.filter((e) => e.status === 'available');
const percent = Math.round((shipped.length / total) * 100);

const available = [...shipped].sort((a, b) => a.name.localeCompare(b.name));

// queued grouped into the build waves we actually work in
const waves: { key: 'critical' | 'standard' | 'low'; n: number; label: string; note: string }[] = [
  { key: 'critical', n: 1, label: 'Critical tier', note: 'Highest demand. Built first, rebuilt daily.' },
  { key: 'standard', n: 2, label: 'Standard tier', note: 'Broad coverage. Rebuilt weekly.' },
  { key: 'low', n: 3, label: 'Low tier', note: 'Long tail. Rebuilt monthly.' },
];
const queued = (t: string) =>
  catalog.filter((e) => e.status === 'planned' && e.tier === t).sort((a, b) => a.name.localeCompare(b.name));
const queuedTotal = total - shipped.length;
---

<Base title="Roadmap — Quenchworks" description="What is available now and what is coming next in the QuenchWorks catalog.">
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">Roadmap</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">What is shipped, what is next</h1>
      <p class="mt-4 text-ash">
        We work the catalog in tiers, top to bottom, and ship the single-node chart first. Each entry
        is hardened end to end before it moves from queued to available.
      </p>
    </header>

    <!-- progress -->
    <section class="mt-10 rounded-2xl border border-line bg-graphite p-6 sm:p-8" aria-label="Catalog progress">
      <div class="flex items-end justify-between gap-4">
        <div>
          <div class="font-mono text-5xl font-bold tabular-nums tracking-tight">
            {shipped.length}<span class="text-ash">/{total}</span>
          </div>
          <p class="mt-1 font-mono text-xs uppercase tracking-widest text-ash">datastores shipped</p>
        </div>
        <div class="text-right font-mono text-3xl font-bold tabular-nums text-ash">{percent}%</div>
      </div>
      <div class="mt-5 h-2 overflow-hidden rounded-full bg-ink" role="progressbar" aria-valuenow={percent} aria-valuemin="0" aria-valuemax="100">
        <div class="h-full rounded-full bg-paper" style={`width:${percent}%`}></div>
      </div>
      <div class="mt-5 flex flex-wrap gap-x-8 gap-y-2 font-mono text-xs uppercase tracking-widest text-ash">
        <span><span class="text-paper tabular-nums">{shipped.length}</span> available</span>
        <span><span class="text-paper tabular-nums">{queuedTotal}</span> queued</span>
        <span><span class="text-paper tabular-nums">{catalog.filter((e) => e.tier === 'critical').length}</span> critical tier</span>
      </div>
    </section>

    <!-- available -->
    <section class="mt-14">
      <div class="mb-5 flex items-center gap-3">
        <span class="size-2.5 rounded-full bg-paper" aria-hidden="true"></span>
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">Available now</h2>
        <span class="font-mono text-xs tabular-nums text-ash">{shipped.length}</span>
      </div>
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          available.map((e) => (
            <li>
              <a
                href={`/catalog/${e.slug}`}
                class="group flex items-center gap-3 rounded-xl border border-line bg-graphite p-4 transition-colors duration-200 hover:border-paper/40"
              >
                <img src="/brand/icon-dark.svg" alt="" class="size-8 shrink-0" width="32" height="32" />
                <span class="min-w-0 flex-1">
                  <span class="block font-semibold leading-tight">{e.name}</span>
                  <span class="mt-0.5 block font-mono text-[10px] uppercase tracking-widest text-ash">
                    {e.category} · {e.tier}
                  </span>
                </span>
                <span class="font-mono text-[10px] uppercase tracking-widest text-ash transition-colors group-hover:text-paper">&rarr;</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- queued, by wave -->
    {
      waves.map((w) => {
        const items = queued(w.key);
        if (items.length === 0) return null;
        return (
          <section class="mt-12">
            <div class="mb-1 flex items-center gap-3">
              <span class="size-2.5 rounded-full border border-ash" aria-hidden="true"></span>
              <h2 class="font-mono text-xs uppercase tracking-widest text-paper">
                Wave {w.n} · {w.label}
              </h2>
              <span class="font-mono text-xs tabular-nums text-ash">{items.length}</span>
            </div>
            <p class="mb-5 pl-[22px] text-sm text-ash">{w.note}</p>
            <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {items.map((e) => (
                <li class="flex items-center justify-between gap-3 rounded-xl border border-line bg-graphite/60 px-4 py-3">
                  <span class="min-w-0">
                    <span class="block text-sm font-medium leading-tight text-paper/90">{e.name}</span>
                    <span class="mt-0.5 block font-mono text-[10px] uppercase tracking-widest text-ash">{e.category}</span>
                  </span>
                  {e.licenseClean === 'caution' && (
                    <span class="shrink-0 font-mono text-[10px] uppercase tracking-widest text-ash" title={e.note}>
                      caution
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        );
      })
    }

    <section class="mt-14 rounded-2xl border border-line bg-graphite px-6 py-8 text-center">
      <p class="text-ash">
        Want something prioritized?{' '}
        <a href="https://github.com/quenchworks/images/issues/new/choose" class="font-medium text-paper underline-offset-4 hover:underline">Request an app</a>{' '}
        and we will slot it into a wave.
      </p>
    </section>
  </main>
  <Footer />
</Base>
