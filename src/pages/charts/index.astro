---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { charts, chartCount, chartTiers } from '../../data/charts';
import { fetchArtifactHub } from '../../data/artifacthub';
import Pagination from '../../components/Pagination.astro';

// live chart + app versions at build time; falls back gracefully if AH is unreachable.
const ah = await fetchArtifactHub();

const entries = [...charts].sort((a, b) => a.name.localeCompare(b.name));
const categories = [...new Set(charts.map((e) => e.category))].sort();
const tierFilters = chartTiers.map((t) => ({ key: t, label: t[0].toUpperCase() + t.slice(1) }));
---

<Base
  title="Charts · Quenchworks"
  description="Browse QuenchWorks hardened Helm charts — digest-pinned to 0-CVE images, cosign-signed, ArtifactHub verified publisher."
>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl" data-pagefind-body data-pagefind-meta="title:All charts,type:Charts">
      <div class="flex flex-wrap items-center gap-3">
        <p class="font-mono text-xs uppercase tracking-widest text-ash">Charts</p>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-line bg-graphite px-3 py-1 font-mono text-xs uppercase tracking-widest text-ash">
          <span class="text-base font-bold tabular-nums text-paper">{chartCount}</span> charts
        </span>
      </div>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Hardened Helm charts</h1>
      <p class="mt-4 leading-relaxed text-ash">
        Each chart deploys our hardened image pinned by its signed digest, with sensible production
        defaults. Cosign-signed and published as an ArtifactHub verified publisher. {chartCount} charts.
      </p>
    </header>

    <div class="relative mt-8">
      <label for="chart-search" class="sr-only">Search charts</label>
      <svg
        class="pointer-events-none absolute left-3.5 top-1/2 size-4 -translate-y-1/2 text-ash"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        id="chart-search"
        type="search"
        placeholder="Search by name, category, license…"
        autocomplete="off"
        class="w-full rounded-lg border border-line bg-graphite py-2.5 pl-10 pr-4 font-mono text-sm text-paper placeholder:text-ash focus:border-paper/40 focus:outline-none"
      />
    </div>

    <div class="mb-8 mt-4 flex flex-wrap gap-2" role="group" aria-label="Filter charts">
      <button
        data-filter="all"
        data-kind="all"
        class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper aria-pressed:border-paper aria-pressed:bg-paper aria-pressed:text-ink"
        aria-pressed="true">All</button>
      {tierFilters.map((f) => (
        <button
          data-filter={f.key}
          data-kind="tier"
          class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper aria-pressed:border-paper aria-pressed:bg-paper aria-pressed:text-ink"
          aria-pressed="false">{f.label}</button>
      ))}
      {categories.map((c) => (
        <button
          data-filter={c}
          data-kind="category"
          class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper aria-pressed:border-paper aria-pressed:bg-paper aria-pressed:text-ink"
          aria-pressed="false">{c}</button>
      ))}
    </div>

    <div class="mb-4 flex min-h-5 items-center justify-between gap-4">
      <p class="font-mono text-xs uppercase tracking-widest text-ash" id="result-count"></p>
      <p class="hidden font-mono text-xs uppercase tracking-widest text-ash" id="no-results">No charts match that search.</p>
    </div>

    <ul id="grid" class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {entries.map((e) => {
        const live = ah[e.slug];
        const chartVer = live?.version ?? e.chartVersion;
        const appVer = live?.appVersion ?? e.appVersion;
        return (
          <li
            class="card"
            data-tier={e.tier}
            data-category={e.category}
            data-search={`${e.name} ${e.category} ${e.license} ${e.summary}`.toLowerCase()}
          >
            <a
              href={`/charts/${e.slug}`}
              class="group flex h-full flex-col gap-4 rounded-xl border border-line bg-graphite p-5 transition-colors duration-200 hover:border-paper/40"
            >
              <div class="flex items-start justify-between gap-3">
                <span class="inline-flex size-10 items-center justify-center rounded-lg border border-line bg-ink">
                  <img src="/brand/icon-dark.svg" alt="" class="size-6" width="24" height="24" />
                </span>
                <span class="rounded border border-line px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-paper">0&nbsp;CVE</span>
              </div>

              <div class="flex-1">
                <h2 class="text-base font-semibold leading-tight">{e.name}</h2>
                <p class="mt-2 text-sm leading-relaxed text-ash">{e.summary}</p>
              </div>

              <p class="font-mono text-[10px] uppercase tracking-widest text-ash">
                chart v{chartVer ?? '?'}{appVer ? ` · app v${appVer}` : ''}
              </p>

              <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                <span class="rounded bg-ink px-2 py-0.5">{e.category}</span>
                <span class="rounded bg-ink px-2 py-0.5">{e.tier}</span>
                <span class:list={['rounded bg-ink px-2 py-0.5', e.caution ? 'text-amber-400' : '']}>{e.license}</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <Pagination id="pagination" />
  </main>
  <Footer />

  <script>
    import { createPaginator } from '../../scripts/paginate';

    const search = document.querySelector<HTMLInputElement>('#chart-search');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
    const noResults = document.querySelector<HTMLElement>('#no-results');
    const nav = document.querySelector<HTMLElement>('#pagination');
    const count = document.querySelector<HTMLElement>('#result-count');

    let activeFilter = 'all';
    let activeKind = 'all';

    const paginator =
      nav &&
      createPaginator({
        cards,
        nav,
        count,
        scrollTarget: search,
        noun: ['chart', 'charts'],
      });

    function apply() {
      const q = (search?.value ?? '').trim().toLowerCase();
      const filtered = cards.filter((card) => {
        const matchFilter =
          activeKind === 'all' ||
          (activeKind === 'tier' && card.dataset.tier === activeFilter) ||
          (activeKind === 'category' && card.dataset.category === activeFilter);
        const matchSearch = q === '' || (card.dataset.search ?? '').includes(q);
        return matchFilter && matchSearch;
      });
      // Hide everything; the paginator reveals only the current page's slice.
      cards.forEach((card) => (card.style.display = 'none'));
      noResults?.classList.toggle('hidden', filtered.length !== 0);
      paginator?.setFiltered(filtered);
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        activeFilter = btn.dataset.filter ?? 'all';
        activeKind = btn.dataset.kind ?? 'all';
        apply();
      });
    });
    search?.addEventListener('input', apply);
    apply();
  </script>
</Base>
