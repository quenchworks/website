---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CatalogList from '../../../components/CatalogList.astro';
import { charts, chartCount, chartTiers, PAGE_SIZE } from '../../../data/charts';
import { fetchArtifactHub } from '../../../data/artifacthub';

// Static pages 2..N. Page 1 lives at /charts (index.astro), so it is NOT
// emitted here. This two-segment route (page/[page]) does not collide with the
// one-segment detail route ([slug].astro).
export function getStaticPaths() {
  const entries = [...charts].sort((a, b) => a.name.localeCompare(b.name));
  const total = Math.max(1, Math.ceil(entries.length / PAGE_SIZE));
  const paths = [];
  for (let page = 2; page <= total; page++) {
    const start = (page - 1) * PAGE_SIZE;
    paths.push({
      params: { page: String(page) },
      props: { slice: entries.slice(start, start + PAGE_SIZE), current: page, total },
    });
  }
  return paths;
}

const { slice, current, total } = Astro.props;
const ah = await fetchArtifactHub();

const entries = [...charts].sort((a, b) => a.name.localeCompare(b.name));
const categories = [...new Set(charts.map((e) => e.category))].sort();
const tierFilters = chartTiers.map((t) => ({ key: t, label: t[0].toUpperCase() + t.slice(1) }));
---

<Base
  title={`Charts · Page ${current} · Quenchworks`}
  description="Browse QuenchWorks hardened Helm charts — digest-pinned to 0-CVE images, cosign-signed, ArtifactHub verified publisher."
>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <CatalogList
      kind="charts"
      base="/charts"
      all={entries}
      ah={ah}
      page={{ data: slice, current, total }}
      count={chartCount}
      categories={categories}
      tierFilters={tierFilters}
    />
  </main>
  <Footer />
</Base>
