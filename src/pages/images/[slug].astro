---
// The base image detail page IS the latest version. ImageDetail renders one
// selected version; here we pass the newest tag from image-meta (falling back to
// the catalog/app version when no per-version metadata exists). Multi-version
// images get extra pages at /images/<slug>/<version>.
import ImageDetail from '../../components/ImageDetail.astro';
import { serviceImages } from '../../data/images';
import imageMeta from '../../data/image-meta.json';
import { compareVersionsDesc } from '../../data/versions';

export function getStaticPaths() {
  const meta = imageMeta as Record<string, Record<string, unknown>>;
  return serviceImages
    .filter((e) => e.status === 'available')
    .map((e) => {
      const tags = Object.keys(meta[e.slug] ?? {}).sort(compareVersionsDesc);
      const version = tags[0] ?? (e.version ?? '');
      return { params: { slug: e.slug }, props: { entry: e, version } };
    });
}

const { entry, version } = Astro.props;
---

<ImageDetail entry={entry} version={version} />
