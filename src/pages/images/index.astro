---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { images, availableCount, imageTiers } from '../../data/images';
import { fetchArtifactHub } from '../../data/artifacthub';

// live image (app) versions at build time; falls back gracefully if AH is unreachable.
const ah = await fetchArtifactHub();

const entries = [...images].sort((a, b) => {
  if (a.status !== b.status) return a.status === 'available' ? -1 : 1;
  return a.name.localeCompare(b.name);
});

const categories = [...new Set(images.map((e) => e.category))].sort();
const tierFilters = imageTiers.map((t) => ({ key: t, label: t[0].toUpperCase() + t.slice(1) }));
---

<Base
  title="Images · Quenchworks"
  description="Browse QuenchWorks hardened, 0-CVE container images — built from source on Wolfi, cosign-signed, digest-pinned, multi-arch."
>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">Images</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Hardened container images</h1>
      <p class="mt-4 leading-relaxed text-ash">
        Every image is built from source on Wolfi, scanned to zero fixable CVEs, cosign-signed, and
        pinned by digest. Nonroot, read-only rootfs, amd64 + arm64. {availableCount} available now.
      </p>
    </header>

    <div class="mt-8">
      <label for="image-search" class="sr-only">Search images</label>
      <input
        id="image-search"
        type="search"
        placeholder="Search by name, category, license…"
        autocomplete="off"
        class="w-full rounded-lg border border-line bg-graphite px-4 py-2.5 font-mono text-sm text-paper placeholder:text-ash focus:border-paper/40 focus:outline-none"
      />
    </div>

    <div class="mb-8 mt-4 flex flex-wrap gap-2" role="group" aria-label="Filter images">
      <button
        data-filter="all"
        data-kind="all"
        class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper aria-pressed:border-paper aria-pressed:text-paper"
        aria-pressed="true">All</button>
      <button
        data-filter="available"
        data-kind="status"
        class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper aria-pressed:border-paper aria-pressed:text-paper"
        aria-pressed="false">Available</button>
      {tierFilters.map((f) => (
        <button
          data-filter={f.key}
          data-kind="tier"
          class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper aria-pressed:border-paper aria-pressed:text-paper"
          aria-pressed="false">{f.label}</button>
      ))}
      {categories.map((c) => (
        <button
          data-filter={c}
          data-kind="category"
          class="filter-btn rounded-lg border border-line px-3.5 py-1.5 font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper aria-pressed:border-paper aria-pressed:text-paper"
          aria-pressed="false">{c}</button>
      ))}
    </div>

    <p class="mb-4 hidden font-mono text-xs uppercase tracking-widest text-ash" id="no-results">No images match that search.</p>

    <ul id="grid" class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {entries.map((e) => {
        const Tag = e.status === 'available' ? 'a' : 'div';
        const live = ah[e.slug];
        const ver = live?.appVersion ?? e.version;
        return (
          <li
            class="card"
            data-status={e.status}
            data-tier={e.tier}
            data-category={e.category}
            data-search={`${e.name} ${e.category} ${e.license} ${e.summary}`.toLowerCase()}
          >
            <Tag
              {...(e.status === 'available' ? { href: `/images/${e.slug}` } : {})}
              class:list={[
                'group flex h-full flex-col gap-4 rounded-xl border bg-graphite p-5 transition-colors duration-200',
                e.status === 'available' ? 'border-line hover:border-paper/40' : 'border-line/70 bg-graphite/50',
              ]}
            >
              <div class="flex items-start justify-between gap-3">
                <span class="inline-flex size-10 items-center justify-center rounded-lg border border-line bg-ink">
                  {e.status === 'available' ? (
                    <img src="/brand/icon-dark.svg" alt="" class="size-6" width="24" height="24" />
                  ) : (
                    <span class="size-2 rounded-full border border-ash" aria-hidden="true" />
                  )}
                </span>
                {e.status === 'available' ? (
                  <span class="rounded border border-line px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-paper">0&nbsp;CVE</span>
                ) : (
                  <span class="rounded border border-line px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-ash">Planned</span>
                )}
              </div>

              <div class="flex-1">
                <h2 class:list={['text-base font-semibold leading-tight', e.status === 'available' ? '' : 'text-paper/80']}>{e.name}</h2>
                <p class="mt-2 text-sm leading-relaxed text-ash">{e.summary}</p>
              </div>

              {e.status === 'available' && ver && (
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash">image v{ver}</p>
              )}

              <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                <span class="rounded bg-ink px-2 py-0.5">{e.category}</span>
                <span class="rounded bg-ink px-2 py-0.5">{e.tier}</span>
                <span class:list={['rounded bg-ink px-2 py-0.5', e.caution ? 'text-amber-400' : '']}>{e.license}</span>
              </div>
            </Tag>
          </li>
        );
      })}
    </ul>
  </main>
  <Footer />

  <script>
    const search = document.querySelector<HTMLInputElement>('#image-search');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.card');
    const noResults = document.querySelector<HTMLElement>('#no-results');

    let activeFilter = 'all';
    let activeKind = 'all';

    function apply() {
      const q = (search?.value ?? '').trim().toLowerCase();
      let shown = 0;
      cards.forEach((card) => {
        const matchFilter =
          activeKind === 'all' ||
          (activeKind === 'status' && card.dataset.status === activeFilter) ||
          (activeKind === 'tier' && card.dataset.tier === activeFilter) ||
          (activeKind === 'category' && card.dataset.category === activeFilter);
        const matchSearch = q === '' || (card.dataset.search ?? '').includes(q);
        const show = matchFilter && matchSearch;
        card.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      if (noResults) noResults.classList.toggle('hidden', shown !== 0);
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        activeFilter = btn.dataset.filter ?? 'all';
        activeKind = btn.dataset.kind ?? 'all';
        apply();
      });
    });
    search?.addEventListener('input', apply);
  </script>
</Base>
