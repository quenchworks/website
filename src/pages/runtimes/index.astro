---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Card from '../../components/shortcodes/Card.astro';
import { runtimeImages, runtimeCount } from '../../data/images';
import { slugify } from '../../data/slugify';

// Each of the three runtime categories gets its own grouped section, in this
// order, with a short intro that says what the images in it are for.
const SECTIONS: { category: string; heading: string; intro: string }[] = [
  {
    category: 'Language runtime',
    heading: 'Language runtimes',
    intro:
      'The interpreter or toolchain for a language, ready to build and run code. Pick the version line you target and pin it.',
  },
  {
    category: 'Runtime base',
    heading: 'Runtime bases',
    intro:
      'The slim final stage you copy a built app onto. No SDK, no build tools, just enough to run.',
  },
  {
    category: 'Build tool',
    heading: 'Build tools',
    intro:
      'A language base with a package or build tool preinstalled. Use it as the build stage, then run the result on a runtime base.',
  },
];

const sorted = (category: string) =>
  runtimeImages
    .filter((e) => e.status === 'available' && e.category === category)
    .sort((a, b) => a.name.localeCompare(b.name));

// Cross-links to the per-ecosystem build guides, plus the overview.
const GUIDES = [
  { slug: 'build-images', title: 'Build hardened images', body: 'The shared multi-stage pattern: build on a toolchain image, run on a slim base.' },
  { slug: 'build-node', title: 'Build a Node app', body: 'node, bun, deno, and the pnpm and yarn build stages.' },
  { slug: 'build-python', title: 'Build a Python app', body: 'python, plus the uv and poetry build stages.' },
  { slug: 'build-go', title: 'Build a Go or Rust binary', body: 'go and rust, copied onto the static base for a tiny final image.' },
  { slug: 'build-java', title: 'Build a Java app', body: 'jdk, maven, and gradle for the build, jre to run the jar.' },
  { slug: 'build-dotnet', title: 'Build a .NET app', body: 'dotnet to build, dotnet-runtime or aspnet to run.' },
];
---

<Base
  title="Runtimes · Quenchworks"
  description="Hardened, 0-CVE base images you build FROM and run on. Nonroot, shell-less, multi-arch, cosign-signed, and pinned by digest. Language runtimes, runtime bases, and build tools."
>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl" data-pagefind-body data-pagefind-meta="title:Runtimes,type:Runtime">
      <div class="flex flex-wrap items-center gap-3">
        <p class="font-mono text-xs uppercase tracking-widest text-ash">Runtimes</p>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-line bg-graphite px-3 py-1 font-mono text-xs uppercase tracking-widest text-ash">
          <span class="text-base font-bold tabular-nums text-paper">{runtimeCount}</span> runtimes
        </span>
      </div>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Hardened base images</h1>
      <p class="mt-4 leading-relaxed text-ash">
        These are the base images you build FROM and run on, the QuenchWorks answer to Chainguard's
        developer images. Every one is nonroot, shell-less, and multi-arch (amd64 + arm64), built
        from source on Wolfi, scanned to zero fixable CVEs, cosign-signed, and pinned by digest with
        an SPDX SBOM and a SLSA build-provenance attestation you can verify. {runtimeCount} available now.
      </p>

      <nav class="mt-6 flex flex-wrap gap-1.5 font-mono text-[11px]" aria-label="Runtime categories">
        {SECTIONS.filter((s) => sorted(s.category).length > 0).map((s) => (
          <a
            href={`#${slugify(s.category)}`}
            class="rounded border border-line bg-graphite px-2 py-1 text-paper transition-colors hover:border-paper/40"
          >{s.heading}</a>
        ))}
      </nav>
    </header>

    {SECTIONS.map((section) => {
      const entries = sorted(section.category);
      if (entries.length === 0) return null;
      return (
        <section id={slugify(section.category)} class="mt-14 scroll-mt-24">
          <h2 class="text-2xl font-semibold tracking-tight">{section.heading}</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-ash">{section.intro}</p>
          <ul class="mt-6 grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {entries.map((e) => (
              <li class="group relative flex h-full flex-col gap-4 rounded-xl border border-line bg-graphite p-5 transition-colors duration-200 hover:border-paper/40">
                <a href={`/runtimes/${e.slug}`} class="absolute inset-0 rounded-xl" aria-label={`${e.name} runtime`}></a>
                <div class="flex items-start justify-between gap-3">
                  <span class="inline-flex size-10 items-center justify-center rounded-lg border border-line bg-ink">
                    <img src="/brand/icon-dark.svg" alt="" class="size-6" width="24" height="24" />
                  </span>
                  <span class="rounded border border-line px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-paper">0&nbsp;CVE</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-base font-semibold leading-tight">{e.name}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-ash">{e.summary}</p>
                </div>
                {e.version && (
                  <p class="font-mono text-[10px] uppercase tracking-widest text-ash">image v{e.version}</p>
                )}
                <div class="relative z-10 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                  <a href={`#${slugify(e.category)}`} class="rounded bg-ink px-2 py-0.5 transition-colors hover:text-paper">{e.category}</a>
                  <span class="rounded bg-ink px-2 py-0.5">{e.tier}</span>
                  <span class:list={['rounded bg-ink px-2 py-0.5', e.caution ? 'text-amber-400' : '']}>{e.license}</span>
                </div>
              </li>
            ))}
          </ul>
        </section>
      );
    })}

    <section class="mt-16">
      <h2 class="text-2xl font-semibold tracking-tight">Build guides</h2>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-ash">
        Each guide shows the multi-stage Dockerfile for its ecosystem, from the build stage to the
        slim image you ship.
      </p>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
        {GUIDES.map((g) => (
          <Card title={g.title} href={`/docs/${g.slug}`}>{g.body}</Card>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Base>
