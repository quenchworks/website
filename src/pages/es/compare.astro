---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, localizeUrl } from '../../i18n/ui';
import {
  vendors,
  rows,
  tone,
  differentiators,
  vendorMeta,
  pillTone,
  verdictLabel,
  groupTitles,
  rowGroupIndex,
  pick,
} from '../../data/compare';

const lang = getLangFromUrl(Astro.url);
const l = (p: string) => localizeUrl(lang, p);

// Localized verdict display for this language.
const vt = (v: string): string => verdictLabel[lang][v] ?? v;

// Rebuild the thematic grouping: for each group index g, gather the rows whose
// rowGroupIndex matches, keeping the original row index so the cells stay aligned
// to the vendor columns.
const groupedRows = groupTitles.map((title, g) => ({
  title: pick(title, lang),
  rows: rows.map((r, i) => ({ r, i })).filter((x) => rowGroupIndex[x.i] === g).map((x) => x.r),
}));
---

<Base
  title="QuenchWorks frente a los proveedores de imágenes reforzadas · Comparación"
  description="Una comparación factual y conservadora de QuenchWorks frente a Bitnami, Chainguard, Docker Hardened Images, RapidFort y Minimus en precio, endurecimiento, firma, SBOMs, procedencia y charts de Helm."
>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16" data-pagefind-body data-pagefind-meta="title:QuenchWorks vs Bitnami, Chainguard, Docker, RapidFort, Minimus,type:Compare">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">Comparar</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">QuenchWorks frente a los proveedores de imágenes reforzadas</h1>
      <p class="mt-4 leading-relaxed text-ash">
        Las imágenes de contenedor reforzadas y de bajo CVE son ya un campo concurrido: Bitnami
        (Broadcom), Chainguard, Docker Hardened Images, RapidFort y Minimus ofrecen todas imágenes
        firmadas y mínimas con SBOMs y procedencia. Las diferencias están en el acceso y el enfoque.
        Bitnami trasladó su catálogo a una oferta comercial y congeló un registro heredado; Chainguard
        da un pequeño conjunto gratuito y restringe el resto tras una suscripción; Docker abrió sus
        Hardened Images como software libre Apache-2.0 a finales de 2025; RapidFort y Minimus son
        plataformas comerciales. QuenchWorks es gratuito, construido en Wolfi y totalmente público:
        imágenes, charts firmados fijados por digest y flujos de compilación que cualquiera puede leer.
        La tabla de abajo es conservadora a propósito. Donde no pudimos confirmar un dato de un
        competidor desde una fuente primaria, lo marcamos "Varía" o "Parcial" en lugar de adivinar.
        Verifica cada afirmación tú mismo.
      </p>
    </header>

    <!-- Where QuenchWorks is different -->
    <section class="mt-12">
      <h2 class="font-mono text-xs uppercase tracking-widest text-ash">En qué se diferencia QuenchWorks</h2>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          differentiators.map((d) => (
            <div class="rounded-xl border border-line bg-graphite p-5">
              <p class="text-sm font-semibold text-paper">{pick(d.label, lang)}</p>
              <p class="mt-2 text-sm leading-relaxed text-ash">{pick(d.body, lang)}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- The providers at a glance -->
    <section class="mt-12">
      <h2 class="font-mono text-xs uppercase tracking-widest text-ash">Los proveedores de un vistazo</h2>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          vendorMeta.map((v) => (
            <div class:list={['rounded-xl border bg-graphite p-5', v.name === 'QuenchWorks' ? 'border-paper/40' : 'border-line']}>
              <div class="flex items-center justify-between gap-3">
                <p class="text-base font-semibold text-paper">{v.name}</p>
                <span class:list={['shrink-0 rounded border px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest', pillTone(v.tier)]}>{verdictLabel[lang][v.tier]}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-ash">{pick(v.blurb, lang)}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Feature-by-feature deep dive -->
    <h2 class="mt-14 font-mono text-xs uppercase tracking-widest text-ash">Característica a característica</h2>

    <!-- Desktop / tablet table -->
    <div class="mt-4 hidden overflow-x-auto rounded-2xl border border-line sm:block">
      <table class="w-full min-w-[56rem] border-collapse text-sm">
        <thead>
          <tr class="border-b border-line bg-graphite">
            <th class="w-1/4 min-w-[12rem] px-4 py-4 text-start font-mono text-[11px] uppercase tracking-widest text-ash">
              Capacidad
            </th>
            {
              vendors.map((v) => (
                <th
                  class:list={[
                    'px-4 py-4 text-start font-mono text-[11px] uppercase tracking-widest',
                    v === 'QuenchWorks' ? 'text-paper' : 'text-ash',
                  ]}
                >
                  {v}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            groupedRows.map((group) => (
              <Fragment>
                <tr class="border-b border-line bg-graphite/60">
                  <td colspan={vendors.length + 1} class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-[0.2em] text-ash">
                    {group.title}
                  </td>
                </tr>
                {group.rows.map((row) => (
                  <tr class="border-b border-line/70">
                    <td class="px-4 py-4 align-top font-medium text-paper">{pick(row.label, lang)}</td>
                    {row.cells.map((cell, i) => (
                      <td class:list={['px-4 py-4 align-top', i === 0 ? 'bg-graphite/40' : '']}>
                        <span class:list={['font-medium', tone(cell.v)]}>{vt(cell.v)}</span>
                        {cell.n && <span class="mt-1 block text-xs leading-relaxed text-ash">{pick(cell.n, lang)}</span>}
                      </td>
                    ))}
                  </tr>
                ))}
              </Fragment>
            ))
          }
        </tbody>
      </table>
    </div>

    <!-- Mobile: stacked cards per capability, grouped by category -->
    <div class="mt-4 space-y-8 sm:hidden">
      {
        groupedRows.map((group) => (
          <div>
            <h3 class="font-mono text-[10px] uppercase tracking-[0.2em] text-ash">{group.title}</h3>
            <div class="mt-3 space-y-3">
              {group.rows.map((row) => (
                <div class="rounded-xl border border-line bg-graphite p-4">
                  <p class="font-medium text-paper">{pick(row.label, lang)}</p>
                  <dl class="mt-3 space-y-2">
                    {row.cells.map((cell, i) => (
                      <div class="flex items-baseline justify-between gap-3 border-t border-line/60 pt-2 first:border-0 first:pt-0">
                        <dt class:list={['font-mono text-[10px] uppercase tracking-widest', vendors[i] === 'QuenchWorks' ? 'text-paper' : 'text-ash']}>
                          {vendors[i]}
                        </dt>
                        <dd class="text-end">
                          <span class:list={['text-sm font-medium', tone(cell.v)]}>{vt(cell.v)}</span>
                          {cell.n && <span class="mt-0.5 block text-xs leading-relaxed text-ash">{pick(cell.n, lang)}</span>}
                        </dd>
                      </div>
                    ))}
                  </dl>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 max-w-2xl text-sm leading-relaxed text-ash">
      Bitnami, Chainguard, Docker, RapidFort y Minimus representan todos una ingeniería seria, y esta
      página no es un desprecio a ninguno de ellos. Varios de ellos ofrecen también excelentes opciones
      gratuitas. QuenchWorks existe para mantener abierto un camino totalmente gratuito, totalmente
      público y sin cuenta, con todo —desde imágenes hasta charts y flujos de compilación— a la vista.
      Verifica cualquier afirmación de aquí frente a las propias fuentes públicas de cada proveedor antes
      de depender de ella.
    </p>

    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ash">
      Dos proyectos relacionados quedan ligeramente fuera de esta tabla: Google Distroless ofrece imágenes
      base mínimas de entornos de ejecución de lenguajes (sin catálogo de aplicaciones ni charts de Helm),
      y Red Hat UBI proporciona imágenes base empresariales redistribuibles (una capa base más que imágenes
      de aplicación listas para ejecutar). Ambos vale la pena conocerlos, pero resuelven un problema distinto
      al de un catálogo de aplicaciones reforzado.
    </p>

    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ash">
      QuenchWorks es independiente y no está afiliado, respaldado ni patrocinado por Bitnami, Broadcom,
      Chainguard, Docker, RapidFort, Minimus, Google o Red Hat. Todos los nombres de productos y marcas
      comerciales son propiedad de sus respectivos dueños.
    </p>

    <section class="mt-12 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-base text-paper">Gratis, reforzado y tuyo para verificar.</p>
      <p class="mt-2 text-sm text-ash">Explora el catálogo o lee el código. Sin cuenta, sin registro que añadir.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-2 font-mono text-xs uppercase tracking-widest">
        <a href={l('/charts')} class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">Explorar charts</a>
        <a href={l('/images')} class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">Explorar imágenes</a>
        <a href="https://github.com/quenchworks" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">GitHub</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
