---
// Spanish hub for the per-competitor alternative pages. Same structure as the en
// hub; only the link prefixes (/es/...), pagefind title, and JSON-LD URLs carry
// the locale. All copy comes from src/data/compare.ts via pick(_, lang).
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getLangFromUrl } from '../../../i18n/ui';
import { vendors, rows, vendorMeta, vendorSlug, pillTone, tone, pick, ui } from '../../../data/compare';

const lang = getLangFromUrl(Astro.url);

const strong = (v: string) => tone(v) === 'text-paper';

const summaries = vendors
  .map((name, i) => ({ name, i }))
  .filter((v) => v.name !== 'QuenchWorks')
  .map(({ name, i }) => {
    const leads = rows
      .filter((r) => strong(r.cells[0].v) && !strong(r.cells[i].v))
      .map((r) => pick(r.label, lang));
    const parity = rows.filter((r) => strong(r.cells[i].v)).map((r) => pick(r.label, lang));
    return { name, slug: vendorSlug(name), meta: vendorMeta[i], leads, parity };
  });

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: pick(ui['eyebrow'], lang),
          item: new URL('/es/alternative', Astro.site).href,
        },
      ],
    },
    {
      '@type': 'ItemList',
      name: 'QuenchWorks alternatives',
      itemListElement: summaries.map((s, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: `QuenchWorks vs ${s.name}`,
        url: new URL(`/es/alternative/${s.slug}`, Astro.site).href,
      })),
    },
  ],
};
---

<Base
  title="Alternativas · QuenchWorks frente a los proveedores de imágenes reforzadas"
  description="Comparación rápida de QuenchWorks frente a Bitnami, Chainguard, Docker Hardened Images, RapidFort y Minimus — en qué destaca QuenchWorks y en qué se mantiene cada proveedor, con una página de detalle para cada competidor."
>
  <Header />
  <main
    class="mx-auto max-w-5xl px-5 py-16"
    data-pagefind-body
    data-pagefind-meta="title:Alternativas a QuenchWorks,type:Alternative"
  >
    <p class="font-mono text-xs uppercase tracking-widest text-ash">{pick(ui['eyebrow'], lang)}</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{pick(ui['hubTitle'], lang)}</h1>
    <p class="mt-4 max-w-2xl leading-relaxed text-ash">{pick(ui['hubIntro'], lang)}</p>

    <div class="mt-12 grid grid-cols-1 gap-4 lg:grid-cols-2">
      {
        summaries.map((s) => (
          <a
            href={`/es/alternative/${s.slug}`}
            class="group block rounded-xl border border-line bg-graphite p-6 no-underline transition-colors hover:border-paper/40"
          >
            <div class="flex items-center justify-between gap-3">
              <h2 class="text-xl font-semibold tracking-tight text-paper">QuenchWorks vs {s.name}</h2>
              <span class:list={['shrink-0 rounded border px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest', pillTone(s.meta.tier)]}>{s.meta.tier}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-ash">{pick(s.meta.blurb, lang)}</p>

            <p class="mt-4 font-mono text-[11px] uppercase tracking-widest text-ash">{pick(ui['leads'], lang)}</p>
            <div class="mt-2 flex flex-wrap gap-1.5">
              {s.leads.length ? (
                s.leads.map((l) => (
                  <span class="rounded border border-line px-2 py-0.5 font-mono text-[10px] text-paper">{l}</span>
                ))
              ) : (
                <span class="text-xs text-ash">{pick(ui['closelyMatched'], lang)}</span>
              )}
            </div>

            <p class="mt-4 font-mono text-[11px] uppercase tracking-widest text-ash">{pick(ui['holdsUp'], lang).replace('{vendor}', s.name)}</p>
            <div class="mt-2 flex flex-wrap gap-1.5">
              {s.parity.length ? (
                s.parity.map((l) => (
                  <span class="rounded border border-line px-2 py-0.5 font-mono text-[10px] text-ash">{l}</span>
                ))
              ) : (
                <span class="text-xs text-ash">{pick(ui['noParity'], lang)}</span>
              )}
            </div>

            <span class="mt-5 inline-flex font-mono text-xs uppercase tracking-widest text-paper">
              {pick(ui['fullComparison'], lang)} &rarr;
            </span>
          </a>
        ))
      }
    </div>

    <section class="mt-12 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-base text-paper">{pick(ui['hubCtaTitle'], lang)}</p>
      <p class="mt-2 text-sm text-ash">{pick(ui['hubCtaBody'], lang)}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-2 font-mono text-xs uppercase tracking-widest">
        <a href="/es/compare" class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">{pick(ui['fullTable'], lang)}</a>
        <a href="/es/charts" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">{pick(ui['browseAll'], lang)}</a>
      </div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Base>
