---
// Spanish per-competitor landing. Same structure as the en [vendor] page; only
// link prefixes (/es/...), pagefind title, and JSON-LD URLs carry the locale.
// All copy comes from src/data/compare.ts via pick(_, lang) / verdictLabel[lang].
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getLangFromUrl } from '../../../i18n/ui';
import { vendors, rows, vendorMeta, vendorSlug, vendorIntro, tone, pick, ui, verdictLabel } from '../../../data/compare';

export function getStaticPaths() {
  return vendors
    .map((name, i) => ({ name, i }))
    .filter((v) => v.name !== 'QuenchWorks')
    .map((v) => ({ params: { vendor: vendorSlug(v.name) }, props: { name: v.name, index: v.i } }));
}

const lang = getLangFromUrl(Astro.url);
const { name, index } = Astro.props;
const meta = vendorMeta[index];
const intro = vendorIntro[vendorSlug(name)] ?? { headline: { en: `QuenchWorks vs ${name}`, ar: `QuenchWorks مقابل ${name}`, es: `QuenchWorks frente a ${name}` }, body: meta.blurb };

const compared = rows.map((r) => ({ label: r.label, quench: r.cells[0], rival: r.cells[index] }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: pick(ui['eyebrow'], lang), item: new URL('/es/alternative', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: `QuenchWorks vs ${name}`, item: new URL(Astro.url.pathname, Astro.site).href },
  ],
};
---

<Base
  title={`QuenchWorks frente a ${name} · Una alternativa gratuita y firmada`}
  description={`Cómo se compara QuenchWorks con ${name} en precio, endurecimiento, firma, SBOM, procedencia SLSA y charts de Helm — característica a característica, conservador y verificable.`}
>
  <Header />
  <main
    class="mx-auto max-w-3xl px-5 py-16"
    data-pagefind-body
    data-pagefind-meta={`title:QuenchWorks frente a ${name},type:Alternative`}
  >
    <p class="font-mono text-xs uppercase tracking-widest text-ash">
      <a href="/es/alternative" class="transition-colors hover:text-paper">{pick(ui['eyebrow'], lang)}</a>
      <span class="text-ash/50">/</span> {name}
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{pick(intro.headline, lang)}</h1>
    <p class="mt-4 leading-relaxed text-ash">{pick(intro.body, lang)}</p>

    <div class="mt-6 flex flex-wrap gap-2 font-mono text-xs uppercase tracking-widest">
      <a href="/es/charts" class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">{pick(ui['browseCharts'], lang)}</a>
      <a href="/es/docs/migrate" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">{pick(ui['migrate'], lang)}</a>
    </div>

    <!-- Feature-by-feature: QuenchWorks vs this vendor -->
    <h2 class="mt-14 font-mono text-xs uppercase tracking-widest text-ash">{pick(ui['featureByFeature'], lang).replace('{vendor}', name)}</h2>
    <div class="mt-4 space-y-3">
      {
        compared.map((r) => (
          <div class="rounded-xl border border-line bg-graphite p-5">
            <p class="font-mono text-[11px] uppercase tracking-widest text-ash">{pick(r.label, lang)}</p>
            <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div>
                <p class="text-sm font-semibold text-paper">QuenchWorks</p>
                <p class:list={['mt-1 text-sm font-medium', tone(r.quench.v)]}>{verdictLabel[lang][r.quench.v]}</p>
                {r.quench.n && <p class="mt-1 text-xs leading-relaxed text-ash">{pick(r.quench.n, lang)}</p>}
              </div>
              <div class="border-t border-line/60 pt-4 sm:border-s sm:border-t-0 sm:ps-4 sm:pt-0">
                <p class="text-sm font-semibold text-ash">{name}</p>
                <p class:list={['mt-1 text-sm font-medium', tone(r.rival.v)]}>{verdictLabel[lang][r.rival.v]}</p>
                {r.rival.n && <p class="mt-1 text-xs leading-relaxed text-ash">{pick(r.rival.n, lang)}</p>}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-4 text-sm leading-relaxed text-ash">{pick(ui['conservative'], lang).replace(/\{vendor\}/g, name)}</p>

    <section class="mt-12 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-base text-paper">{pick(ui['ctaTitle'], lang)}</p>
      <p class="mt-2 text-sm text-ash">{pick(ui['ctaBody'], lang)}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-2 font-mono text-xs uppercase tracking-widest">
        <a href="/es/charts" class="rounded-lg border border-paper/40 px-4 py-2.5 text-paper transition-colors hover:bg-ink">{pick(ui['browseAll'], lang)}</a>
        <a href="/es/docs/migrate" class="rounded-lg border border-line px-4 py-2.5 text-paper transition-colors hover:bg-ink">{pick(ui['migrationGuide'], lang)}</a>
      </div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Base>
