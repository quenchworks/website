---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { images as catalog } from '../../data/images';
import { roadmap, roadmapTotal, roadmapCategories, byPriority } from '../../data/roadmap';
import { localizedSummary } from '../../i18n/content';
import { categoryName } from '../../i18n/categories';
import { localizeUrl } from '../../i18n/ui';

const shipped = catalog.filter((e) => e.status === 'available');
const total = shipped.length + roadmapTotal;
const percent = Math.round((shipped.length / total) * 100);
const available = [...shipped].sort((a, b) => a.name.localeCompare(b.name));

const priorityLabel: Record<string, string> = { next: 'próximo', planned: 'planificado', exploring: 'explorando' };
const grouped = roadmapCategories.map((cat) => ({
  cat,
  items: roadmap.filter((r) => r.category === cat).sort(byPriority),
}));
const nextCount = roadmap.filter((r) => r.priority === 'next').length;
---

<Base title="Hoja de ruta · Quenchworks" description="Lo que está disponible ahora y las más de 180 aplicaciones en camino para el catálogo de QuenchWorks, que cubre los almacenes de datos, la infraestructura y las herramientas de desarrollo más solicitados.">
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-ash">Hoja de ruta</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Lo que está disponible, lo que viene</h1>
      <p class="mt-4 leading-relaxed text-ash">
        {shipped.length} almacenes de datos y herramientas están reforzados y disponibles hoy. A
        continuación está lo que viene, primero las opciones limpias según OSI. Cada entrada se
        compila desde el código fuente en Wolfi, se analiza hasta cero CVE corregibles, se firma
        y se fija por digest antes de pasar a disponible.
      </p>
    </header>

    <!-- progress -->
    <section class="mt-12 rounded-2xl border border-line bg-graphite p-6 sm:p-8" aria-label="Progreso del catálogo">
      <div class="flex items-end justify-between gap-4">
        <div class="font-mono text-5xl font-bold tabular-nums leading-none tracking-tight">
          {shipped.length}<span class="text-ash">/{total}</span>
        </div>
        <div class="font-mono text-2xl font-bold tabular-nums text-ash">{percent}%</div>
      </div>
      <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-ink" role="progressbar" aria-valuenow={percent} aria-valuemin="0" aria-valuemax="100">
        <div class="h-full rounded-full bg-paper" style={`width:${percent}%`}></div>
      </div>
      <dl class="mt-6 grid grid-cols-3 gap-4 border-t border-line pt-5 text-center">
        {
          (
            [
              ['Disponible', shipped.length],
              ['En la hoja de ruta', roadmapTotal],
              ['Próximamente', nextCount],
            ] as [string, number][]
          ).map(([label, n]) => (
            <div>
              <dd class="font-mono text-2xl font-bold tabular-nums">{n}</dd>
              <dt class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ash">{label}</dt>
            </div>
          ))
        }
      </dl>
    </section>

    {/* Roadmap item names are intentionally kept in English (proper nouns). */}
    <!-- available -->
    <section class="mt-16">
      <div class="mb-6 flex items-center gap-4">
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">Disponible ahora</h2>
        <span class="h-px flex-1 bg-line"></span>
        <span class="font-mono text-xs tabular-nums text-ash">{shipped.length}</span>
      </div>
      <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          available.map((e) => (
            <li>
              <a
                href={localizeUrl('es', `/images/${e.slug}`)}
                class="group flex h-full flex-col justify-between gap-5 rounded-xl border border-line bg-graphite p-5 transition-colors duration-200 hover:border-paper/40"
              >
                <div class="flex items-start justify-between">
                  <span class="inline-flex size-10 items-center justify-center rounded-lg border border-line bg-ink">
                    <img src="/brand/icon-dark.svg" alt="" class="size-6" width="24" height="24" />
                  </span>
                  <span class="font-mono text-sm text-ash transition-colors group-hover:text-paper">&rarr;</span>
                </div>
                <div>
                  <span class="block text-base font-semibold leading-tight">{e.name}</span>
                  <span class="mt-2 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                    <span class="rounded bg-ink px-2 py-0.5">{e.category}</span>
                    <span class="rounded bg-ink px-2 py-0.5">{e.tier}</span>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- on the roadmap, grouped by theme -->
    <section class="mt-16">
      <div class="mb-6 flex items-center gap-4">
        <h2 class="font-mono text-xs uppercase tracking-widest text-paper">En la hoja de ruta</h2>
        <span class="h-px flex-1 bg-line"></span>
        <span class="font-mono text-xs tabular-nums text-ash">{roadmapTotal}</span>
      </div>
      <p class="-mt-3 mb-8 max-w-2xl text-sm text-ash">
        Candidatos, no compromisos. <span class="text-paper">próximo</span> = las apuestas más sólidas a corto plazo;
        luego siguen <span class="text-paper">planificado</span> y <span class="text-paper">explorando</span>. Los elementos
        marcados como <span class="text-paper">precaución</span> son de código disponible (no OSI) y solo se publicarían con
        una nota de licencia destacada y la alternativa limpia señalada. Cada tarjeta también muestra cómo
        se publicará: <span class="text-paper">imagen + chart</span> para un servicio desplegable, o
        <span class="text-paper">solo imagen</span> para una utilidad base/CLI/sidecar (como busybox).
      </p>

      <div class="space-y-10">
        {
          grouped.map((g) => (
            <div>
              <div class="mb-3 flex items-center gap-3">
                <h3 class="text-sm font-semibold text-paper">{categoryName('es', g.cat)}</h3>
                <span class="h-px flex-1 bg-line/60"></span>
                <span class="font-mono text-[10px] tabular-nums text-ash">{g.items.length}</span>
              </div>
              <ul class="grid auto-rows-fr grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {g.items.map((r) => (
                  <li class="flex h-full flex-col gap-3 rounded-xl border border-line/70 bg-graphite/50 p-5">
                    <div class="flex items-start justify-between gap-2">
                      <span class="text-base font-medium leading-tight text-paper/90">{r.name}</span>
                      <span
                        class:list={[
                          'rounded px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest',
                          r.priority === 'next' ? 'border border-paper/40 text-paper' : 'bg-ink text-ash',
                        ]}
                      >
                        {priorityLabel[r.priority]}
                      </span>
                    </div>
                    <p class="flex-1 text-sm leading-relaxed text-ash">{localizedSummary('es', 'roadmap', r.name, r.note)}</p>
                    {r.cleanAlternative && (
                      <p class="text-xs leading-relaxed text-ash">
                        <span class="font-mono uppercase tracking-widest text-paper/70">alt. limpia:</span> {r.cleanAlternative}
                      </p>
                    )}
                    <div class="flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
                      <span class="rounded border border-line px-2 py-0.5 text-paper/70">
                        {r.deliverable === 'image' ? 'solo imagen' : 'imagen + chart'}
                      </span>
                      <span class="rounded bg-ink px-2 py-0.5">{r.license}</span>
                      {r.licenseClean === 'caution' && (
                        <span class="rounded border border-ash/50 px-2 py-0.5 text-paper/80">precaución</span>
                      )}
                      {r.licenseClean === 'agpl' && <span class="rounded bg-ink px-2 py-0.5">agpl</span>}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-16 rounded-2xl border border-line bg-graphite px-6 py-10 text-center">
      <p class="text-ash">
        ¿Quieres priorizar algo?{' '}
        <a href="mailto:info@quench-works.com?subject=App%20request" class="font-medium text-paper underline-offset-4 hover:underline">Solicita una aplicación</a>{' '}
        y lo encajaremos en la hoja de ruta.
      </p>
    </section>
  </main>
  <Footer />
</Base>
