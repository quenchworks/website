---
// Home: a real ~20s terminal capture rendered from genuine command output —
// run a 0-CVE image, verify its signature, deploy the chart, watch it come up.
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const t = useTranslations(getLangFromUrl(Astro.url));
---

<section class="mx-auto max-w-5xl px-5 py-12 sm:py-16">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{t('demo.title')}</h2>
    <p class="mt-3 leading-relaxed text-ash">
      {t('demo.body')}
    </p>
  </div>
  <figure class="mx-auto mt-8 max-w-3xl overflow-hidden rounded-2xl border border-line bg-ink">
    <img
      src="/demo.gif"
      alt={t('demo.alt')}
      width="1200"
      height="868"
      class="w-full"
      loading="lazy"
      decoding="async"
    />
  </figure>
</section>
