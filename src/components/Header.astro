---
const nav = [
  { label: 'Catalog', href: '/catalog' },
  { label: 'Charts', href: 'https://artifacthub.io/packages/search?ts_query_web=quenchworks' },
  { label: 'Images', href: 'https://github.com/orgs/quenchworks/packages' },
];
---

<header class="sticky top-0 z-50 border-b border-line/80 bg-ink/80 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-5">
    <a href="/" class="flex items-center gap-2" aria-label="Quenchworks home">
      <img src="/brand/logo-dark.svg" alt="Quenchworks" class="h-7 w-auto" width="200" height="51" />
    </a>

    <nav class="hidden items-center gap-7 sm:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="https://github.com/quenchworks"
      class="inline-flex items-center gap-2 rounded-lg border border-line px-3.5 py-2 font-mono text-xs uppercase tracking-widest text-paper transition-colors duration-200 hover:bg-graphite"
    >
      <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7 0-.7 0-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5.1 18.3 5.1c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
      </svg>
      GitHub
    </a>
  </div>
</header>
