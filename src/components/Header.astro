---
import Search from './Search.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl, useTranslations, languages, localizeUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => localizeUrl(lang, p);

// `primary` items show in the desktop bar; the full set shows in the mobile menu
// (and everything is also linked from the footer). The desktop bar carries the
// core sections, with Roadmap back in the bar after Compare. Changelog and FAQ
// stay in the mobile/footer set. hrefs are localized so nav stays in-locale.
const nav = [
  { label: t('nav.charts'), href: l('/charts'), primary: true },
  { label: t('nav.images'), href: l('/images'), primary: true },
  { label: t('nav.docs'), href: l('/docs'), primary: true },
  { label: t('nav.compare'), href: l('/compare'), primary: true },
  { label: t('nav.roadmap'), href: l('/roadmap'), primary: true },
  { label: t('nav.security'), href: l('/security'), primary: true },
  { label: t('nav.changelog'), href: l('/changelog') },
  { label: t('nav.faq'), href: l('/faq') },
];
const primaryNav = nav.filter((n) => n.primary);

const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);

// Language switcher: link to the same page under each locale. Strip the current
// locale prefix first so /ar/charts -> /charts (en) / /es/charts etc.
const basePath = Astro.url.pathname.replace(/^\/(ar|es)(?=\/|$)/, '') || '/';
const localeLinks = (Object.keys(languages) as (keyof typeof languages)[]).map((l) => ({
  code: l,
  href: getRelativeLocaleUrl(l, basePath),
  current: l === lang,
}));
---

<header class="sticky top-0 z-50 border-b border-line/80 bg-ink/80 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-4 px-5">
    <a href={l('/')} class="flex shrink-0 items-center gap-2" aria-label="Quenchworks home">
      <img src="/brand/logo-dark.svg" alt="Quenchworks" class="h-7 w-auto" width="200" height="51" />
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        primaryNav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'whitespace-nowrap font-mono text-xs uppercase tracking-widest transition-colors duration-200 hover:text-paper',
              isActive(item.href) ? 'text-paper' : 'text-ash',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <div class="hidden lg:block">
        <Search trigger="desktop" />
      </div>

      <nav
        class="hidden items-center gap-1 rounded-lg border border-line px-1.5 py-1 sm:inline-flex"
        aria-label={t('lang.label')}
      >
        {
          localeLinks.map((l) => (
            <a
              href={l.href}
              hreflang={l.code}
              aria-current={l.current ? 'true' : undefined}
              class:list={[
                'rounded px-1.5 py-0.5 font-mono text-[11px] uppercase tracking-widest transition-colors duration-200 hover:text-paper',
                l.current ? 'text-paper' : 'text-ash',
              ]}
            >
              {l.code}
            </a>
          ))
        }
      </nav>

      <a
        href="https://github.com/quenchworks"
        class="hidden items-center gap-2 rounded-lg border border-line px-3.5 py-2 font-mono text-xs uppercase tracking-widest text-paper transition-colors duration-200 hover:bg-graphite sm:inline-flex"
        aria-label="QuenchWorks on GitHub"
      >
        <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7 0-.7 0-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5.1 18.3 5.1c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
        </svg>
        <span class="hidden md:inline">GitHub</span>
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="inline-flex size-11 items-center justify-center rounded-lg border border-line text-paper transition-colors duration-200 hover:bg-graphite lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    class="hidden border-t border-line/80 bg-ink/95 px-5 pb-4 pt-2 backdrop-blur lg:hidden"
    aria-label="Primary mobile"
  >
    <div class="border-b border-line/60 pb-2">
      <Search trigger="mobile" />
    </div>
    {
      nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'flex min-h-11 items-center font-mono text-xs uppercase tracking-widest transition-colors duration-200 hover:text-paper',
            isActive(item.href) ? 'text-paper' : 'text-ash',
          ]}
        >
          {item.label}
        </a>
      ))
    }
    <a
      href="https://github.com/quenchworks"
      class="flex min-h-11 items-center font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper"
    >
      GitHub
    </a>
    <div
      class="mt-2 flex items-center gap-3 border-t border-line/60 pt-3"
      aria-label={t('lang.label')}
      role="group"
    >
      <span class="font-mono text-[11px] uppercase tracking-widest text-ash/70">{t('lang.label')}</span>
      {
        localeLinks.map((l) => (
          <a
            href={l.href}
            hreflang={l.code}
            aria-current={l.current ? 'true' : undefined}
            class:list={[
              'font-mono text-xs uppercase tracking-widest transition-colors duration-200 hover:text-paper',
              l.current ? 'text-paper' : 'text-ash',
            ]}
          >
            {l.code}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('#nav-toggle');
  const menu = document.querySelector<HTMLElement>('#mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
