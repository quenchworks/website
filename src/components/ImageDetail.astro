---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import { ghcr, type ImageEntry } from '../data/images';
import { charts } from '../data/charts';
import { fetchPackageDetail } from '../data/artifacthub';
import { resolveAlternatives } from '../data/alternatives';
import { slugify } from '../data/slugify';
import { compareVersionsDesc } from '../data/versions';
import imageMeta from '../data/image-meta.json';

interface Props {
  entry: ImageEntry;
  /** The version this page renders (one of the image's tags). */
  version: string;
}

const { entry, version } = Astro.props;
const image = entry.image || `${ghcr}/images/${entry.slug}`;
const hasChart = charts.some((c) => c.slug === entry.slug);

// Humanize a byte count into a compact MB/GB string (e.g. "28.4 MB").
function humanizeBytes(bytes: number): string {
  if (bytes >= 1e9) return `${(bytes / 1e9).toFixed(1)} GB`;
  if (bytes >= 1e6) return `${(bytes / 1e6).toFixed(1)} MB`;
  if (bytes >= 1e3) return `${(bytes / 1e3).toFixed(1)} KB`;
  return `${bytes} B`;
}

// Turn a build timestamp into a short, friendly "Rebuilt …" label.
function freshness(iso: string): { abs: string; rel: string } {
  const built = new Date(iso);
  const abs = built.toISOString().slice(0, 10);
  const days = Math.floor((Date.now() - built.getTime()) / 86_400_000);
  const rel = days <= 0 ? 'today' : days === 1 ? '1 day ago' : `${days} days ago`;
  return { abs, rel };
}

// live, build-time facts from ArtifactHub (Trivy report + the digest the chart deploys).
const ah = await fetchPackageDetail(entry.slug);
const appVersion = ah?.appVersion ?? entry.version;
const pinned = ah?.image; // image@sha256:... (the chart's deployed digest)
const sec = ah?.security;
const total = ah?.securityTotal;

// Build-time image metadata, nested per version tag. The version list is the
// image's tags, newest-first (numeric-aware, with non-numeric last).
type ImgMeta = { sizeBytes?: number; builtISO?: string; sbomPackages?: number };
const metaByTag = (imageMeta as Record<string, Record<string, ImgMeta>>)[entry.slug] ?? {};
const versions = Object.keys(metaByTag).sort(compareVersionsDesc);

const m = metaByTag[version] ?? Object.values(metaByTag)[0];
const sizeLabel = m?.sizeBytes != null ? humanizeBytes(m.sizeBytes) : undefined;
const fresh = m?.builtISO ? freshness(m.builtISO) : undefined;
const sbomPackages = m?.sbomPackages;

// All pull/tag/verify references use the selected version's tag.
const pullTag = version || appVersion;
const imageTags = pullTag ? [pullTag, `${pullTag}-amd64`, `${pullTag}-arm64`] : [];

// Verify against the version tag: it always resolves to the current, attested digest.
const verifyRef = pullTag ? `${image}:${pullTag}` : image;

// The chart's digest only lines up with the latest line; show it only there.
const isLatest = versions.length === 0 || versions[0] === version;
const digest = isLatest && pinned?.includes('@') ? pinned.slice(pinned.indexOf('@') + 1) : undefined;

// "Runs as" varies for a couple of Coolify images; default is nonroot uid 1001.
const runsAs =
  entry.slug === 'coolify-app'
    ? 'nonroot (uid 9999)'
    : entry.slug === 'coolify-helper'
      ? 'root (by design)'
      : 'nonroot (uid 1001)';

const alternatives = entry.caution ? resolveAlternatives(entry.cleanAlternative) : [];
const categorySlug = slugify(entry.category);
const titleSuffix = isLatest ? '' : ` ${version}`;

const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: entry.name,
  description: entry.summary,
  applicationCategory: entry.category,
  operatingSystem: 'Linux',
  softwareVersion: version || appVersion,
  isAccessibleForFree: true,
  license: entry.license,
  codeRepository: entry.upstream,
};

// Only show the live Trivy report on the latest line (it scans the deployed digest).
const sevs = isLatest && sec
  ? ([
      ['Critical', sec.critical],
      ['High', sec.high],
      ['Medium', sec.medium],
      ['Low', sec.low],
      ['Unknown', sec.unknown],
    ] as [string, number][])
  : [];
---

<Base title={`${entry.name}${titleSuffix} image · Quenchworks`} description={entry.summary} image={`/og/${entry.slug}.png`}>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16" data-pagefind-body data-pagefind-meta={`title:${entry.name} image,type:Image`}>
    <nav class="flex flex-wrap items-center gap-2 font-mono text-xs uppercase tracking-widest text-ash" aria-label="Breadcrumb">
      <a href="/images" class="transition-colors hover:text-paper">Images</a>
      <span class="text-line" aria-hidden="true">/</span>
      <a href={`/images/category/${categorySlug}`} class="rounded border border-line bg-graphite px-2 py-0.5 text-paper transition-colors hover:border-paper/40">{entry.category}</a>
      <span class="text-line" aria-hidden="true">/</span>
      <span class="text-paper">{entry.name}{isLatest ? '' : ` ${version}`}</span>
    </nav>

    <header class="mt-6 flex items-center gap-4">
      <img src="/brand/icon-dark.svg" alt="" class="size-12" width="48" height="48" />
      <div>
        <h1 class="text-4xl font-bold tracking-tight">{entry.name}{isLatest ? '' : ` ${version}`}</h1>
        <p class="mt-1 font-mono text-xs uppercase tracking-widest text-ash">
          Image · <a href={`/images/category/${categorySlug}`} class="underline-offset-4 transition-colors hover:text-paper hover:underline">{entry.category}</a> · {entry.tier}{pullTag ? ` · v${pullTag}` : ''}
        </p>
      </div>
    </header>

    <div class="mt-4 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
      <span class="rounded border border-line bg-graphite px-2 py-0.5 text-paper">0&nbsp;fixable&nbsp;CVEs</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">cosign&nbsp;signed</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">SPDX&nbsp;SBOM</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">SLSA&nbsp;provenance</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">amd64&nbsp;·&nbsp;arm64</span>
      {fresh && (
        <span class="rounded border border-line bg-graphite px-2 py-0.5 text-paper" title={`Image rebuilt ${fresh.rel}`}>Rebuilt&nbsp;{fresh.abs}</span>
      )}
    </div>

    <p class="mt-6 max-w-2xl text-ash">{entry.summary}</p>

    <VersionSwitcher section="images" slug={entry.slug} versions={versions} current={version} />

    {digest && (
      <section class="mt-6 rounded-xl border border-line bg-graphite p-5">
        <p class="font-mono text-xs uppercase tracking-widest text-ash">Current digest (deployed by the chart)</p>
        <pre class="mt-2 overflow-x-auto rounded-lg border border-line bg-ink p-3 font-mono text-xs text-paper"><code>{digest}</code></pre>
        <p class="mt-2 text-xs text-ash">Signatures, the SBOM, and provenance all attach to this digest. Pin to it for reproducible, tamper-evident pulls.</p>
      </section>
    )}

    <section class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {([
        ['Signed', 'cosign keyless'],
        ['SBOM', 'SPDX, on digest'],
        ['Provenance', 'SLSA build'],
        ['Architectures', 'amd64, arm64'],
        ['Runs as', runsAs],
        ['Root filesystem', 'read-only'],
        ...(sizeLabel ? [['Image size', sizeLabel]] as [string, string][] : []),
        ...(sbomPackages != null ? [['SBOM packages', String(sbomPackages)]] as [string, string][] : []),
      ] as [string, string][]).map(([k, v]) => (
        <div class="rounded-lg border border-line bg-graphite p-3">
          <div class="font-mono text-[10px] uppercase tracking-widest text-ash">{k}</div>
          <div class="mt-1 text-sm font-medium text-paper">{v}</div>
        </div>
      ))}
    </section>

    {entry.caution && (
      <aside class="mt-6 rounded-xl border border-amber-500/50 bg-amber-500/5 p-5">
        <p class="font-mono text-xs uppercase tracking-widest text-amber-400">License caution · {entry.license} is not OSI-approved</p>
        <p class="mt-2 text-sm leading-relaxed text-paper">
          {entry.name} is source-available, not open source. We carry it hardened, but do not
          represent it as open source.
        </p>
        {entry.cleanAlternative && (
          <p class="mt-2 text-sm leading-relaxed text-ash">
            Clean alternative: <span class="text-paper">{entry.cleanAlternative}</span>
          </p>
        )}
        {alternatives.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5 font-mono text-[11px] uppercase tracking-widest">
            {alternatives.map((a) => (
              <a
                href={a.hasImage ? `/images/${a.slug}` : `/charts/${a.slug}`}
                class="rounded border border-line bg-graphite px-2.5 py-1 text-paper transition-colors hover:bg-ink"
              >{a.name} &rarr;</a>
            ))}
          </div>
        )}
      </aside>
    )}

    {sevs.length > 0 && (
      <section class="mt-8 rounded-xl border border-line bg-graphite p-5">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="font-mono text-xs uppercase tracking-widest text-ash">Security report (Trivy, via ArtifactHub)</h2>
          {total === 0 && <span class="font-mono text-xs uppercase tracking-widest text-paper">0 fixable CVEs</span>}
        </div>
        <div class="mt-4 grid grid-cols-5 gap-3 text-center">
          {sevs.map(([k, v]) => (
            <div class="rounded-lg bg-ink p-3">
              <div class="text-2xl font-bold tabular-nums">{v}</div>
              <div class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ash">{k}</div>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 rounded-2xl border border-line bg-graphite p-6">
      <h2 class="text-xl font-semibold tracking-tight">Pull the image</h2>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        Run it directly with Docker, Podman, or any Kubernetes workload. Nonroot, read-only root
        filesystem, built for amd64 and arm64.
      </p>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Pull (tag)</p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-sm text-paper"><code>docker pull {pullTag ? `${image}:${pullTag}` : image}</code></pre>
      {digest && pinned && (
        <>
          <p class="mt-4 font-mono text-xs uppercase tracking-widest text-ash">Pinned by digest (recommended)</p>
          <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code>docker pull {pinned}</code></pre>
        </>
      )}

      {imageTags.length > 0 && (
        <>
          <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Tags</p>
          <div class="mt-2 flex flex-wrap gap-1.5 font-mono text-[11px] text-paper">
            {imageTags.map((t) => <span class="rounded bg-ink px-2 py-1">{t}</span>)}
          </div>
          <p class="mt-2 text-xs text-ash">Images are tagged by app version (never <code class="font-mono">:latest</code>): a multi-arch index plus per-arch tags.</p>
        </>
      )}

      <dl class="mt-5 space-y-2.5 text-sm">
        <div class="flex justify-between gap-3"><dt class="text-ash">App version</dt><dd class="font-medium">{pullTag ?? 'n/a'}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">Architectures</dt><dd class="font-medium">amd64, arm64</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">Runs as</dt><dd class="font-medium">{runsAs}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">Root filesystem</dt><dd class="font-medium">read-only</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">License</dt><dd class:list={['font-medium', entry.caution ? 'text-amber-400' : '']}>{entry.license}</dd></div>
      </dl>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Verify the supply chain</p>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        This image is cosign-signed and carries an SPDX SBOM and a SLSA build-provenance
        attestation on the same digest. Check all three yourself:
      </p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code><span class="text-ash"># 1. signature — built and signed by QuenchWorks CI</span>
cosign verify {verifyRef} \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com

<span class="text-ash"># 2. SLSA build provenance — which workflow built it, from what</span>
gh attestation verify oci://{verifyRef} --owner quenchworks

<span class="text-ash"># 3. SPDX SBOM — the package inventory</span>
gh attestation verify oci://{verifyRef} --owner quenchworks \
  --predicate-type https://spdx.dev/Document</code></pre>
      <p class="mt-2 text-xs text-ash">See the <a href="/docs/sbom" class="text-paper underline-offset-4 hover:underline">SBOM &amp; provenance guide</a> for reading the SBOM and using these checks in CI.</p>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Transparency</p>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        Every attestation is published on the org's <a href="https://github.com/quenchworks/images/attestations" class="text-paper underline-offset-4 hover:underline">GitHub attestations</a> listing and logged to the Sigstore transparency log (Rekor), which <code class="font-mono">cosign verify</code> and <code class="font-mono">gh attestation verify</code> check for you.
      </p>

      <div class="mt-5 flex flex-wrap gap-2 font-mono text-xs uppercase tracking-widest">
        {hasChart && <a href={`/charts/${entry.slug}`} class="rounded-lg border border-paper/40 px-3.5 py-2 text-paper transition-colors hover:bg-ink">View the Helm chart</a>}
        <a href="https://github.com/quenchworks/images" class="rounded-lg border border-line px-3.5 py-2 text-paper transition-colors hover:bg-ink">Image source</a>
      </div>
    </section>

    <p class="mt-8 text-sm text-ash">
      Upstream project: <a href={entry.upstream} class="text-paper underline-offset-4 hover:underline">{entry.upstream}</a>
    </p>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
  <Footer />
</Base>
