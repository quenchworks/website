---
// Bento feature grid, 4 tiles. SVG icons only (Lucide-style strokes), monochrome.
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const t = useTranslations(getLangFromUrl(Astro.url));

const features = [
  {
    title: t('features.builtFromSource.title'),
    body: t('features.builtFromSource.body'),
    icon: 'cube',
    span: 'sm:col-span-2',
  },
  {
    title: t('features.zeroCve.title'),
    body: t('features.zeroCve.body'),
    icon: 'shield',
    span: '',
  },
  {
    title: t('features.signed.title'),
    body: t('features.signed.body'),
    icon: 'badge',
    span: '',
  },
  {
    title: t('features.pinned.title'),
    body: t('features.pinned.body'),
    icon: 'hash',
    span: 'sm:col-span-2',
  },
];
---

<section id="how" class="mx-auto max-w-5xl px-5 py-16 sm:py-24">
  <div class="mb-10 text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{t('features.title')}</h2>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    {
      features.map((f, i) => (
        <article
          data-reveal
          style={`--i:${i}`}
          class={`group rounded-xl border border-line bg-graphite p-6 transition duration-200 hover:-translate-y-px hover:border-ash/50 ${f.span}`}
        >
          <div class="mb-4 inline-flex size-10 items-center justify-center rounded-lg border border-line text-paper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="size-5" aria-hidden="true">
              {f.icon === 'cube' && (
                <>
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
                  <path d="m3.3 7 8.7 5 8.7-5M12 22V12" />
                </>
              )}
              {f.icon === 'shield' && (
                <>
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                  <path d="m9 12 2 2 4-4" />
                </>
              )}
              {f.icon === 'badge' && (
                <>
                  <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                  <path d="M12 2 4 6v6c0 5 8 8 8 8s8-3 8-8V6Z" opacity="0" />
                  <path d="m7.5 12.5-2 7 2.5-1 1.5 2 2-6M16.5 12.5l2 7-2.5-1-1.5 2-2-6" />
                </>
              )}
              {f.icon === 'hash' && (
                <>
                  <path d="M4 9h16M4 15h16M10 3 8 21M16 3l-2 18" />
                </>
              )}
            </svg>
          </div>
          <h3 class="text-lg font-semibold tracking-tight">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ash">{f.body}</p>
        </article>
      ))
    }
  </div>
</section>
