---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import { ghcr, type ChartEntry } from '../data/charts';
import { images } from '../data/images';
import { resolveAlternatives } from '../data/alternatives';
import { slugify } from '../data/slugify';
import type { AhDetail } from '../data/artifacthub';
import { getLangFromUrl, useTranslations, localizeUrl } from '../i18n/ui';
import { localizedSummary } from '../i18n/content';

interface Props {
  entry: ChartEntry;
  /** The chart version this page renders. */
  version: string;
  /** Live ArtifactHub detail (the latest line). Always fetched on the base page. */
  ah: AhDetail | null;
  /**
   * Release timestamp (unix seconds) for THIS version, from ah.versions.
   * Lets historical pages show the right date without per-version AH fetches.
   */
  versionTs?: number;
}

const { entry, version, ah, versionTs } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => localizeUrl(lang, p);
const summary = localizedSummary(lang, 'charts', entry.slug, entry.summary);
const hasImage = images.some((i) => i.slug === entry.slug && i.status === 'available');

// The newest chart version (ArtifactHub history is newest-first). The base page
// renders it with the full live detail; older versions get a generic page.
const allVersions = (ah?.versions ?? []).map((v) => v.version);
const versions = allVersions.length > 0 ? allVersions : [version];
const isLatest = versions[0] === version;

const appVersion = ah?.appVersion ?? entry.appVersion;
const signed = ah?.signed ?? true;
const installRef = entry.chartRef || `oci://${ghcr}/charts/${entry.slug}`;
const pinnedImage = ah?.image ?? (entry.imageDigest ? `${entry.imageRepository}@${entry.imageDigest}` : undefined);
const imageDigest = pinnedImage?.includes('@') ? pinnedImage.slice(pinnedImage.indexOf('@') + 1) : undefined;

// The release date for the version this page shows.
const releaseTs = versionTs ?? (isLatest ? ah?.ts : undefined);
const releaseDate = releaseTs ? new Date(releaseTs * 1000).toISOString().slice(0, 10) : undefined;

const alternatives = entry.caution ? resolveAlternatives(entry.cleanAlternative) : [];
const categorySlug = slugify(entry.category);

function freshness(iso: string): { abs: string; rel: string } {
  const built = new Date(iso);
  const abs = built.toISOString().slice(0, 10);
  const days = Math.floor((Date.now() - built.getTime()) / 86_400_000);
  const rel = days <= 0 ? 'today' : days === 1 ? '1 day ago' : `${days} days ago`;
  return { abs, rel };
}

// Size/built for the image this chart deploys (shares the chart's slug), from
// images.json versions[]. Only meaningful on the latest line.
const imgVersions = images.find((i) => i.slug === entry.slug)?.versions ?? [];
const vmeta = isLatest
  ? (imgVersions.find((v) => v.version === appVersion) ?? imgVersions.find((v) => v.version === entry.appVersion) ?? imgVersions[0])
  : undefined;
const sizeLabel = vmeta?.size;
const fresh = vmeta?.published ? freshness(vmeta.published) : undefined;

const titleSuffix = isLatest ? '' : ` ${version}`;

const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: entry.name,
  description: summary,
  applicationCategory: entry.category,
  operatingSystem: 'Linux',
  ...(appVersion ? { softwareVersion: appVersion } : {}),
  isAccessibleForFree: true,
  license: entry.license,
  codeRepository: entry.upstream || entry.upstreams?.[0] || '',
};
---

<Base title={`${entry.name}${titleSuffix} chart · QuenchWorks`} description={summary} image={`/og/${entry.slug}.png`}>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16" data-pagefind-body data-pagefind-meta={`title:${entry.name} chart,type:Chart`}>
    <nav class="flex flex-wrap items-center gap-2 font-mono text-xs uppercase tracking-widest text-ash" aria-label="Breadcrumb">
      <a href={l('/charts')} class="transition-colors hover:text-paper">{t('detail.breadcrumb.charts')}</a>
      <span class="text-line" aria-hidden="true">/</span>
      <a href={l(`/charts/category/${categorySlug}`)} class="rounded border border-line bg-graphite px-2 py-0.5 text-paper transition-colors hover:border-paper/40">{entry.category}</a>
      <span class="text-line" aria-hidden="true">/</span>
      <span class="text-paper">{entry.name}{isLatest ? '' : ` ${version}`}</span>
    </nav>

    <header class="mt-6 flex items-center gap-4">
      <img src="/brand/icon-dark.svg" alt="" class="size-12" width="48" height="48" />
      <div>
        <h1 class="text-4xl font-bold tracking-tight">{entry.name}{isLatest ? '' : ` ${version}`}</h1>
        <p class="mt-1 font-mono text-xs uppercase tracking-widest text-ash">
          {t('detail.label.chart')} · <a href={l(`/charts/category/${categorySlug}`)} class="underline-offset-4 transition-colors hover:text-paper hover:underline">{entry.category}</a> · {entry.tier} · v{version}
        </p>
      </div>
    </header>

    <div class="mt-4 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
      <span class="rounded border border-line bg-graphite px-2 py-0.5 text-paper">{t('detail.badge.digestPinned')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.cosignSigned')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.spdxSbom')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.slsaProvenance')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.arch')}</span>
      {fresh && (
        <span class="rounded border border-line bg-graphite px-2 py-0.5 text-paper" title={`${t('detail.rebuiltTitle')} ${fresh.rel}`}>{t('detail.badge.rebuilt')}{fresh.abs}</span>
      )}
    </div>

    <p class="mt-6 max-w-2xl text-ash">{summary}</p>

    <VersionSwitcher section="charts" slug={entry.slug} versions={versions} current={version} />

    {!isLatest && (
      <section class="mt-6 rounded-xl border border-line bg-graphite p-5">
        <p class="font-mono text-xs uppercase tracking-widest text-ash">{t('chart.released.heading')}</p>
        <p class="mt-2 text-sm leading-relaxed text-paper">
          {t('chart.released.bodyPre')} <span class="font-mono">{version}</span> {t('chart.released.bodyMid')} {entry.name} {t('chart.released.bodyChart')}{releaseDate ? `${t('chart.released.published')} ${releaseDate}` : ''}.
          {t('chart.released.bodyEnd')}
          <a href={l(`/charts/${entry.slug}`)} class="text-paper underline-offset-4 hover:underline"> {t('chart.released.latestLink')}</a>.
        </p>
      </section>
    )}

    {isLatest && (imageDigest || version) && (
      <section class="mt-6 rounded-xl border border-line bg-graphite p-5">
        {imageDigest && (
          <>
            <p class="font-mono text-xs uppercase tracking-widest text-ash">{t('chart.deployedDigest.heading')}</p>
            <pre class="mt-2 overflow-x-auto rounded-lg border border-line bg-ink p-3 font-mono text-xs text-paper"><code>{imageDigest}</code></pre>
          </>
        )}
        <p class="mt-4 font-mono text-xs uppercase tracking-widest text-ash">{t('chart.ociVersion.heading')}</p>
        <pre class="mt-2 overflow-x-auto rounded-lg border border-line bg-ink p-3 font-mono text-xs text-paper"><code>{installRef}:{version}</code></pre>
        <p class="mt-2 text-xs text-ash">{t('chart.deployNote')}</p>
      </section>
    )}

    <section class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {([
        [t('detail.meta.signed'), signed ? t('detail.meta.signedValue') : t('chart.field.no')],
        [t('detail.meta.sbom'), t('detail.meta.sbomOnImage')],
        [t('detail.meta.provenance'), t('detail.meta.provenanceValue')],
        [t('detail.meta.architectures'), t('detail.meta.archValue')],
        [t('detail.meta.runsAs'), 'nonroot (uid 1001)'],
        [t('detail.meta.rootFs'), t('detail.meta.rootFsValue')],
        ...(sizeLabel ? [[t('detail.meta.imageSize'), sizeLabel]] as [string, string][] : []),
      ] as [string, string][]).map(([k, v]) => (
        <div class="rounded-lg border border-line bg-graphite p-3">
          <div class="font-mono text-[10px] uppercase tracking-widest text-ash">{k}</div>
          <div class="mt-1 text-sm font-medium text-paper">{v}</div>
        </div>
      ))}
    </section>

    {entry.caution && (
      <aside class="mt-6 rounded-xl border border-amber-500/50 bg-amber-500/5 p-5">
        <p class="font-mono text-xs uppercase tracking-widest text-amber-400">{t('detail.caution.heading')} {entry.license} {t('detail.caution.notOsi')}</p>
        <p class="mt-2 text-sm leading-relaxed text-paper">
          {entry.name} {t('detail.caution.bodyChart')}
        </p>
        {entry.cleanAlternative && (
          <p class="mt-2 text-sm leading-relaxed text-ash">
            {t('detail.caution.cleanAlt')} <span class="text-paper">{entry.cleanAlternative}</span>
          </p>
        )}
        {alternatives.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5 font-mono text-[11px] uppercase tracking-widest">
            {alternatives.map((a) => (
              <a
                href={l(a.hasChart ? `/charts/${a.slug}` : `/images/${a.slug}`)}
                class="rounded border border-line bg-graphite px-2.5 py-1 text-paper transition-colors hover:bg-ink"
              >{a.name} &rarr;</a>
            ))}
          </div>
        )}
      </aside>
    )}

    <section class="mt-8 rounded-2xl border border-line bg-graphite p-6">
      <h2 class="text-xl font-semibold tracking-tight">{t('chart.install.heading')}</h2>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        {t('chart.install.intro')}
      </p>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{isLatest ? t('chart.install.labelLatest') : `${t('chart.install.labelPinnedPre')} ${version})`}</p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-sm text-paper"><code>helm install my-{entry.slug} {installRef} --version {version}</code></pre>

      {isLatest && entry.images?.length ? (
        <>
          <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('chart.install.deploys')}</p>
          <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code>{entry.images.map((i) => i.image).join('\n')}</code></pre>
        </>
      ) : isLatest && pinnedImage ? (
        <>
          <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('chart.install.deploys')}</p>
          <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code>{pinnedImage}</code></pre>
        </>
      ) : null}

      {entry.components?.length && (
        <>
          <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('detail.chartsUsed')}</p>
          <div class="mt-2 flex flex-wrap gap-1.5 font-mono text-[11px] uppercase tracking-widest">
            {entry.components.map((c) => (
              <a href={l(`/charts/${c}`)} class="rounded border border-line bg-graphite px-2.5 py-1 text-paper transition-colors hover:bg-ink">{c} &rarr;</a>
            ))}
          </div>
        </>
      )}

      <dl class="mt-5 space-y-2.5 text-sm">
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.chartVersion')}</dt><dd class="font-medium">{version}</dd></div>
        {isLatest && <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.appVersion')}</dt><dd class="font-medium">{appVersion ?? 'n/a'}</dd></div>}
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.chartLicense')}</dt><dd class="font-medium">{ah?.chartLicense ?? 'MIT'}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.appLicense')}</dt><dd class:list={['font-medium', entry.caution ? 'text-amber-400' : '']}>{entry.license}</dd></div>
        {entry.port && <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.servicePort')}</dt><dd class="font-medium">{entry.port}</dd></div>}
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.signed')}</dt><dd class="font-medium">{signed ? t('chart.field.signedKeyless') : t('chart.field.signedNo')}</dd></div>
        {isLatest && <div class="flex justify-between gap-3"><dt class="text-ash">{t('chart.field.valuesSchema')}</dt><dd class="font-medium">{ah?.hasValuesSchema ? t('chart.field.yes') : t('chart.field.no')}</dd></div>}
        {releaseDate && <div class="flex justify-between gap-3"><dt class="text-ash">{isLatest ? t('chart.field.lastPublished') : t('chart.field.released')}</dt><dd class="font-medium">{releaseDate}</dd></div>}
      </dl>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('chart.verify.heading')}</p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code>cosign verify {ghcr}/charts/{entry.slug}:{version} \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com</code></pre>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('detail.transparency.heading')}</p>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        {t('chart.transparency.pre')} <a href="https://github.com/quenchworks/charts/attestations" class="text-paper underline-offset-4 hover:underline">{t('chart.transparency.attestLink')}</a> {t('chart.transparency.post')} <code class="font-mono">cosign verify</code> {t('chart.transparency.postEnd')}
      </p>

      <div class="mt-5 flex flex-wrap gap-2 font-mono text-xs uppercase tracking-widest">
        {hasImage && <a href={l(`/images/${entry.slug}`)} class="rounded-lg border border-paper/40 px-3.5 py-2 text-paper transition-colors hover:bg-ink">{t('detail.action.viewImage')}</a>}
        {ah?.url && <a href={ah.url} class="rounded-lg border border-line px-3.5 py-2 text-paper transition-colors hover:bg-ink">{t('detail.action.viewArtifactHub')}</a>}
        <a href={`https://github.com/quenchworks/charts/tree/main/quench/${entry.slug}`} class="rounded-lg border border-line px-3.5 py-2 text-paper transition-colors hover:bg-ink">{t('detail.action.chartSource')}</a>
      </div>
    </section>

    {entry.upstreams?.length ? (
      <div class="mt-8 text-sm text-ash">
        <p>{t('detail.upstream')}</p>
        <ul class="mt-2 space-y-1">
          {entry.upstreams.map((u) => (
            <li><a href={u} class="text-paper underline-offset-4 hover:underline">{u}</a></li>
          ))}
        </ul>
      </div>
    ) : entry.upstream ? (
      <p class="mt-8 text-sm text-ash">
        {t('detail.upstream')} <a href={entry.upstream} class="text-paper underline-offset-4 hover:underline">{entry.upstream}</a>
      </p>
    ) : null}
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
  <Footer />
</Base>
