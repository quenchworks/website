---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import { ghcr, type ChartEntry } from '../data/charts';
import { images } from '../data/images';
import { resolveAlternatives } from '../data/alternatives';
import { slugify } from '../data/slugify';
import imageMeta from '../data/image-meta.json';
import type { AhDetail } from '../data/artifacthub';

interface Props {
  entry: ChartEntry;
  /** The chart version this page renders. */
  version: string;
  /** Live ArtifactHub detail (the latest line). Always fetched on the base page. */
  ah: AhDetail | null;
  /**
   * Release timestamp (unix seconds) for THIS version, from ah.versions.
   * Lets historical pages show the right date without per-version AH fetches.
   */
  versionTs?: number;
}

const { entry, version, ah, versionTs } = Astro.props;
const hasImage = images.some((i) => i.slug === entry.slug && i.status === 'available');

// The newest chart version (ArtifactHub history is newest-first). The base page
// renders it with the full live detail; older versions get a generic page.
const allVersions = (ah?.versions ?? []).map((v) => v.version);
const versions = allVersions.length > 0 ? allVersions : [version];
const isLatest = versions[0] === version;

const appVersion = ah?.appVersion ?? entry.appVersion;
const signed = ah?.signed ?? true;
const installRef = entry.chartRef || `oci://${ghcr}/charts/${entry.slug}`;
const pinnedImage = ah?.image ?? (entry.imageDigest ? `${entry.imageRepository}@${entry.imageDigest}` : undefined);
const imageDigest = pinnedImage?.includes('@') ? pinnedImage.slice(pinnedImage.indexOf('@') + 1) : undefined;

// The release date for the version this page shows.
const releaseTs = versionTs ?? (isLatest ? ah?.ts : undefined);
const releaseDate = releaseTs ? new Date(releaseTs * 1000).toISOString().slice(0, 10) : undefined;

const alternatives = entry.caution ? resolveAlternatives(entry.cleanAlternative) : [];
const categorySlug = slugify(entry.category);

// Humanize a byte count into a compact MB/GB string (e.g. "28.4 MB").
function humanizeBytes(bytes: number): string {
  if (bytes >= 1e9) return `${(bytes / 1e9).toFixed(1)} GB`;
  if (bytes >= 1e6) return `${(bytes / 1e6).toFixed(1)} MB`;
  if (bytes >= 1e3) return `${(bytes / 1e3).toFixed(1)} KB`;
  return `${bytes} B`;
}
function freshness(iso: string): { abs: string; rel: string } {
  const built = new Date(iso);
  const abs = built.toISOString().slice(0, 10);
  const days = Math.floor((Date.now() - built.getTime()) / 86_400_000);
  const rel = days <= 0 ? 'today' : days === 1 ? '1 day ago' : `${days} days ago`;
  return { abs, rel };
}

// Build-time metadata for the image this chart deploys (shares the chart's slug).
// Only meaningful on the latest line; historical pages keep it generic.
type ImgMeta = { sizeBytes?: number; builtISO?: string; sbomPackages?: number };
const metaByTag = (imageMeta as Record<string, Record<string, ImgMeta>>)[entry.slug] ?? {};
const meta = isLatest ? (metaByTag[appVersion ?? ''] ?? metaByTag[entry.appVersion ?? ''] ?? Object.values(metaByTag)[0]) : undefined;
const sizeLabel = meta?.sizeBytes != null ? humanizeBytes(meta.sizeBytes) : undefined;
const fresh = meta?.builtISO ? freshness(meta.builtISO) : undefined;
const sbomPackages = meta?.sbomPackages;

const titleSuffix = isLatest ? '' : ` ${version}`;

const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: entry.name,
  description: entry.summary,
  applicationCategory: entry.category,
  operatingSystem: 'Linux',
  ...(appVersion ? { softwareVersion: appVersion } : {}),
  isAccessibleForFree: true,
  license: entry.license,
  codeRepository: entry.upstream,
};
---

<Base title={`${entry.name}${titleSuffix} chart · Quenchworks`} description={entry.summary} image={`/og/${entry.slug}.png`}>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16" data-pagefind-body data-pagefind-meta={`title:${entry.name} chart,type:Chart`}>
    <a href="/charts" class="font-mono text-xs uppercase tracking-widest text-ash transition-colors hover:text-paper">&larr; Charts</a>

    <header class="mt-6 flex items-center gap-4">
      <img src="/brand/icon-dark.svg" alt="" class="size-12" width="48" height="48" />
      <div>
        <h1 class="text-4xl font-bold tracking-tight">{entry.name}{isLatest ? '' : ` ${version}`}</h1>
        <p class="mt-1 font-mono text-xs uppercase tracking-widest text-ash">
          Chart · <a href={`/charts/category/${categorySlug}`} class="underline-offset-4 transition-colors hover:text-paper hover:underline">{entry.category}</a> · {entry.tier} · v{version}
        </p>
      </div>
    </header>

    <div class="mt-4 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
      <span class="rounded border border-line bg-graphite px-2 py-0.5 text-paper">digest&nbsp;pinned</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">cosign&nbsp;signed</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">SPDX&nbsp;SBOM</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">SLSA&nbsp;provenance</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">amd64&nbsp;·&nbsp;arm64</span>
      {fresh && (
        <span class="rounded border border-line bg-graphite px-2 py-0.5 text-paper" title={`Image rebuilt ${fresh.rel}`}>Rebuilt&nbsp;{fresh.abs}</span>
      )}
    </div>

    <p class="mt-6 max-w-2xl text-ash">{entry.summary}</p>

    <VersionSwitcher section="charts" slug={entry.slug} versions={versions} current={version} />

    {!isLatest && (
      <section class="mt-6 rounded-xl border border-line bg-graphite p-5">
        <p class="font-mono text-xs uppercase tracking-widest text-ash">Released version</p>
        <p class="mt-2 text-sm leading-relaxed text-paper">
          This is the <span class="font-mono">{version}</span> release of the {entry.name} chart{releaseDate ? `, published ${releaseDate}` : ''}.
          For the live security report and the currently deployed image digest, see the
          <a href={`/charts/${entry.slug}`} class="text-paper underline-offset-4 hover:underline"> latest release</a>.
        </p>
      </section>
    )}

    {isLatest && (imageDigest || version) && (
      <section class="mt-6 rounded-xl border border-line bg-graphite p-5">
        {imageDigest && (
          <>
            <p class="font-mono text-xs uppercase tracking-widest text-ash">Deployed image digest</p>
            <pre class="mt-2 overflow-x-auto rounded-lg border border-line bg-ink p-3 font-mono text-xs text-paper"><code>{imageDigest}</code></pre>
          </>
        )}
        <p class="mt-4 font-mono text-xs uppercase tracking-widest text-ash">Chart OCI version</p>
        <pre class="mt-2 overflow-x-auto rounded-lg border border-line bg-ink p-3 font-mono text-xs text-paper"><code>{installRef}:{version}</code></pre>
        <p class="mt-2 text-xs text-ash">The chart pins its image by this signed digest, so you never track it yourself. Signatures, SBOM, and provenance attach to the same digest.</p>
      </section>
    )}

    <section class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {([
        ['Signed', signed ? 'cosign keyless' : 'no'],
        ['SBOM', 'SPDX, on image'],
        ['Provenance', 'SLSA build'],
        ['Architectures', 'amd64, arm64'],
        ['Runs as', 'nonroot (uid 1001)'],
        ['Root filesystem', 'read-only'],
        ...(sizeLabel ? [['Image size', sizeLabel]] as [string, string][] : []),
        ...(sbomPackages != null ? [['SBOM packages', String(sbomPackages)]] as [string, string][] : []),
      ] as [string, string][]).map(([k, v]) => (
        <div class="rounded-lg border border-line bg-graphite p-3">
          <div class="font-mono text-[10px] uppercase tracking-widest text-ash">{k}</div>
          <div class="mt-1 text-sm font-medium text-paper">{v}</div>
        </div>
      ))}
    </section>

    {entry.caution && (
      <aside class="mt-6 rounded-xl border border-amber-500/50 bg-amber-500/5 p-5">
        <p class="font-mono text-xs uppercase tracking-widest text-amber-400">License caution · {entry.license} is not OSI-approved</p>
        <p class="mt-2 text-sm leading-relaxed text-paper">
          {entry.name} is source-available, not open source. The chart carries this note prominently,
          and we do not represent it as open source.
        </p>
        {entry.cleanAlternative && (
          <p class="mt-2 text-sm leading-relaxed text-ash">
            Clean alternative: <span class="text-paper">{entry.cleanAlternative}</span>
          </p>
        )}
        {alternatives.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5 font-mono text-[11px] uppercase tracking-widest">
            {alternatives.map((a) => (
              <a
                href={a.hasChart ? `/charts/${a.slug}` : `/images/${a.slug}`}
                class="rounded border border-line bg-graphite px-2.5 py-1 text-paper transition-colors hover:bg-ink"
              >{a.name} &rarr;</a>
            ))}
          </div>
        )}
      </aside>
    )}

    <section class="mt-8 rounded-2xl border border-line bg-graphite p-6">
      <h2 class="text-xl font-semibold tracking-tight">Install the chart</h2>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        Deploy to Kubernetes with hardened defaults. The chart pins its image by signed digest, so
        you never track it yourself.
      </p>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Install {isLatest ? '(latest)' : `(pinned to ${version})`}</p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-sm text-paper"><code>helm install my-{entry.slug} {installRef} --version {version}</code></pre>

      {isLatest && pinnedImage && (
        <>
          <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Deploys image (digest-pinned)</p>
          <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code>{pinnedImage}</code></pre>
        </>
      )}

      <dl class="mt-5 space-y-2.5 text-sm">
        <div class="flex justify-between gap-3"><dt class="text-ash">Chart version</dt><dd class="font-medium">{version}</dd></div>
        {isLatest && <div class="flex justify-between gap-3"><dt class="text-ash">App version</dt><dd class="font-medium">{appVersion ?? 'n/a'}</dd></div>}
        <div class="flex justify-between gap-3"><dt class="text-ash">Chart license</dt><dd class="font-medium">{ah?.chartLicense ?? 'MIT'}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">App license</dt><dd class:list={['font-medium', entry.caution ? 'text-amber-400' : '']}>{entry.license}</dd></div>
        {entry.port && <div class="flex justify-between gap-3"><dt class="text-ash">Service port</dt><dd class="font-medium">{entry.port}</dd></div>}
        <div class="flex justify-between gap-3"><dt class="text-ash">Signed</dt><dd class="font-medium">{signed ? 'cosign (keyless)' : 'no'}</dd></div>
        {isLatest && <div class="flex justify-between gap-3"><dt class="text-ash">Values schema</dt><dd class="font-medium">{ah?.hasValuesSchema ? 'yes' : 'no'}</dd></div>}
        {releaseDate && <div class="flex justify-between gap-3"><dt class="text-ash">{isLatest ? 'Last published' : 'Released'}</dt><dd class="font-medium">{releaseDate}</dd></div>}
      </dl>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Verify the chart</p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code>cosign verify {ghcr}/charts/{entry.slug}:{version} \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com</code></pre>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">Transparency</p>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        The chart and the image it deploys both publish their attestations on GitHub (<a href="https://github.com/quenchworks/charts/attestations" class="text-paper underline-offset-4 hover:underline">charts</a>, <a href="https://github.com/quenchworks/images/attestations" class="text-paper underline-offset-4 hover:underline">images</a>) and log them to the Sigstore transparency log (Rekor), which <code class="font-mono">cosign verify</code> checks for you.
      </p>

      <div class="mt-5 flex flex-wrap gap-2 font-mono text-xs uppercase tracking-widest">
        {hasImage && <a href={`/images/${entry.slug}`} class="rounded-lg border border-paper/40 px-3.5 py-2 text-paper transition-colors hover:bg-ink">View the image</a>}
        {ah?.url && <a href={ah.url} class="rounded-lg border border-line px-3.5 py-2 text-paper transition-colors hover:bg-ink">View on ArtifactHub</a>}
        <a href="https://github.com/quenchworks/charts" class="rounded-lg border border-line px-3.5 py-2 text-paper transition-colors hover:bg-ink">Chart source</a>
      </div>
    </section>

    <p class="mt-8 text-sm text-ash">
      Upstream project: <a href={entry.upstream} class="text-paper underline-offset-4 hover:underline">{entry.upstream}</a>
    </p>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
  <Footer />
</Base>
