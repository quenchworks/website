---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import { Code } from 'astro-expressive-code/components';
import { ghcr, canonicalVersions, type ImageEntry } from '../data/images';
import { fetchPackageDetail } from '../data/artifacthub';
import security from '../data/security.json';
import CveStatus from '../components/CveStatus.astro';
import { dockerfileFor } from '../data/dockerfiles';
import { slugify } from '../data/slugify';
import { getLangFromUrl, useTranslations, localizeUrl } from '../i18n/ui';
import { localizedSummary } from '../i18n/content';

interface Props {
  /** The runtime catalog entry. */
  entry: ImageEntry;
  /** The version this page renders (must be one of the slug's tags). */
  version: string;
}

const { entry, version } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => localizeUrl(lang, p);
const summary = localizedSummary(lang, 'images', entry.slug, entry.summary);
const image = entry.image || `${ghcr}/images/${entry.slug}`;

// Turn a build timestamp into a short, friendly label.
function freshness(iso: string): { abs: string; rel: string } {
  const built = new Date(iso);
  const abs = built.toISOString().slice(0, 10);
  const days = Math.floor((Date.now() - built.getTime()) / 86_400_000);
  const rel = days <= 0 ? 'today' : days === 1 ? '1 day ago' : `${days} days ago`;
  return { abs, rel };
}

// Map each runtime slug to the build guide that covers its ecosystem.
const BUILD_GUIDE: Record<string, { slug: string; label: string }> = {
  node: { slug: 'build-node', label: t('runtime.guide.buildNode') },
  bun: { slug: 'build-node', label: t('runtime.guide.buildNode') },
  deno: { slug: 'build-node', label: t('runtime.guide.buildNode') },
  pnpm: { slug: 'build-node', label: t('runtime.guide.buildNode') },
  yarn: { slug: 'build-node', label: t('runtime.guide.buildNode') },
  python: { slug: 'build-python', label: t('runtime.guide.buildPython') },
  uv: { slug: 'build-python', label: t('runtime.guide.buildPython') },
  poetry: { slug: 'build-python', label: t('runtime.guide.buildPython') },
  go: { slug: 'build-go', label: t('runtime.guide.buildGoRust') },
  rust: { slug: 'build-go', label: t('runtime.guide.buildGoRust') },
  static: { slug: 'build-go', label: t('runtime.guide.buildGoRust') },
  jdk: { slug: 'build-java', label: t('runtime.guide.buildJava') },
  jre: { slug: 'build-java', label: t('runtime.guide.buildJava') },
  maven: { slug: 'build-java', label: t('runtime.guide.buildJava') },
  gradle: { slug: 'build-java', label: t('runtime.guide.buildJava') },
  dotnet: { slug: 'build-dotnet', label: t('runtime.guide.buildDotnet') },
  'dotnet-runtime': { slug: 'build-dotnet', label: t('runtime.guide.buildDotnet') },
  aspnet: { slug: 'build-dotnet', label: t('runtime.guide.buildDotnet') },
};

// live, build-time facts from ArtifactHub.
const ah = await fetchPackageDetail(entry.slug);
const appVersion = ah?.appVersion ?? entry.version;

const guide = BUILD_GUIDE[entry.slug] ?? { slug: 'build-images', label: t('runtime.guide.buildImages') };

// The version list driving the page is the published canonical tags (full
// X.Y.Z leaves, newest first), same as the routes — so the switcher, table, and
// generated pages all line up. The Dockerfile is best-effort per version: pick
// the variant matching the selected version, else the newest variant.
const allVersions = canonicalVersions(entry.versions);
const versions = allVersions.map((v) => v.version);
const newest = versions[0];
const dockerfile = dockerfileFor(entry.slug);
const variants = dockerfile?.variants ?? [];
const selected = variants.find((v) => v.version === version) ?? variants[0];

// Per-version size/published from the catalog lock.
const vmeta = allVersions.find((v) => v.version === version) ?? allVersions[0];
const sizeLabel = vmeta?.size;
const fresh = vmeta?.published ? freshness(vmeta.published) : undefined;

// Every reference on this page is pinned to the selected version's tag.
const ref = `${image}:${version}`;

// Public GHCR package page (the images repo is private; the package is public).
const pkgUrl = `https://github.com/orgs/quenchworks/packages/container/package/images%2F${entry.slug}`;

const categorySlug = slugify(entry.category);
const isLatest = versions[0] === version;

// Trivy security for the SELECTED version (security.json carries per-version data),
// shown the same way as the image/chart detail pages; falls back to latest.
const secRec = (security as Record<string, any>)[entry.slug];
const sec = secRec?.versions?.find((v: any) => v.version === version) ?? secRec ?? ah?.security;
const total = sec?.total ?? ah?.securityTotal;
const sevs: [string, number][] = sec
  ? [
      [t('detail.security.critical'), sec.critical],
      [t('detail.security.high'), sec.high],
      [t('detail.security.medium'), sec.medium],
      [t('detail.security.low'), sec.low],
      [t('detail.security.unknown'), sec.unknown],
    ]
  : [];
const titleSuffix = isLatest ? '' : ` ${version}`;

const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: entry.name,
  description: summary,
  applicationCategory: entry.category,
  operatingSystem: 'Linux',
  softwareVersion: version,
  isAccessibleForFree: true,
  license: entry.license,
  codeRepository: entry.upstream,
};
---

<Base title={`${entry.name}${titleSuffix} base image · QuenchWorks`} description={summary} image={`/og/${entry.slug}.png`}>
  <Header />
  <main class="mx-auto max-w-5xl px-5 py-16" data-pagefind-body data-pagefind-meta={`title:${entry.name} runtime,type:Runtime`}>
    <nav class="flex flex-wrap items-center gap-2 font-mono text-xs uppercase tracking-widest text-ash" aria-label="Breadcrumb">
      <a href={l('/images')} class="transition-colors hover:text-paper">{t('detail.breadcrumb.images')}</a>
      <span class="text-line" aria-hidden="true">/</span>
      <a href={l(`/images/category/${categorySlug}`)} class="rounded border border-line bg-graphite px-2 py-0.5 text-paper transition-colors hover:border-paper/40">{entry.category}</a>
      <span class="text-line" aria-hidden="true">/</span>
      <span class="text-paper">{entry.name}{isLatest ? '' : ` ${version}`}</span>
    </nav>

    <header class="mt-6 flex items-center gap-4">
      <img src="/brand/icon-dark.svg" alt="" class="size-12" width="48" height="48" />
      <div>
        <h1 class="text-4xl font-bold tracking-tight">{entry.name}{isLatest ? '' : ` ${version}`}</h1>
        <p class="mt-1 font-mono text-xs uppercase tracking-widest text-ash">
          {t('detail.label.runtime')} · <a href={l(`/images/category/${categorySlug}`)} class="underline-offset-4 transition-colors hover:text-paper hover:underline">{entry.category}</a> · {entry.tier} · v{version}
        </p>
      </div>
    </header>

    <div class="mt-4 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
      <CveStatus total={total} sec={sec} cleanLabel={t('detail.badge.fixableCves')} />
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.nonroot')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.cosignSigned')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.spdxSbom')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.slsaProvenance')}</span>
      <span class="rounded border border-line bg-graphite px-2 py-0.5">{t('detail.badge.arch')}</span>
    </div>

    {entry.knownIssue && (
      <div class="mt-4 flex max-w-2xl items-start gap-2 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-200">
        <span class="mt-0.5 inline-block size-2 shrink-0 rounded-full bg-amber-500" aria-hidden="true" />
        <p><span class="font-semibold">Known issue:</span> {entry.knownIssue}</p>
      </div>
    )}

    <p class="mt-6 max-w-2xl text-ash">{summary}</p>

    <VersionSwitcher section="images" slug={entry.slug} versions={versions} current={version} label={t('versions.lineLabel')} />

    <section class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {([
        [t('detail.meta.image'), `${image}:${version}`, true],
        [t('detail.meta.signed'), t('detail.meta.signedValue'), false],
        [t('detail.meta.sbom'), t('detail.meta.sbomOnDigest'), false],
        [t('detail.meta.provenance'), t('detail.meta.provenanceValue'), false],
        [t('detail.meta.architectures'), t('detail.meta.archValue'), false],
        [t('detail.meta.runsAs'), 'nonroot (uid 1001)', false],
        ...(sizeLabel ? [[t('detail.meta.imageSize'), sizeLabel, false]] as [string, string, boolean][] : []),
        ...(fresh ? [[t('detail.meta.lastRebuilt'), fresh.abs, false]] as [string, string, boolean][] : []),
      ] as [string, string, boolean][]).map(([k, v, isImg]) => (
        <div class="rounded-lg border border-line bg-graphite p-3">
          <div class="font-mono text-[10px] uppercase tracking-widest text-ash">{k}</div>
          <div class="mt-1 break-all text-sm font-medium text-paper">
            {isImg ? <a href={pkgUrl} class="underline-offset-4 transition-colors hover:text-ash hover:underline">{v}</a> : v}
          </div>
        </div>
      ))}
    </section>

    {sevs.length > 0 && (
      <section class="mt-8 rounded-xl border border-line bg-graphite p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="font-mono text-xs uppercase tracking-widest text-ash">{t('detail.security.heading')}</h2>
          <div class="flex flex-wrap items-center gap-2">
            {sec?.grade && (
              <span
                class:list={['inline-flex items-center gap-1 rounded border px-2 py-0.5 font-mono text-[11px] font-semibold uppercase tracking-widest tabular-nums',
                  sec.grade === 'A+' || sec.grade === 'A' ? 'border-emerald-500/40 bg-emerald-500/10 text-emerald-300'
                  : sec.grade === 'B' || sec.grade === 'C' ? 'border-amber-500/40 bg-amber-500/10 text-amber-300'
                  : 'border-red-500/40 bg-red-500/10 text-red-300']}
              >{sec.grade}{sec?.score != null && <span class="text-ash/70">· {sec.score}/100</span>}</span>
            )}
            {total === 0
              ? <span class="font-mono text-[11px] uppercase tracking-widest text-emerald-300">{t('detail.security.zeroFixable')}</span>
              : sec?.fixable
                ? <span class="font-mono text-[11px] uppercase tracking-widest text-amber-300">{sec.fixable} fixable · rebuild clears {sec.fixable === 1 ? 'it' : 'them'}</span>
                : <span class="font-mono text-[11px] uppercase tracking-widest text-ash">{total} open · no upstream fix yet</span>}
          </div>
        </div>
        <div class="mt-4 grid grid-cols-5 gap-3 text-center">
          {sevs.map(([k, v]) => (
            <div class="rounded-lg bg-ink p-3">
              <div class="text-2xl font-bold tabular-nums">{v}</div>
              <div class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ash">{k}</div>
            </div>
          ))}
        </div>
        {sec?.version && <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-ash/70">{t('detail.security.heading')} · {entry.slug} {sec.version}</p>}
      </section>
    )}

    {allVersions.length > 0 && (
      <section class="mt-8 rounded-2xl border border-line bg-graphite p-6">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="text-xl font-semibold tracking-tight">{t('detail.versions.heading')}</h2>
          <span class="font-mono text-xs uppercase tracking-widest text-ash">{allVersions.length} {allVersions.length === 1 ? t('detail.versions.tagOne') : t('detail.versions.tagMany')}</span>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-ash">
          {t('detail.versions.intro')} <code class="font-mono">:latest</code>.
        </p>
        <div class="mt-4 overflow-x-auto">
          <table class="w-full min-w-[34rem] text-start text-sm">
            <thead>
              <tr class="border-b border-line font-mono text-[10px] uppercase tracking-widest text-ash">
                <th scope="col" class="py-2 pe-4 font-medium">{t('detail.versions.colVersion')}</th>
                <th scope="col" class="py-2 pe-4 font-medium">{t('detail.versions.colSize')}</th>
                <th scope="col" class="py-2 pe-4 font-medium">{t('detail.versions.colPublished')}</th>
                <th scope="col" class="py-2 font-medium">{t('detail.versions.colDigest')}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-line/60">
              {allVersions.map((v) => (
                <tr>
                  <td class="py-2.5 pe-4">
                    <a
                      href={l(v.version === newest ? `/images/${entry.slug}` : `/images/${entry.slug}/${v.version}`)}
                      class:list={['font-mono tabular-nums underline-offset-4 transition-colors hover:underline', v.version === version ? 'text-paper' : 'text-paper/90 hover:text-paper']}
                    >{v.version}</a>
                    {v.version === newest && (
                      <span class="ms-2 rounded border border-line px-1.5 py-0.5 align-middle font-mono text-[10px] uppercase tracking-widest text-ash">{t('detail.versions.latest')}</span>
                    )}
                  </td>
                  <td class="py-2.5 pe-4 tabular-nums text-ash">{v.size ?? '—'}</td>
                  <td class="py-2.5 pe-4 tabular-nums text-ash">{v.published ? v.published.slice(0, 10) : '—'}</td>
                  <td class="py-2.5 font-mono text-xs text-ash" title={v.digest}>{v.digest ? `${v.digest.slice(0, 19)}…` : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="mt-8 rounded-2xl border border-line bg-graphite p-6">
      <h2 class="text-xl font-semibold tracking-tight">{t('runtime.base.heading')}</h2>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        {t('runtime.base.intro')}
      </p>

      <pre class="mt-4 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-sm text-paper"><code>FROM {ref}</code></pre>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('runtime.base.orPull')}</p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-sm text-paper"><code>docker pull {ref}</code></pre>

      <dl class="mt-5 space-y-2.5 text-sm">
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('runtime.field.versionLine')}</dt><dd class="font-medium">{version}</dd></div>
        {appVersion && <div class="flex justify-between gap-3"><dt class="text-ash">{t('runtime.field.latestLine')}</dt><dd class="font-medium">{appVersion}</dd></div>}
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('detail.meta.architectures')}</dt><dd class="font-medium">amd64, arm64</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('detail.meta.runsAs')}</dt><dd class="font-medium">nonroot (uid 1001)</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('detail.meta.rootFs')}</dt><dd class="font-medium">{t('detail.meta.rootFsValue')}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ash">{t('detail.field.license')}</dt><dd class:list={['font-medium', entry.caution ? 'text-amber-400' : '']}>{entry.license}</dd></div>
      </dl>

      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-ash">{t('detail.verify.heading')}</p>
      <p class="mt-2 text-sm leading-relaxed text-ash">
        {t('detail.verify.introBuild')}
      </p>
      <pre class="mt-2 overflow-x-auto rounded-xl border border-line bg-ink p-4 font-mono text-xs text-paper"><code><span class="text-ash"># 1. signature — built and signed by QuenchWorks CI</span>
cosign verify {ref} \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com

<span class="text-ash"># 2. SLSA build provenance — which workflow built it, from what</span>
cosign verify-attestation --type https://slsa.dev/provenance/v1 {ref} \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com

<span class="text-ash"># 3. SPDX SBOM — the package inventory</span>
cosign verify-attestation --type https://spdx.dev/Document/v2.3 {ref} \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com</code></pre>
      <p class="mt-2 text-xs text-ash">{t('detail.verify.guidePre')} <a href={l('/docs/sbom')} class="text-paper underline-offset-4 hover:underline">{t('detail.verify.guideLink')}</a> {t('detail.verify.guidePost')}</p>

      <div class="mt-6 flex flex-wrap gap-2 font-mono text-xs uppercase tracking-widest">
        <a href={l(`/docs/${guide.slug}`)} class="rounded-lg border border-paper/40 px-3.5 py-2 text-paper transition-colors hover:bg-ink">{guide.label} &rarr;</a>
        <a href={`https://github.com/orgs/quenchworks/packages/container/package/images%2F${entry.slug}`} class="rounded-lg border border-line px-3.5 py-2 text-paper transition-colors hover:bg-ink">{t('detail.action.viewPackage')}</a>
      </div>
    </section>

    {selected && (
      <section class="mt-8 rounded-2xl border border-line bg-graphite p-6">
        <h2 class="text-xl font-semibold tracking-tight">{t('runtime.dockerfile.heading')} {version}</h2>
        <p class="mt-2 text-sm leading-relaxed text-ash">{dockerfile?.note}</p>
        <div class="mt-4">
          <div class="mb-3 flex flex-wrap gap-1.5 font-mono text-[10px] uppercase tracking-widest text-ash">
            <span class="rounded border border-line bg-ink px-2 py-0.5 text-paper">{ref}</span>
            {sizeLabel && <span class="rounded border border-line bg-ink px-2 py-0.5">{sizeLabel}</span>}
            {fresh && <span class="rounded border border-line bg-ink px-2 py-0.5">{t('runtime.dockerfile.rebuilt')}{fresh.rel}</span>}
          </div>
          <Code code={selected.code} lang="dockerfile" />
        </div>
        <p class="mt-4 text-xs text-ash">
          {t('runtime.dockerfile.notePre')} {version} {t('runtime.dockerfile.notePost')}
          <a href={l(`/docs/${guide.slug}`)} class="text-paper underline-offset-4 hover:underline"> {guide.label}</a>{t('runtime.dockerfile.guideSuffix')}
        </p>
      </section>
    )}

    <p class="mt-8 text-sm text-ash">
      {t('detail.upstream')} <a href={entry.upstream} class="text-paper underline-offset-4 hover:underline">{entry.upstream}</a>
    </p>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
  <Footer />
</Base>
