---
const year = new Date().getFullYear();
const links = [
  { label: 'Catalog', href: '/catalog' },
  { label: 'Roadmap', href: '/roadmap' },
  { label: 'Security', href: '/security' },
  { label: 'GitHub', href: 'https://github.com/quenchworks' },
  { label: 'Images', href: 'https://github.com/orgs/quenchworks/packages?repo_name=images' },
];
---

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-6 px-5 py-10 sm:flex-row">
    <div class="flex items-center gap-3">
      <img src="/brand/icon-dark.svg" alt="" class="size-7" width="28" height="28" aria-hidden="true" />
      <p class="font-mono text-xs text-ash">
        MIT licensed. Built independently, not affiliated with any upstream vendor.
      </p>
    </div>

    <nav class="flex flex-wrap items-center justify-center gap-5" aria-label="Footer">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="border-t border-line/60 py-5 text-center">
    <p class="font-mono text-xs text-ash">
      © {year} Quenchworks · <a href="https://quenchworks.mkabumattar.com" class="hover:text-paper">quenchworks.mkabumattar.com</a>
    </p>
  </div>
</footer>
