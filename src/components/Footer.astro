---
import { githubStars } from '../data/github';
import { getLangFromUrl, useTranslations, localizeUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => localizeUrl(lang, p);
const year = new Date().getFullYear();

// Two columns: catalog/resources and developer entry points. Content-page links
// are localized to the active locale; /api/docs and /rss.xml are global (English
// only), so they are NOT prefixed.
const resources = [
  { label: t('nav.charts'), href: l('/charts') },
  { label: t('nav.images'), href: l('/images') },
  { label: t('nav.stacks'), href: l('/stacks') },
  { label: t('nav.roadmap'), href: l('/roadmap') },
  { label: t('nav.compare'), href: l('/compare') },
  { label: 'Alternatives', href: l('/alternative') },
  { label: t('nav.changelog'), href: l('/changelog') },
  { label: t('nav.faq'), href: l('/faq') },
  { label: t('nav.about'), href: l('/about') },
];
const developers = [
  { label: t('nav.docs'), href: l('/docs') },
  { label: t('nav.api'), href: '/api/docs' },
  { label: t('nav.security'), href: l('/security') },
  { label: 'How it works', href: l('/how-it-works') },
  { label: 'RSS', href: '/rss.xml' },
  { label: 'GitHub', href: 'https://github.com/quenchworks' },
];
---

<footer class="border-t border-line">
  <div class="mx-auto grid max-w-5xl grid-cols-2 gap-x-8 gap-y-10 px-5 py-14 sm:grid-cols-4 lg:gap-x-16">
    {/* Brand block: wordmark + tagline + the GitHub stat, spanning two columns. */}
    <div class="col-span-2 flex flex-col items-start gap-5">
      <a href={l('/')} class="inline-flex shrink-0 items-center" aria-label="Quenchworks home">
        <img src="/brand/logo-dark.svg" alt="Quenchworks" class="h-7 w-auto" width="200" height="51" />
      </a>
      <p class="max-w-xs text-sm leading-relaxed text-ash">{t('footer.tagline')}</p>
      {githubStars !== null && (
        <a
          href="https://github.com/quenchworks"
          class="inline-flex items-center gap-2 rounded-lg border border-line px-3 py-1.5 font-mono text-xs text-ash transition-colors duration-200 hover:border-paper/40 hover:text-paper"
          aria-label={`${githubStars} stars on GitHub`}
        >
          <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7 0-.7 0-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5.1 18.3 5.1c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
          </svg>
          <span class="text-paper" aria-hidden="true">★</span>
          <span class="font-bold tabular-nums text-paper">{githubStars}</span>
        </a>
      )}
    </div>

    <nav class="flex flex-col gap-3" aria-label={t('footer.resources')}>
      <p class="font-mono text-[11px] uppercase tracking-widest text-ash/60">{t('footer.resources')}</p>
      {
        resources.map((x) => (
          <a
            href={x.href}
            class="font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper"
          >
            {x.label}
          </a>
        ))
      }
    </nav>

    <nav class="flex flex-col gap-3" aria-label={t('footer.developers')}>
      <p class="font-mono text-[11px] uppercase tracking-widest text-ash/60">{t('footer.developers')}</p>
      {
        developers.map((x) => (
          <a
            href={x.href}
            class="font-mono text-xs uppercase tracking-widest text-ash transition-colors duration-200 hover:text-paper"
          >
            {x.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="border-t border-line/60">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-3 px-5 py-5 sm:flex-row">
      <p class="font-mono text-xs text-ash">
        © {year} Quenchworks · {t('footer.builtBy')}
        <a href="https://mkabumattar.com/" class="text-paper/80 hover:text-paper">Mohammad Abu Mattar</a>
      </p>
      <a href="https://quench-works.com" class="font-mono text-xs text-ash transition-colors hover:text-paper">quench-works.com</a>
    </div>
  </div>
</footer>
