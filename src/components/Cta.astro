---
// Closing CTA band.
import { getLangFromUrl, useTranslations, localizeUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => localizeUrl(lang, p);
---

<section class="mx-auto max-w-5xl px-5 pb-24">
  <div class="rounded-xl border border-line bg-graphite px-6 py-14 text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{t('cta.title')}</h2>
    <p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-ash">
      {t('cta.body')}
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={l('/charts')}
        class="inline-flex w-full items-center justify-center rounded-lg bg-paper px-5 py-3 text-sm font-semibold text-ink transition-transform duration-200 hover:scale-[1.02] sm:w-auto"
      >
        {t('cta.primary')}
      </a>
      <a
        href="mailto:info@quench-works.com?subject=App%20request"
        class="inline-flex w-full items-center justify-center rounded-lg border border-line px-5 py-3 text-sm font-semibold text-paper transition-colors duration-200 hover:bg-ink sm:w-auto"
      >
        {t('cta.request')}
      </a>
    </div>
  </div>
</section>
