---
// The /api/docs page body, localized (en/ar/es) + with the live status badges
// rendered at the top. Rendered by src/pages/api/docs.astro and its /ar /es
// counterparts; lang comes from the URL so Base handles dir/RTL + hreflang.
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { images } from '../data/images';
import { charts } from '../data/charts';
import { roadmap } from '../data/roadmap';
import { PER_PAGE } from '../pages/api/v1/_data';
import security from '../data/security.json';
import { getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const cveTotal = Object.values(security as Record<string, { total: number }>).reduce((a, r) => a + r.total, 0);
const totalPages = Math.ceil(images.length / PER_PAGE);
const pre = 'mt-3 overflow-x-auto rounded-lg border border-line bg-graphite/40 p-4 font-mono text-xs text-ash';

type Lang = 'en' | 'ar' | 'es';
const T: Record<string, Record<Lang, string>> = {
  title: { en: 'JSON API', ar: 'واجهة JSON البرمجية', es: 'API JSON' },
  intro: {
    en: 'A free, read-only JSON API over the catalog. It is prerendered as static JSON (the dataset is small and the site is static), so it is fast, cacheable, and needs no key. Base path /api/v1.',
    ar: 'واجهة JSON برمجية مجانية للقراءة فقط فوق الكتالوج. تُولَّد مسبقًا كـ JSON ثابت (المجموعة صغيرة والموقع ثابت)، فهي سريعة وقابلة للتخزين المؤقت ولا تحتاج مفتاحًا. المسار الأساسي /api/v1.',
    es: 'Una API JSON gratuita y de solo lectura sobre el catálogo. Se prerenderiza como JSON estático (el conjunto es pequeño y el sitio es estático), así que es rápida, cacheable y no requiere clave. Ruta base /api/v1.',
  },
  collections: { en: 'Collections', ar: 'المجموعات', es: 'Colecciones' },
  collectionsDesc: {
    en: 'Each resource returns its full list under a small envelope.',
    ar: 'تُعيد كل مجموعة قائمتها الكاملة داخل غلاف صغير.',
    es: 'Cada recurso devuelve su lista completa dentro de un pequeño envoltorio.',
  },
  items: { en: 'items', ar: 'عنصرًا', es: 'elementos' },
  pagination: { en: 'Pagination', ar: 'ترقيم الصفحات', es: 'Paginación' },
  paginationDesc: {
    en: `Pages are prerendered at ${PER_PAGE} items each, so the page number lives in the path (not a ?page query). Each page carries meta + links.`,
    ar: `تُولَّد الصفحات مسبقًا بـ ${PER_PAGE} عنصرًا لكل صفحة، فيكون رقم الصفحة في المسار (وليس في استعلام ?page). تحمل كل صفحة meta و links.`,
    es: `Las páginas se prerenderizan con ${PER_PAGE} elementos cada una, así que el número de página va en la ruta (no en un ?page). Cada página incluye meta + links.`,
  },
  security: { en: 'Security', ar: 'الأمان', es: 'Seguridad' },
  securityDesc: {
    en: `Live CVE counts from the ArtifactHub Trivy scan of each chart-pinned image digest, refreshed every deploy. The summary gives the catalog total + a severity rollup; every images/charts item also carries a per-item security object (${cveTotal} open CVEs catalog-wide right now).`,
    ar: `أعداد ثغرات CVE حيّة من فحص Trivy عبر ArtifactHub لكل بصمة صورة مثبَّتة في المخطط، تُحدَّث مع كل نشر. يعطي الملخص الإجمالي للكتالوج مع تجميع حسب الخطورة؛ كما يحمل كل عنصر images/charts كائن security خاصًا به (${cveTotal} ثغرة مفتوحة في الكتالوج حاليًا).`,
    es: `Conteos de CVE en vivo del escaneo Trivy de ArtifactHub sobre cada digest de imagen fijado en el chart, actualizados en cada despliegue. El resumen da el total del catálogo + un desglose por severidad; cada elemento de images/charts incluye además un objeto security propio (${cveTotal} CVE abiertos en el catálogo ahora mismo).`,
  },
  badges: { en: 'Status badges', ar: 'شارات الحالة', es: 'Insignias de estado' },
  badgesDesc: {
    en: 'shields.io endpoint badges, for any README. Live (shields fetches them on render; they refresh each deploy). Style, logo, and colors ship in the endpoint payload, so the for-the-badge look below renders with no extra query params:',
    ar: 'شارات endpoint من shields.io لأي ملف README. حيّة (يجلبها shields عند العرض؛ وتُحدَّث مع كل نشر). يأتي النمط والشعار والألوان ضمن حمولة الـ endpoint، فيظهر شكل for-the-badge أدناه دون أي معاملات استعلام إضافية:',
    es: 'Insignias endpoint de shields.io, para cualquier README. En vivo (shields las obtiene al renderizar; se actualizan en cada despliegue). El estilo, el logo y los colores van en la respuesta del endpoint, así que el aspecto for-the-badge de abajo se renderiza sin parámetros de consulta adicionales:',
  },
  examples: { en: 'Examples', ar: 'أمثلة', es: 'Ejemplos' },
  notes: { en: 'Notes', ar: 'ملاحظات', es: 'Notas' },
  note1: {
    en: 'Read-only, no auth, CORS-open, cached for an hour.',
    ar: 'للقراءة فقط، بلا مصادقة، CORS مفتوح، ومُخزَّن مؤقتًا لمدة ساعة.',
    es: 'Solo lectura, sin autenticación, CORS abierto, en caché durante una hora.',
  },
  note2: {
    en: 'Item fields match what the catalog pages show (slug, name, category, tier, license, versions, …).',
    ar: 'تطابق حقول العناصر ما تعرضه صفحات الكتالوج (slug، الاسم، الفئة، المستوى، الترخيص، الإصدارات، …).',
    es: 'Los campos de cada elemento coinciden con lo que muestran las páginas del catálogo (slug, nombre, categoría, nivel, licencia, versiones, …).',
  },
  note3: {
    en: "Server-side filtering via ?query is not offered: static hosting can't read query strings. Filter the collection client-side.",
    ar: 'لا تتوفر تصفية من جانب الخادم عبر ?query: الاستضافة الثابتة لا تقرأ سلاسل الاستعلام. صفِّ المجموعة من جانب العميل.',
    es: 'No se ofrece filtrado en el servidor vía ?query: el hosting estático no lee cadenas de consulta. Filtra la colección en el cliente.',
  },
};
const tr = (k: string) => T[k][lang as Lang] ?? T[k].en;

const resources = [
  { name: 'images', total: images.length, desc: { en: 'Hardened container images in the catalog.', ar: 'صور حاويات مُحصَّنة في الكتالوج.', es: 'Imágenes de contenedor endurecidas en el catálogo.' } },
  { name: 'charts', total: charts.length, desc: { en: 'Signed Helm charts in the catalog.', ar: 'مخططات Helm موقَّعة في الكتالوج.', es: 'Helm charts firmados en el catálogo.' } },
  { name: 'roadmap', total: roadmap.length, desc: { en: 'Apps on deck, not yet built.', ar: 'تطبيقات قادمة لم تُبنَ بعد.', es: 'Apps en cola, aún no construidas.' } },
];
const BADGE = (s: string) => `https://img.shields.io/endpoint?url=https://quench-works.com/api/v1/badge/${s}.json`;
const BADGES = ['images', 'charts', 'cves', 'wolfi', 'cosign', 'multiarch', 'artifacthub', 'license'];
---

<Base title="API · Quenchworks" description="The free QuenchWorks JSON API: hardened images, signed charts, the roadmap, and live CVE counts as paginated JSON.">
  <Header />
  <main class="mx-auto max-w-3xl px-5 py-16">
    <p class="font-mono text-xs uppercase tracking-widest text-ash">API · v1</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{tr('title')}</h1>

    <div class="mt-5 flex flex-wrap gap-2">
      {BADGES.map((s) => <img src={BADGE(s)} alt={s} />)}
    </div>

    <div class="mt-6 space-y-5 leading-relaxed text-ash">
      <p>{tr('intro')}</p>
    </div>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">{tr('collections')}</h2>
    <p class="mt-2 text-ash">{tr('collectionsDesc')}</p>
    <ul class="mt-4 space-y-2">
      {resources.map((r) => (
        <li class="font-mono text-sm">
          <a class="text-paper underline" href={`/api/v1/${r.name}.json`}>GET /api/v1/{r.name}.json</a>
          <span class="text-ash"> — {r.desc[lang as Lang] ?? r.desc.en} ({r.total} {tr('items')})</span>
        </li>
      ))}
    </ul>
    <pre class={pre}>{`{
  "apiVersion": "v1",
  "resource": "images",
  "total": ${images.length},
  "data": [ /* every item */ ]
}`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">{tr('pagination')}</h2>
    <p class="mt-2 text-ash">{tr('paginationDesc')}</p>
    <p class="mt-3 font-mono text-sm">
      <a class="text-paper underline" href="/api/v1/images/1.json">GET /api/v1/&lbrace;resource&rbrace;/&lbrace;page&rbrace;.json</a>
    </p>
    <pre class={pre}>{`{
  "apiVersion": "v1", "resource": "images",
  "page": 2, "perPage": ${PER_PAGE}, "total": ${images.length}, "totalPages": ${totalPages},
  "links": { "self": "…/2.json", "first": "…/1.json", "last": "…/${totalPages}.json", "next": "…/3.json", "collection": "/api/v1/images.json" },
  "data": [ /* this page */ ]
}`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">{tr('security')}</h2>
    <p class="mt-2 text-ash">{tr('securityDesc')}</p>
    <p class="mt-3 font-mono text-sm">
      <a class="text-paper underline" href="/api/v1/security.json">GET /api/v1/security.json</a>
    </p>
    <pre class={pre}>{`{
  "apiVersion": "v1", "resource": "security",
  "total": ${cveTotal},
  "bySeverity": { "critical": 0, "high": 0, "medium": 0, "low": 0, "unknown": 0 },
  "imagesWithCves": 0,
  "images": { "<name>": { "critical": 0, "high": 0, "medium": 0, "low": 0, "unknown": 0, "total": 0 } }
}

# per-item too: each images/charts entry gains a "security" field
curl https://quench-works.com/api/v1/images.json | jq '.data[] | {slug, security}'`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">{tr('badges')}</h2>
    <p class="mt-2 text-ash">{tr('badgesDesc')}</p>
    <pre class={pre}>{BADGES.map((s) => `![${s}](${BADGE(s)})`).join('\n')}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">{tr('examples')}</h2>
    <pre class={pre}>{`curl https://quench-works.com/api/v1/images.json
curl https://quench-works.com/api/v1/charts/2.json
curl https://quench-works.com/api/v1/security.json`}</pre>

    <h2 class="mt-12 text-2xl font-bold tracking-tight">{tr('notes')}</h2>
    <ul class="mt-3 list-disc space-y-1 ps-5 text-ash">
      <li>{tr('note1')}</li>
      <li>{tr('note2')}</li>
      <li>{tr('note3')}</li>
    </ul>
  </main>
  <Footer />
</Base>
