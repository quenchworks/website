---
// Hero: minimal single column, one primary CTA (per MASTER design system).
import { availableCount } from '../data/images';
import { chartCount } from '../data/charts';
import { githubStars } from '../data/github';
import { fetchArtifactHub } from '../data/artifacthub';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
// shipped end-to-end = apps with both an available image and a chart.
const shipped = Math.min(availableCount, chartCount);

// LIVE CVE total across the catalog, summed from ArtifactHub's per-package Trivy
// summaries (never hardcoded). If AH is unreachable (no data), fall back to the
// static "0 fixable CVEs" claim so the hero never shows a false count.
const ahFacts = await fetchArtifactHub();
const ahKeys = Object.keys(ahFacts);
const cveTotal = ahKeys.reduce((s, k) => s + (ahFacts[k].securityTotal ?? 0), 0);
const cveLive = ahKeys.length > 0; // we actually got scan data back

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const chartsHref = getRelativeLocaleUrl(lang, '/charts');
---

<section class="relative overflow-hidden">
  <!-- subtle layered-cube backdrop motif -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.06]"
    style="background-image:radial-gradient(var(--color-paper) 1px,transparent 1px);background-size:28px 28px;"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-5xl px-5 pb-20 pt-20 text-center sm:pt-28">
    <p class="mb-5 font-mono text-xs uppercase tracking-[0.25em] text-ash">
      <span class="font-bold tabular-nums text-paper">{availableCount}</span> {t('hero.statImages')} ·
      <span class="font-bold tabular-nums text-paper">{chartCount}</span> {t('hero.statCharts')} · {
        cveLive && cveTotal > 0 ? (
          <><span class="font-bold tabular-nums text-amber-400">{cveTotal}</span> {cveTotal === 1 ? 'open CVE' : 'open CVEs'}</>
        ) : (
          t('hero.statCves')
        )
      }{
        githubStars !== null && (
          <>
            {' '}· <span class="text-paper" aria-hidden="true">★</span>{' '}
            <span class="font-bold tabular-nums text-paper">{githubStars}</span>
          </>
        )
      }
    </p>

    <h1 class="mx-auto max-w-3xl text-balance text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
      {t('hero.title')}
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-pretty text-base leading-relaxed text-ash sm:text-lg">
      <span class="font-bold tabular-nums text-paper">{shipped}</span> {t('hero.subtitle')}
    </p>

    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={chartsHref}
        class="inline-flex w-full items-center justify-center rounded-lg bg-paper px-5 py-3 text-sm font-semibold text-ink transition-transform duration-200 hover:scale-[1.02] sm:w-auto"
      >
        {t('hero.cta.primary')}
      </a>
      <a
        href="https://github.com/quenchworks"
        class="inline-flex w-full items-center justify-center rounded-lg border border-line px-5 py-3 text-sm font-semibold text-paper transition-colors duration-200 hover:bg-graphite sm:w-auto"
      >
        {t('hero.cta.secondary')}
      </a>
    </div>

    <!-- terminal card -->
    <div class="mx-auto mt-14 max-w-2xl overflow-hidden rounded-xl border border-line bg-graphite text-start">
      <div class="flex items-center gap-2 border-b border-line px-4 py-3">
        <span class="size-3 rounded-full border border-line"></span>
        <span class="size-3 rounded-full border border-line"></span>
        <span class="size-3 rounded-full border border-line"></span>
        <span class="ms-2 font-mono text-xs text-ash">install &amp; verify</span>
      </div>
      <pre class="overflow-x-auto px-4 py-4 font-mono text-[13px] leading-relaxed text-paper"><code><span class="text-ash"># add the chart (OCI) and install</span>
helm install my-redis oci://ghcr.io/quenchworks/charts/redis

<span class="text-ash"># verify the image was built &amp; signed by CI before you trust it</span>
cosign verify ghcr.io/quenchworks/images/redis:8.8.0 \
  --certificate-identity-regexp 'https://github.com/quenchworks/.+' \
  --certificate-oidc-issuer https://token.actions.githubusercontent.com</code></pre>
    </div>
  </div>
</section>
