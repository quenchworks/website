---
/**
 * Kbd — a key-cap for keyboard shortcuts, e.g. <Kbd>⌘K</Kbd>.
 * Matches the search hint cap in Search.astro (border-line, bg-ink, mono).
 */
---

<kbd
  class="inline-flex items-center rounded border border-line bg-ink px-1.5 py-0.5 font-mono text-[0.75em] leading-none text-ash"
>
  <slot />
</kbd>
