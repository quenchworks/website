---
/**
 * Pagination shell. The container is filled client-side by
 * `src/scripts/paginate.ts` (createPaginator) since the catalog
 * filters/searches on the client. Renders nothing visible until JS
 * populates the controls (and only when there is more than one page).
 */
interface Props {
  /** id used by the page script to find this nav. */
  id?: string;
}
const { id = 'pagination' } = Astro.props;
---

<nav
  id={id}
  class="mt-10 flex flex-wrap items-center justify-center gap-1.5"
  aria-label="Pagination"
  hidden
>
</nav>
